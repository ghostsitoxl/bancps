function downloadMovementSwift(numberProduct, url) {
	var date=new Date();
	cDay = date.getDate();
	cMonth = date.getMonth();
	cMonth = cMonth+1;
	if((String(cDay)).length==1)
	{
		cDay = '0'+cDay;
	}
	if((String(cMonth)).length==1)
	{
		cMonth='0'+cMonth;
	}
	var today = cDay+cMonth+date.getFullYear()+date.getHours()+date.getMinutes()+date.getSeconds();
	var params = 'numberAccount=' + numberProduct;
	var req = new XMLHttpRequest();
	req.open("POST", url, true);
	req.responseType = "blob";
	req.setRequestHeader("Content-type", "application/x-www-form-urlencoded");
	req.onload = function () {
		if(req.status === 200){
			var blob = req.response;
			var fileName = "comprobante-swift-" + numberProduct + '-' + today +'.pdf';
			downloadAllReport(blob, fileName);
		}else{
			console.log(req.response)
			showModalGenericError("No se pudo encontrar el comprobante");
		}
	};
	req.send(params);
}