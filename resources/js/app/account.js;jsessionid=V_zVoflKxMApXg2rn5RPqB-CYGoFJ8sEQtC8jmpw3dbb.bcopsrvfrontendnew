function saveRequestExtractsMail(checkVal,mailInvoiceSelected,
		mailExtractSelected,schedule,mediumInvoice,mediumExtract,frequency,format){
	var info = [];
	var invoice = {};
	var extract = {};
	if(mediumInvoice === "DESCARGA"){
		mailInvoiceSelected = null;
	}
	if(mediumExtract === "DESCARGA"){
		mailExtractSelected = null;
	}
	invoice.correoElectronico = mailInvoiceSelected;
	invoice.medioEnvio = mediumInvoice;
	invoice.tipoComprobante = "FACTURA";
	extract.correoElectronico = mailExtractSelected;
	extract.medioEnvio = mediumExtract;
	extract.tipoComprobante = "EXTRACTO";
	info.push(invoice);
	info.push(extract);
	$.ajax({
		type:"POST",
		url:  appname+'/invoice/modifyRequestExtractsMail',
		data: {
			schedule: schedule,
			status: checkVal,
			frequency: frequency,
			format: format,
			info : JSON.stringify(info)
		}					
	}).done(function(data){		
		var msg = 'Datos guardados correctamente';
		showModalDataActualization(msg);
	}).fail(function(request, status, error){
		var errorData = request.responseJSON;
		ajaxErrorHandler(errorData, status, error, ID_GENERIC_ERROR);		
	});
}

function verifyDataExtractEmail(mediumInvoice,mediumExtract,mailInvoiceSelected,mailExtractSelected,frequency,schedule,format){
	var obj = {status:"ok",msg:""};
	
	if(mediumInvoice === "0"  && mailInvoiceSelected !== undefined){
		obj.status = "error";
		obj.msg = "Debe seleccionar un Medio de Envio para la Factura";
		return obj;
	}else if(mediumInvoice === "CORREO" &&  mailInvoiceSelected === undefined){
		obj.status = "error";
		obj.msg = "Debe seleccionar un Correo para la Factura";
		return obj;
	}else if(mediumInvoice === "0" && mailInvoiceSelected === undefined){
		obj.status = "error";
		obj.msg = "Debe seleccionar un Medio de Envio para la Factura";
		return obj;
	}
	if(mediumExtract === "0"  && mailExtractSelected !== undefined){
		obj.status = "error";
		obj.msg = "Debe seleccionar un Medio de Envio para el Extracto";
		return obj;
	}else if(mediumExtract === "CORREO" &&  mailExtractSelected === undefined){
		obj.status = "error";
		obj.msg = "Debe seleccionar un Correo para el Extracto";
		return obj;
	}else if(mediumExtract === "0" && mailExtractSelected === undefined){
		obj.status = "error";
		obj.msg = "Debe seleccionar un Medio de Envio para el Extracto";
		return obj;
	}
	if(frequency === "0"){
		obj.status = "error";
		obj.msg = "Debe seleccionar una Frecuencia";
		return obj;
	}else if(frequency === "DIARIA" && schedule === "0"){
		obj.status = "error";
		obj.msg = "Debe seleccionar un Horario de Envio";
		return obj;
	}
	
	if(format === "0"){
		obj.status = "error";
		obj.msg = "Debe seleccionar un formato de Impresión";
		return obj;
	}
	return obj;
}

