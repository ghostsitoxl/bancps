//función para obtener movimientos y todos los datos de una cuenta
function getAccount(idProducto)
{
	var fields = {
            numberAccount: idProducto,            
    }
    var $form = $('<form>', {
        action: appname+'/account',
        method: 'post'
    }).append(
            $.map(fields, function (val, key) {
                return $('<input>').attr({
                    type: "hidden",
                    name: key,
                    value: val
                })
            })
    )
    $form.appendTo('body').submit();
}
/************************************************************************
 *  
 *  Función que llama al controller mediante ajaxpara mostrar los 
 *  detalles de movimiento del registro del producto pasado como 
 *  parámetro y lo muestra en pantalla.
 *  idModal: id del modal a mostrar.
 *  idContent: id del contenedor donde injectar el html retornado como respuesta.
 *  fileNameProduct: nombre del archivo a descargar.
 *  userCode, date, hour, sequenceNumber: parámetros que necesita el servicio API
 *  se envía en un wrapper.
 *  url: url del método a llamar en el controller.
 ************************************************************************/
function getMovementDetail(idModal, idContent, userCode, date, hour, dateFlag, hourFlag, sequenceNumber,ref, url, swift)
{
	console.log('Swift ', swift)
	var numberAccount = $("#numberAccount").val();
	$.ajax({
		type:"POST",
		url: url,
		data: {
			numberProduct: numberAccount,
			userCode: userCode,
			date: date,	
			hour: hour,
			dateFlag: dateFlag,
			hourFlag: hourFlag,
			sequenceNumber: sequenceNumber,
			refVoucher : ref,
			swift: swift
		}					
	}).done(function(data){
		$("#"+idContent).html(data);
		$("#"+idModal).modal("show");
	}).fail(function(request, status, error){
		var errorData = request.responseJSON;
		ajaxErrorHandler(errorData, status, error, ID_GENERIC_ERROR);		
	});		
}

/************************************************************************
 *  
 *  Función para descargar en pdf los detalles del movimiento del producto.
 *  numberProduct: número de la cuenta.
 *  fileNameProduct: nombre del archivo a descargar.
 *  userCode, date, hour, sequenceNumber: parámetros que necesita el servicio API
 *  se envía en un wrapper.
 *  url: url del método a llamar en el controller.
 ************************************************************************/
function downloadMovementDetails(numberProduct, fileNameProduct, userCode, movementDate, hour, dateFlag, hourFlag, sequenceNumber,refVoucher, url)
{		
	var date=new Date();
    cDay = date.getDate();
    cMonth = date.getMonth();
    cMonth = cMonth+1;
    if((String(cDay)).length==1)
    {
    	cDay = '0'+cDay;
    }
    if((String(cMonth)).length==1)
    {
    	cMonth='0'+cMonth;
    }
	var today = cDay+cMonth+date.getFullYear()+date.getHours()+date.getMinutes()+date.getSeconds();
    var params = 'numberProduct=' + numberProduct + '&date=' + movementDate + '&dateFlag=' + dateFlag + '&userCode=' +
    	userCode + '&hour=' + hour + '&hourFlag=' + hourFlag + '&sequenceNumber=' + sequenceNumber + '&refVoucher='+ refVoucher;
    var req = new XMLHttpRequest();
    req.open("POST", url, true);
    req.responseType = "blob";
    req.setRequestHeader("Content-type", "application/x-www-form-urlencoded");
    req.onload = function () {
    	if(req.status === 200){
    		 var blob = req.response;
    	     var fileName = fileNameProduct + numberProduct + '-' + today +'.pdf';
    	     downloadAllReport(blob, fileName);
    	}else{
    		showModalGenericError("Error al generar el Comprobante");
    	}
    };
    req.send(params);	
}

