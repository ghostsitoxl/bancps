function downloadServicesPaymentReport(numberOperation, tokenTransactionPS){
	var params = 'numberOperation=' + numberOperation + '&tokenTransaction=' + tokenTransactionPS;
	console.log("Parametros enviados: ", params);
    var req = new XMLHttpRequest();
    req.open("POST", appname + "/services/servicespdf", true);
    req.responseType = "blob";
    req.setRequestHeader("Content-type", "application/x-www-form-urlencoded");
    req.onload = function () {
    	if(req.status === 200){
    		var blob = req.response;
            var fileName = 'pago-servicios' + '-' + numberOperation + '.pdf';
            downloadAllReport(blob, fileName);
    	}else{
    		showModalGenericError("Error al generar el Comprobante");
    	}
    };
    req.send(params);
}

