            $("div.step-4-right-container").height(height);
            var height1 = $("div.step-5-left").height();
            $("div.pos-5-right").height(height1);
            $("div.step-5-right").height(height1);

            TEXT_SERVICE = $("#dataChargedPaymentService").text();
        } else if (detailSubService !== undefined && detailSubService.value === "false") {
            $("#nameClassification-step-5").text(CLASSIFICATION_NAME);
            $('#numberCuenta-step-5').text(PRODUCT_TEXT);
            $("#nameService-step-5").text(SERVICE_NAME);
            var height = $("div.step-4-left-container").height();
            $("div.step-4-right-container").height(height);
            var height1 = $("div.step-5-left").height();
            $("div.pos-5-right").height(height1);
            $("div.step-5-right").height(height1);

            TEXT_SERVICE = $("#dataChargedPaymentService").text();
        } else {
            $("#step-5").html("");
            $("#step-5").addClass("hidden");
            $("#step-4").removeClass("hidden");
            $(".service-detail").html(data);
            $(".service-detail").removeClass("hidden");
            $("#buttonProcessPayment").addClass("hidden");
            $(".button-detail-process").addClass("hidden");
            var height1 = $("div.step-4-left").height();
            $("div.pos-4-right").height(height1);
            $("div.step-4-right").height(height1);
            $("div.step-4-right").removeClass("icon-div-selected");

        }

    }).fail(function (request, status, error) {
        $(".loader").addClass("hidden");
        $("#buttonProcessPayment").removeAttr("disabled");
        var errorData = request.responseJSON;
        ajaxErrorHandler(errorData, status, error, ID_GENERIC_ERROR);
    });
}
