//metodo que envia la cuenta seleccionada en el acceso directo de los servicios
function getServicesPaymentSelected(accountNumber) {
    var fields = {
        account: accountNumber,
        cname: CLASSIFICATION_CODE,
        service_id: COD_SERVICE
    }
    var $form = $('<form>', {
        action: '/bancop/services/selected',
        method: 'post'
    }).append(
            $.map(fields, function (val, key) {
                return $('<input>').attr({
                    type: "hidden",
                    name: key,
                    value: val
                })
            })
            )
    $form.appendTo('body').submit();

}
