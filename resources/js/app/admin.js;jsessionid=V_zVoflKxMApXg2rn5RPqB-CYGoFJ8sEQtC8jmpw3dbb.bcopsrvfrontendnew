function loadRolPermisions(uuid) {

    $.ajax({
        type: "POST",
        url: appname + "/admin/lista-rol-permisions",
        data: {
            uuid: uuid,
        }
    }).done(function (data) {
        $(".permiso-item").each(function () {
            data.forEach(function (element) {
                if (element.checked === 'false') {
                    $(this).find(".excelent").attr('hidden', true);
                } else {
                    $(this).find(".excelent").attr('hidden', false);
                }
            })

        })


    }).fail(function (request, status, error) {
        var errorData = request.responseJSON;
        ajaxErrorHandler(errorData, status, error, ID_GENERIC_ERROR);
    });
}

function showFullFillError(emptyField){
    var msg = 'Debe ingresar un '+emptyField;
    $("#fullfillError").hide();
    $("#fullfillError").show();
    $("#fullfillError").removeClass("hidden");
    $("#msg").text(msg);
    $('html, body').animate({scrollTop: 0}, 800);
}

function showSucessMessage(message){
    var msg = message;
    $("#sucessMessage").hide();
    $("#sucessMessage").show();
    $("#sucessMessage").removeClass("hidden");
    $("#smsg").text(msg);
    $('html, body').animate({scrollTop: 0}, 800);
}

function Producto(idProduct, nombre){
