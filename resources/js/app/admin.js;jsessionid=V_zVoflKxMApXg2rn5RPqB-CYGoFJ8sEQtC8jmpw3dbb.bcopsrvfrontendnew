}

function cleanFields(){
    $("#roleName").val("");
    $("#maxTransAmmount").val("");
    $("#maxDayAmmount").val("");

    $(".check-permiso").each(function(){
        $(this).prop("checked",false);
    })

    resetAuts();
}

function resetAuts(){
    $("#aut-class").each(function(){
        $(this).val("");
    });

    $("#row-aut").each(function(){
        $(this).addClass("hidden");
    })

    $("#cantAutorizations").addClass("hidden")
}


