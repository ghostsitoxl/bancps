function getAccount(accountNumber) {
    var fields = {
        numberAccount: accountNumber
    }
    var $form = $('<form>', {
        action: appname + '/account',
        method: 'post'
    }).append(
        $.map(fields, function (val, key) {
            return $('<input>').attr({
                type: "hidden",
                name: key,
                value: val
            })
        })
    )
    $form.appendTo('body').submit();
}

