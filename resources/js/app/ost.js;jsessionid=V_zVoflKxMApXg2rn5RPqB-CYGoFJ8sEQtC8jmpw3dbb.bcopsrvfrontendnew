function loadAction(accountNumber, phoneNumber, action, currency) {
    $("#phoneSelected").val(phoneNumber);
    $("#accountSelected").val(accountNumber);
    $("#currencySelected").val(currency);
    $("#action").val(action);

    if(action == 'D') {
        $("#modalTitle").html("Cancelar Servicio");
        $("#modalBody").html("¿Está seguro que desea cancelar el enlace entre su cuenta y su número de teléfono?");

    } else if (action == 'L') {
        $("#modalTitle").html("Bloqueo Temporal");
        $("#modalBody").html("¿Está seguro que desea bloquear su cuenta asociada?");

    } else if (action == 'U') {
        $("#modalTitle").html("Desbloquear");
        $("#modalBody").html("¿Está seguro que desea desbloquear su cuenta asociada?");

    } else if (action == 'R') {
        $("#modalTitle").html("Regenerar PIN");
        $("#modalBody").html("¿Está seguro que desea regenerar su PIN?");

    }

    $('#modalAction').modal();
}

function registerAction(redirect) {
    $('.loader').removeClass('hidden');
    let phoneNumber = $("#phoneSelected").val();
    let accountNumber = $("#accountSelected").val();
    let currency = $("#currencySelected").val();
    let action = $("#action").val();

    $.ajax({
        url: appname + '/ost/associate/update',
        type: 'POST',
        data: {
            phoneNumber: phoneNumber,
            accountNumber: accountNumber,
            currency: currency,
            action: action
        },
        success: function (result) {
            if(result.hasError){
                ajaxErrorHandler(result.errorBody, "", "", ID_GENERIC_ERROR);
            }
            else {
                if(redirect == 'ACCOUNT') {
                    getAccount(accountNumber);
                } else {
                    getOST();
                }

            }
        },
        error: function(request, status, error){
            var errorData = request.responseJSON;
            ajaxErrorHandler(errorData, status, error, ID_GENERIC_ERROR);
        },
        complete: function () {
            $('.loader').addClass('hidden');
        }
    });

}

