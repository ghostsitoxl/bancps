function registerOST(accountNumber, phoneNumber, currencyIso, action) {

    $(".loader").removeClass("hidden");
    $("#buttonSelectPhone").attr("disabled","disabled");
    $.ajax({
        type: "POST",
        url: appname + "/ost/associate/register",
        data: {
            accountNumber: accountNumber,
            phoneNumber: phoneNumber,
            currencyIso: currencyIso,
            action: action
        }
    }).done(function (data) {
        $("#step-1").addClass("hidden");
        $(".loader").addClass("hidden");
        $("#buttonSelectPhone").removeAttr("disabled");
        $("#step-2").html(data);
        $("#step-2").removeClass("hidden");

        var height1 = $("div.step-31-left").height();
        height1 = height1 + 20;
        $("div.step-31-right").css('height', height1);

        var height2 = $("div.step-32-left").height();
        height2 = height2 + 20;
        $("div.step-32-right").css('height', height2);

        var height3 = $("div.step-3-left").height();
        height3 = height3 + 20;
        $("div.step-3-right").css('height', height3);

    }).fail(function (request, status, error, response) {
        $(".loader").addClass("hidden");
        //goBackToStepOneOST();

        $("#buttonSelectPhone").removeAttr("disabled");
        console.log(request);
        console.log(response);
        console.log(error);
        console.log(status);
        $("#container-main").css('margin-top', '0px');
        var errorData = request.responseJSON;
        ajaxErrorHandler(errorData, status, error, "genericError");

    })
}

