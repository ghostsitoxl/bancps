function formatUSDQuotations(elem, decimals){
    var value = elem.toString();
    //value = value.replace(/\./g, '')MVAM NHB-6
    value = value.replace(/,/g, '.')
    value = value.replace(/[^0-9\.]+/g, '')
    var number = value.split('.')
    var formattedString = number[0].replace(/\B(?=(\d{3})+\b)/g, ".")
    if (decimals == 'true') {
        if (value.indexOf('.') > 0 && value.indexOf('.') == value.length - 1) {
            formattedString += ','
        } else if (number[1] !== undefined) {
            formattedString += ',' + number[1].substring(0, 2)
        }
    }
    return formattedString;
}

