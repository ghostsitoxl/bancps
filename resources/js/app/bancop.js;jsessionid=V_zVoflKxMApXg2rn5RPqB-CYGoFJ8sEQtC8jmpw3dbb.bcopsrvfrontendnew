//Ofusca los datos según acuerdo y según el canal recibido como parámetro.
function shorten(canal) {
    var value = "";
    if (canal === 'MAIL') {
        $("input[name=mail]").each(function (index) {
            value = $(this).val();
            var vector = value.split("@", 2);
            value = value.substr(0, 2) + "****" + vector[0].substr(vector[0].length - 2, 2) + "@" + vector[1];
            $("#label_mail_" + index).text(value);
        });
    } else {
        $("input[name=phone]").each(function (index) {
            value = $(this).val();
            value = value.substr(0, 3) + "*****" + value.substr(value.length - 2, 2);
            $("#label_phone_" + index).text(value);
        });
    }
}

/*****************************************************************************
 * Contiene toda la lógica para el drag and drop de las cajitas del dashboard
 *
 * ***************************************************************************/
function handleDragStart(e) {
    //this.style.opacity = '0.4';  // this / e.target is the source node.

    dragSrcEl = this;

    e.dataTransfer.effectAllowed = 'move';
    e.dataTransfer.setData('text/html', this.innerHTML);
}

function handleDragOver(e) {
    if (e.preventDefault) {
        e.preventDefault(); // Necessary. Allows us to drop.
    }

    e.dataTransfer.dropEffect = 'move';  // See the section on the DataTransfer object.

    return false;
}

function handleDropPendingAuthorization(e) {
    // this / e.target is current target element.
    if (e.stopPropagation) {
        e.stopPropagation(); // stops the browser from redirecting.
    }
    var notDraggable = $(this).hasClass('not-draggable');
    if (!notDraggable) {
        if (dragSrcEl != this) {
            // Set the source column's HTML to the HTML of the columnwe dropped
            // on.
            dragSrcEl.innerHTML = this.innerHTML;
            this.innerHTML = e.dataTransfer.getData('text/html');

            return false;
        }
    }
}

function handleDrop(e) {
    // this / e.target is current target element.
    if (e.stopPropagation) {
        e.stopPropagation(); // stops the browser from redirecting.
    }
    var notDraggable = $(this).hasClass('not-draggable');
    if (!notDraggable) {
        // Don't do anything if dropping the same column we're dragging.
        if (dragSrcEl != this) {
            var idHeaderWhite = $(dragSrcEl).find("header").attr('id');
            var idHeaderBlue = $(this).find("header").attr('id');

            if (idHeaderWhite != idHeaderBlue) {
                var idBegin = $(dragSrcEl).find("input").attr('id');
                var begin = idBegin.split("-");
                // Set the source column's HTML to the HTML of the columnwe dropped on.
                dragSrcEl.innerHTML = this.innerHTML;

                var idEnd = $(this).find("input").attr('id');
                var end = idEnd.split("-");

                var idDivBegin = "#" + begin[0] + "-" + begin[1];
                var valueBegin = begin[0] + "-" + begin[1] + "-" + end[2] + "-" + end[3];
                $(idDivBegin + " input").attr('id', valueBegin);

                updatePositionProducts(begin[2], begin[3], end[0], end[1]);
                this.innerHTML = e.dataTransfer.getData('text/html');
                var idDivEnd = "#" + end[0] + "-" + end[1];
                var valueEnd = end[0] + "-" + end[1] + "-" + begin[2] + "-" + begin[3];
                $(idDivEnd + " input").attr('id', valueEnd);
                return false;
            }
        }
    }
    // See the section on the DataTransfer object.

    /*return false;*/
}

function handleDragEnd(e) {
    // this/e.target is the source node.

    [].forEach.call(cols, function (col) {
        col.classList.remove('over');
    });
}

function handleDragEnter(e) {
    // this / e.target is the current hover target.
    this.classList.add('over');
}

function handleDragLeave(e) {
    this.classList.remove('over');  // this / e.target is previous target element.
}


