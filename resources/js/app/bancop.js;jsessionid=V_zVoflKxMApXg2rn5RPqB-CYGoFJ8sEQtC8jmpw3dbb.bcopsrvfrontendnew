function getTransferencias(idProducto) {

    if (idProducto === "") {
        idProducto = "0";
    }
    var fields = {
        numberProduct: idProducto,
    }
    var $form = $('<form>', {
        action: appname + '/transfer',
        method: 'post',
    }).append(
        $.map(fields, function (val, key) {
            return $('<input>').attr({
                type: "hidden",
                name: key,
                value: val
            })
        })
    )
    $form.appendTo('body').submit();
