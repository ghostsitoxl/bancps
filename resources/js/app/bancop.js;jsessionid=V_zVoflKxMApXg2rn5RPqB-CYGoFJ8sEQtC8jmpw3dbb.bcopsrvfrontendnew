function validateScheduledTransfer() {
    if (!$("#schedule-transfer").is(':checked')) {
        return true; // No es programada
    }
    
    var frequency = $("#scheduled-frequency").val();
    var startDate = $("#scheduled-date").val();
    var endDate = $("#scheduled-end-date").val();
    
    if (!frequency || frequency === "") {
        showModalGenericError("Debe seleccionar una frecuencia");
        return false;
    }
    
    if (!startDate || startDate === "") {
        showModalGenericError("Debe seleccionar una fecha de inicio");
        return false;
    }

    // Para frecuencias recurrentes, fecha de fin es obligatoria
    if (frequency !== "UNICA") {
        if (!endDate || endDate === "") {
            showModalGenericError("Debe seleccionar una fecha de finalización para transferencias recurrentes");
            return false;
        }
        
        // Validar que fecha fin sea mayor a fecha inicio
        var startParts = startDate.split('/');
        var endParts = endDate.split('/');
        var startDateObj = new Date(startParts[2], startParts[1] - 1, startParts[0]);
        var endDateObj = new Date(endParts[2], endParts[1] - 1, endParts[0]);
        
        if (endDateObj <= startDateObj) {
            showModalGenericError("La fecha de finalización debe ser posterior a la fecha de inicio");
            return false;
        }
    }
    
    // Si el checkbox de mensaje está marcado
    if ($("#scheduled-message-enabled").is(':checked')) {
        var phone = $("#scheduled-phone").val();
        var email = $("#scheduled-email").val();
        var message = $("#scheduled-message").val();
        
        if (!phone && !email) {
            showModalGenericError("Debe ingresar al menos un teléfono o email para notificación");
            return false;
        }
        
        // Validar formato de email si está presente
        if (email && !validateEmail(email)) {
            showModalGenericError("Ingrese un email válido");
            return false;
        }

        if (!message || message.trim() === "") {
            showModalGenericError("Debe ingresar el mensaje");
            return false;
        }
    }
    
    return true;
}

