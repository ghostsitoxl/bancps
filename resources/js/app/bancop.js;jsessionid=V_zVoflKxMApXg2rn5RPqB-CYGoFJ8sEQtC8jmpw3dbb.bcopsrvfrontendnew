//error genérico ajax.
function ajaxErrorHandler(errorData, status, error, idError, alternativeMessaje) {
    $('html, body').animate({scrollTop: 0}, 800);

    if (error == ERROR_FORBIDDEN) {	// forbidden
        window.location = appname + "/";
    }
    var msg = "";
    if (errorData !== undefined) {
        if (errorData.useApiMessage) {
            msg = errorData.message;
        } else if(alternativeMessaje !== undefined && alternativeMessaje !== ""){
            msg = alternativeMessaje;
        }
        else
            msg = ERROR_UNEXPECTED;
    } else if(alternativeMessaje !== undefined && alternativeMessaje !== ""){
        msg = alternativeMessaje;
    }
    else
