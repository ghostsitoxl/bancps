function populateMasOpcionesFromMenu(containerId) {
    var gridContainer = $('#' + containerId + ' .accesos-directos-grid');
    
    if (gridContainer.length === 0) {
        console.warn('No se encontró el contenedor con id: ' + containerId);
        return;
    }
    
    // Limpiar contenido existente
    gridContainer.empty();
    
    // Buscar todos los enlaces del menú lateral
    var menuItems = $('.icon-bar.operations-options a.border-a-operations-left');
    
    if (menuItems.length === 0) {
        console.warn('No se encontraron items en el menú lateral');
        return;
    }
    
    // Clonar y transformar cada item del menú
    menuItems.each(function() {
        var $originalItem = $(this);
        
        // Extraer información del item original
        var href = $originalItem.attr('href') || '#';
        var onclick = $originalItem.attr('onclick') || '';
        var icon = $originalItem.find('i:first').attr('class') || '';
        var tooltipText = $originalItem.find('.tooltiptext').text().trim();
        
        // Crear el nuevo elemento para el grid
        var $newItem = $('<a></a>')
            .addClass('acceso-directo-item')
            .attr('href', href);
        
        // Agregar onclick si existe
        if (onclick) {
            $newItem.attr('onclick', onclick);
        }
        
        // Agregar el icono (sin la flecha azul del menú original)
        var iconClass = icon.replace('icon-arrow-operations-blue', '').trim();
        var $icon = $('<i></i>').addClass(iconClass);
        
        // Agregar el texto
        var $span = $('<span></span>').text(tooltipText);
        
        // Ensamblar el item
        $newItem.append($icon).append($span);
        
        // Agregar al contenedor grid
        gridContainer.append($newItem);
    });
    
    console.log('Menú "Más opciones" poblado con ' + menuItems.length + ' items');
}

/**
 * Inicializa el componente "Más opciones" en una página
 * @param {string} containerId - ID del contenedor mas-opciones
 */
function initMasOpciones(containerId) {
    // Poblar el grid desde el menú existente
    populateMasOpcionesFromMenu(containerId);
    
    // Activar el toggle
    activarMasOpcionesToggle(containerId);
}