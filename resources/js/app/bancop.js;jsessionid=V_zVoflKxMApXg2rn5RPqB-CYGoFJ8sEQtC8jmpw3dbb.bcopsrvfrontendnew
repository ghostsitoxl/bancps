function downloadMovements(numberProduct, fileNameProduct, idMonth, url) {
    var disabled = $(".icon-download").hasClass("disabled");
    if (!disabled) {
        var month = $("#" + idMonth).val();
        var date = new Date();
        cDay = date.getDate();
        cMonth = date.getMonth();
        cMonth = cMonth + 1;
        if ((String(cDay)).length == 1) {
            cDay = '0' + cDay;
        }
        if ((String(cMonth)).length == 1) {
            cMonth = '0' + cMonth;
        }
        var today = cDay + cMonth + date.getFullYear() + date.getHours() + date.getMinutes() + date.getSeconds();
        var params = 'numberProduct=' + numberProduct + '&month=' + month;
        var req = new XMLHttpRequest();
        req.open("POST", url, true);
        req.responseType = "blob";
        req.setRequestHeader("Content-type", "application/x-www-form-urlencoded");
        req.onload = function () {
        	if(req.status === 200){
        		 var blob = req.response;
                 var fileName = fileNameProduct + '-' + today + '.xls';
                 downloadAllReport(blob, fileName);
        	}else{
        		showModalGenericError("Error al generar el Comprobante");
        	}
        };
        req.send(params);
    }
}

//recibe un Date y retorna un fecha en string
function getDate(date) {
    var day = date.getDate();
    var month = date.getMonth();
    month = month + 1;
    if ((String(day)).length == 1) {
        day = '0' + day;
    }
    if ((String(month)).length == 1) {
        month = '0' + month;
    }
    var d = day + "/" + month + "/" + date.getFullYear();
    return d;
}

//función que retorna la cantidad de meses que hay entre dos fechas pasadas por parámetro.
function getNumberOfMonths(date1, date2) {
    var d1 = date1.split("/");
    var d2 = date2.split("/");
    //se calcula el número de meses transcurridos entre dos fechas.
    var numMonths = Math.abs(((parseInt(d2[2]) * 12) + parseInt(d2[1])) - ((parseInt(d1[2]) * 12) + parseInt(d1[1])));
    return numMonths;
}

//función para formatear montos con (.) como separador de miles y 
//(,) para los decimales si hubiere.
function numberFormat(amount, decimals) {

    amount += ''; // por si pasan un numero en vez de un string
    amount = parseFloat(amount.replace(/[^0-9\.]/g, '')); // elimino cualquier cosa que no sea numero o punto

    decimals = decimals || 0; // por si la variable no fue fue pasada

    // si no es un numero o es igual a cero retorno el mismo cero
    if (isNaN(amount) || amount === 0)
        return parseFloat(0).toFixed(decimals);

    // si es mayor o menor que cero retorno el valor formateado como numero
    amount = '' + amount.toFixed(decimals);

    var amount_parts = amount.split('.'),
        regexp = /(\d+)(\d{3})/;

    while (regexp.test(amount_parts[0]))
        amount_parts[0] = amount_parts[0].replace(regexp, '$1' + '.' + '$2');

    return amount_parts.join(',');
}

