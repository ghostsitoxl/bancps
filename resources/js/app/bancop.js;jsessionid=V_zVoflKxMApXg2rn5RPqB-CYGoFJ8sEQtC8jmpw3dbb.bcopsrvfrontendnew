                    tr = "<tr class='div-error-background-orange row'>".concat(comprobante, description, account, pendings, amount, status, "</tr>");
                }else{
                    status = "<td class='text-align-left col-xs-3 col-md-3'>".concat(valAuth === "<span class='label-green glyphicon glyphicon-ok'></span>" ? "Autorización Procesada Correctamente" : "Proceso Pendiente de Aprobación", "</td>", "</td>");
                    tr = "<tr class='row'>".concat(comprobante, description, account, pendings, amount, status, "</tr>");
                }
            }else{
                tr = "<tr class='div-error-background-orange row'>".concat(comprobante, description, account, pendings, amount, status, "</tr>");
            }
        } else {
            tr = "<tr class='row'>".concat(comprobante, description, account, pendings, amount, status, "</tr>");
        }
        trs = trs.concat(tr);
    }
    htmlDetail = htmlDetail.concat("<tbody>", trs, "</tbody>");
    htmlDetail = htmlDetail.concat("</table>");
    $("#div-detail").append(htmlDetail);
