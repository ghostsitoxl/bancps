function formatDateToShow(dateStr) {
    try {
        const date = new Date(dateStr);

        if (isNaN(date.getTime())) {
            return dateStr;
        }

        const day = String(date.getDate()).padStart(2, '0');
        const month = String(date.getMonth() + 1).padStart(2, '0');
        const year = date.getFullYear();

        return `${day}/${month}/${year}`;
    } catch (e) {
        return dateStr;
    }
}

/**
 * Función genérica para capturar y validar datos de transferencia programada
 * 
 * @param {string} tipoTransferencia - Tipo de transferencia (TRANSFERENCIA_PROPIAS, TRANSFERENCIA_TERCEROS, etc.)
 * @returns {object} - Objeto con isProgrammed y scheduledData, o null si hay error
 */
function procesarTransferenciaProgramada(tipoTransferencia) {
    var isProgrammed = $("#schedule-transfer").is(':checked');
    
    if (!isProgrammed) {
        return {
            isProgrammed: false,
            scheduledData: null
        };
    }
    
    // Validar campos requeridos
    if (!validateScheduledTransfer()) {
        return null; // Indica error
    }
    
    var frequency = $("#scheduled-frequency").val();
    var startDate = $("#scheduled-date").val();
    var endDate = $("#scheduled-end-date").val();
    
    // Para frecuencia UNICA, la fecha de fin es igual a la de inicio
    if (frequency === "UNICA") {
        endDate = startDate;
    }
    
    // Construir objeto de transferencia programada
    var scheduledData = {
        frecuenciaProgramada: frequency,
        fechaInicioProgramada: startDate,
        fechaFinProgramada: endDate,
        emailNotificacion: $("#scheduled-email").val() || "",
        telefonoNotificacion: $("#scheduled-phone").val() || "",
        mensajeNotificacion: $("#scheduled-message").val() || "",
        tipoTransferencia: tipoTransferencia
    };
    
    return {
        isProgrammed: true,
        scheduledData: scheduledData
    };
}
