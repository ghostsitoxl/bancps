function downloadCheckbookRequestReport(numberOperation, type) {
    var params;
    var url;
    if(type === 'TRANSACTIONAL') {
        params = 'checkbookIdentifier=' + numberOperation;
        url = "/checkbook-requests/pdf-transactional";
    } else {
        params = 'numberOperation=' + numberOperation;
        url = "/checkbook-requests/report";
    }

    var req = new XMLHttpRequest();
    req.open("POST", appname + url, true);
    req.responseType = "blob";
    req.setRequestHeader("Content-type", "application/x-www-form-urlencoded");
    req.onload = function () {
        if(req.status === 200){
            var blob = req.response;
            var fileName = 'solicitud-chequera' + '-' + numberOperation + '.pdf';
            downloadAllReport(blob, fileName);
        }else{
            showModalGenericError("Error al generar el Comprobante");
        }
    };
    req.send(params);
}

