// FUNCIÓN PARA DESCARGAR REPORTE DE TRANSFERENCIAS PROGRAMADAS
function downloadScheduledTransferReport(transaccionToken, tipoTransaccion, numeroOperacion) {
    //Si no se pasó el token, intentar obtenerlo del DOM
    if (!transaccionToken || transaccionToken === "") {
        transaccionToken = $("#transaccionToken").val();
        console.log("Token obtenido del DOM:", transaccionToken);
    }

    //SI NO SE PASÓ EL NÚMERO DE OPERACIÓN, OBTENERLO DEL DOM
    if (!numeroOperacion || numeroOperacion === "") {
        numeroOperacion = $("#numeroOperacion").val();
    }

    if (!transaccionToken || transaccionToken === "") {
        showModalGenericError("No se pudo obtener el token de la transacción programada");
        return;
    }

    var params = 'transaccionToken=' + transaccionToken + '&tipoTransaccion=' + tipoTransaccion + '&numeroOperacion=' + numeroOperacion;
   
    var req = new XMLHttpRequest();
    req.open("POST", appname + "/transfer/pdfscheduled", true);
    req.responseType = "blob";
    req.setRequestHeader("Content-type", "application/x-www-form-urlencoded");
    
    req.onload = function () {
        if(req.status === 200){
            var blob = req.response;
            
            // ⭐ EXTRAER EL NOMBRE DEL HEADER Content-Disposition
            var contentDisposition = req.getResponseHeader('Content-Disposition');
            var fileName = 'transferencia-programada.pdf';
            
            if (contentDisposition) {
                var filenameRegex = /filename[^;=\n]*=([^;\n]*)/;
                var matches = filenameRegex.exec(contentDisposition);
                if (matches != null && matches[1]) {
                    fileName = matches[1].replace(/"/g, '').replace(/'/g, '');
                }
            }
            
            downloadAllReport(blob, fileName);
        } else {
            showModalGenericError("Error al generar el Comprobante de Transferencia Programada");
        }
    };
    
    req.send(params);
}

