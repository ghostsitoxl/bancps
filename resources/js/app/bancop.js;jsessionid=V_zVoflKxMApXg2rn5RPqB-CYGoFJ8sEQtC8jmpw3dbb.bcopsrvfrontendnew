function formatAmount(elem, decimals) {
    /*Se realiza condicion para moneda de salarios ya que en el paso donde se obtiene la cuenta origen no realiza una llamada al servidor
     * y si se decide cambiar de cuenta ya queda cacheado con la primera eleccion y no realiza el correcto control para la coma*/
	if(CURRENCY_ACCOUNT !== ""){//moneda utilizada para salarios
    	if(CURRENCY_ACCOUNT === "USD"){
    		decimals = true;
    	}else{
    		decimals = false;
    	}
    		
    }
    if (elem !== null)
    {
        var value = elem.val();
        if(decimals){
            decimals = "true";
        }
        value = value.replace(/\./g, '')
        value = value.replace(/,/g, '.')
        value = value.replace(/[^0-9\.]+/g, '')
        var number = value.split('.')
        var formattedString = number[0].replace(/\B(?=(\d{3})+\b)/g, ".")
        if (decimals == 'true') {
            if (value.indexOf('.') > 0 && value.indexOf('.') == value.length - 1) {
                formattedString += ','
            } else if (number[1] !== undefined) {
                //formattedString += ',' + parseInt(number[1].substring(0, 2))
                formattedString += ',' + number[1].substring(0, 2)
            }
        }
        elem.val(formattedString)
        let placeholder = $("#transfer-ammount-own").attr("placeholder");
        $("#label-for-transfer-ammount-own").text(placeholder);
        $("#divTransferAmountOwn").floatLabels();
    }
}

