//función para obtener un producto según su número pasado por parámetro
function getProduct(idProduct, typeProduct) {
    switch (typeProduct) {
        case 'C':
            getAccount(idProduct);
            break;
        case 'CDA':
            getCDA(idProduct);
            break;
        case 'T':
            getCard(idProduct);
            break;
        case 'Pre':
            getLoan(idProduct);
            break;
        case 'Chk':
            getCheckbook(idProduct);
            break;
        case 'Chks':
        	getAccount(idProduct);
            break;
        case 'Ret':
            getReturned(idProduct);
        default:
            break;
    }
}

