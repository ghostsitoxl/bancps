/*Priero se setea el destino,luego se filtra y finalmente
* se vuelve a dibujar*/
function setDestinationAccount(selectElement) {

    const selectedOption = selectElement.options[selectElement.selectedIndex];
    const cuentaInfo = selectedOption.textContent || selectedOption.innerText;


    const regex = /Saldo:\s*(\S+)/;
    const match = cuentaInfo.match(regex);
    let selectedCurrency
    if (match) {
        selectedCurrency = match[1];
        console.log("Símbolo de la moneda:", selectedCurrency);
    }

    const destiny = $("#select-destiny").val();

    if (destiny == "Mis Cuentas") {
        account = $("#select-account2").val();
        $("#transfer-ammount-own").prop("disabled", false);

        if (selectedCurrency != null) {
            $("#transfer-ammount-own").attr("placeholder", 'Monto ' + selectedCurrency);
            $("#label-for-transfer-ammount-own").text('Monto ' + selectedCurrency);
            $("#divTransferAmountOwn").floatLabels();
        }

    } else {
        if (destiny == "Otras Cuentas") {
            account = $("#input-destiny").val();
        } else {
            account = $("#bank-destiny-0").val();

        }

    }

    if ($("#chooseContract").val() == "0") { //si no se eligio aun el contrato
        loadSelect();
    }

    var height2 = $("div.step-21-left").height();
    height2 = height2 + 20;
    $("div.step-1-right").css('height', height2);

    var height2 = $("div.step-2-left").height();
    height2 = height2 + 20;
    $("div.step-2-right").css('height', height2);

    var height3 = $("div.step-3-left").height();
    height3 = height3 + 20;
    $("div.step-3-right").css('height', height3);

    selectAccount2Changed();
}

/*Borra de la lista de contratos los que no son aplicables a las cuentas
* de origen y destino previamente seleccionadas*/
function filterExchange() {

    var len = listContratosCambioShow.length;
    while (len > 0) {

        if (listContratosCambioShow[len - 1].cuentaDebito != numberProduct
            || listContratosCambioShow[len - 1].tipoTransaccion != tipoTransaction) {
            listContratosCambioShow.splice(len - 1, 1);
        }

        len--;
    }
    ;
    reloadSelect();

}
