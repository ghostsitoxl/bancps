function getToday() {
    const today = new Date();

    const day = String(today.getDate()).padStart(2, '0');
    const month = String(today.getMonth() + 1).padStart(2, '0');
    const year = today.getFullYear();

    return `${day}/${month}/${year}`;
}

/*Constructor para el array de transferencais que se manda a SIPAP*/
function TransferSipap(origen, destino, moneda, nro_documento, entidad, nombre, type_documento, monto, concepto, motivo, exchange) {
    this.source = origen;
    this.destiny = destino;
    this.coin = moneda;
    this.number_document = nro_documento;
    this.entity = entidad;
    this.nameLastname = nombre;
    this.date = getToday();
    this.typeDocument = type_documento;
    this.ammount = monto;
    this.concept = concepto;
    this.reason = motivo;
    this.exchange = exchange;

}
/*Constructor adaptado para alias para el array de transferencais que se manda a SIPAP*/
