function confirmCardPay(token,key,keyMethod){
	PAY_TEXT = $(".cardPayDescription").text();
	$("#step-4 #cardButtonTransactionalKey").attr("disabled","disabled");
	$(".loader").removeClass("hidden");
	$.ajax({
        type: "POST",
        url: appname + "/card/payconfirm",
        data: {
            dinamicKey: key,
            tokenAprobacion: token,
            keyAproval: keyMethod,
        }
    }).done(function (data) {
        $("#step-1").addClass("hidden");
        $("#step-2").addClass("hidden");
        $("#step-3").addClass("hidden");
        $("#step-4").addClass("hidden");
        $(".loader").addClass("hidden");
        $("#step-5").html(data);
        $("#step-5").removeClass("hidden");
        $("#step-4 #cardButtonTransactionalKey").removeAttr("disabled");
        $(".cardDescription").text(CARD_TEXT);
        $(".accountDescription").text(ACCOUNT_TEXT);
        $(".cardPayDescription").text(PAY_TEXT);
        var height = $(".card-1-step-5-left").height();
        $(".card-1-step-5-right").height(height);
        
        var height1 = $(".card-2-step-5-left").height();
        $(".card-2-step-5-right").height(height1);
        
        var height2 = $(".card-3-step-5-left").height();
        $(".card-3-step-5-right").height(height2);
        
        var height3 = $(".card-4-step-5-left").height();
        $(".card-4-step-5-right").height(height3);

    }).fail(function (request, status, error) {
    	$("#step-4 #cardButtonTransactionalKey").removeAttr("disabled");
    	$(".loader").addClass("hidden");
    	 var errorData = request.responseJSON;
         ajaxErrorHandler(errorData, status, error, ID_GENERIC_ERROR);
    })
}

function downloadCardReport(numberOperation){

    var params = 'numberOperation=' + numberOperation;
    var req = new XMLHttpRequest();
    req.open("POST", appname + "/card/pay/pdfcard", true);
    req.responseType = "blob";
    req.setRequestHeader("Content-type", "application/x-www-form-urlencoded");
    req.onload = function () {
    	if(req.status === 200){
    		 var blob = req.response;
    	     var fileName = 'pago-tarjeta' + '-' + numberOperation + '.pdf';
    	     downloadAllReport(blob, fileName);
    	}else{
    		showModalGenericError("Error al generar el Comprobante");
    	}
    };
    req.send(params);


}

function downloadCashAdvanceReport(numberOperation){

    var params = 'numberOperation=' + numberOperation;
    var req = new XMLHttpRequest();
    req.open("POST", appname + "/card/cash-advance/pdf", true);
    req.responseType = "blob";
    req.setRequestHeader("Content-type", "application/x-www-form-urlencoded");
    req.onload = function () {
        if(req.status === 200){
            var blob = req.response;
            var fileName = 'adelanto-efectivo' + '-' + numberOperation + '.pdf';
            downloadAllReport(blob, fileName);
        }else{
            showModalGenericError("Error al generar el Comprobante");
        }
    };
    req.send(params);


}

function sendCardEmail(email, subject, message, numberOperation,typeTransaction) {
    $.ajax({
        type: "POST",
        url: appname + "/card/notifyemail",
        data: {
            email: email,
            asunto: subject,
            mensaje: message,
            numberOperation: numberOperation,
            typeTransaction: typeTransaction
        }
    }).done(function (data) {
        $("#emailDiv").addClass("hidden");
    }).fail(function (request, status, error) {
        var errorData = request.responseJSON;
        ajaxErrorHandler(errorData, status, error, ID_GENERIC_ERROR);
    })
}

function sendCardSms(number, numberOperation,typeTransaction) {

    $.ajax({
        type: "POST",
        url: appname + "/card/notifysms",
        data: {
            numberPhone: number,
            numberOperation: numberOperation,
            typeTransaction: typeTransaction

        }
    }).done(function (data) {
        $("#smsDiv").addClass("hidden");
    }).fail(function (request, status, error) {
        var errorData = request.responseJSON;
        ajaxErrorHandler(errorData, status, error, ID_GENERIC_ERROR);
    })

}

function registerCashAdvance(amount,quota){

    $("#step-3 #buttonCardPayDetails").attr("disabled","disabled");
    $(".loader").removeClass("hidden");
    $.ajax({
        type: "POST",
        url: appname + "/card/cash-advance/register",
        data: {
            amount : amount,
            quota : quota
        }
    }).done(function (data) {
        $("#step-1").addClass("hidden");
        $("#step-2").addClass("hidden");
        $("#step-3").addClass("hidden");
        $(".loader").addClass("hidden");
        $("#step-4").removeClass("hidden");
        $("#step-3 #buttonCardPayDetails").removeAttr("disabled");
        $("#step-4").html(data);
        $(".cardDescription").text(CARD_TEXT);
        $(".accountDescription").text(ACCOUNT_TEXT);
        if(CARD_SELECTED){
            $(".card-1-step-4-left").removeAttr("onclick");
        }
        var height = $(".card-1-step-4-left").height();
        $(".card-1-step-4-right").height(height);

        var height1 = $(".card-2-step-4-left").height();
        $(".card-2-step-4-right").height(height1);

        var height2 = $(".card-3-step-4-left").height();
        $(".card-3-step-4-right").height(height2);

        var height3 = $(".card-step-4-left").height();
        $(".card-step-4-right").height(height3);
    }).fail(function (request, status, error) {
        $("#step-3 #buttonCardPayDetails").removeAttr("disabled");
        $(".loader").addClass("hidden");
        var errorData = request.responseJSON;
        ajaxErrorHandler(errorData, status, error, ID_GENERIC_ERROR);
    })
}

