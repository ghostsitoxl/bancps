function verifyCardPay(amount,typePay){
	
	$("#step-3 #buttonCardPayDetails").attr("disabled","disabled");
	$(".loader").removeClass("hidden");
	$.ajax({
        type: "POST",
        url: appname + "/card/payverify",
        data: {
        	amount : amount,
        	type : typePay
        }
    }).done(function (data) {
    	$("#step-1").addClass("hidden");
        $("#step-2").addClass("hidden");
        $("#step-3").addClass("hidden");
        $(".loader").addClass("hidden");
        $("#step-4").removeClass("hidden");
        $("#step-3 #buttonCardPayDetails").removeAttr("disabled");
        $("#step-4").html(data);
        $(".cardDescription").text(CARD_TEXT);
        $(".accountDescription").text(ACCOUNT_TEXT);
        if(CARD_SELECTED){
        	$(".card-1-step-4-left").removeAttr("onclick");
        }
        var height = $(".card-1-step-4-left").height();
        $(".card-1-step-4-right").height(height);
        
        var height1 = $(".card-2-step-4-left").height();
        $(".card-2-step-4-right").height(height1);
        
        var height2 = $(".card-3-step-4-left").height();
        $(".card-3-step-4-right").height(height2);
        
        var height3 = $(".card-step-4-left").height();
        $(".card-step-4-right").height(height3);
    }).fail(function (request, status, error) {
    	$("#step-3 #buttonCardPayDetails").removeAttr("disabled");
    	$(".loader").addClass("hidden");
        var errorData = request.responseJSON;
        ajaxErrorHandler(errorData, status, error, ID_GENERIC_ERROR);
    })
}
function cardBackToStepOne(){
	$("#step-1").removeClass("hidden");
	 var height1 = $("div.step-1-left").height();
     height1 = height1 + 20;
     $("div.step-1-right").css('height', height1);
    $("#step-2").addClass("hidden");
    $("#step-3").addClass("hidden");
    $("#step-4").addClass("hidden");
    $("#step-5").addClass("hidden");
}
function cardBackToStepTwo(){
	$("#step-1").addClass("hidden");
    $("#step-2").removeClass("hidden");
    $("#step-3").addClass("hidden");
    $("#step-4").addClass("hidden");
    $("#step-5").addClass("hidden");
}
function cardBackToStepTree(){
	$("#step-1").addClass("hidden");
