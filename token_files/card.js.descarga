CARD_TEXT = "";
ACCOUNT_TEXT = "";
CARD_SELECTED = false;
PAY_TEXT = "";
/********************************************************************
 * función para obtener movimientos y todos los datos de una tarjeta
 * 
 * ******************************************************************/
function getCard(idProducto)
{
	var fields = {
            numberProduct: idProducto,            
    }
    var $form = $('<form>', {
        action: appname+'/card',
        method: 'post'
    }).append(
            $.map(fields, function (val, key) {
                return $('<input>').attr({
                    type: "hidden",
                    name: key,
                    value: val
                })
            })
    )
    $form.appendTo('body').submit();
}

function getCards(){
	if ($("#cards").val() != '[]' && $("#cards").val() != "" && $("#cards").val() != '{}') {
		location.href= appname+ '/card/pay';
	}
	
}

function getCashAdvance(){
    if ($("#cards").val() != '[]' && $("#cards").val() != "" && $("#cards").val() != '{}') {
        location.href= appname+ '/card/cash-advance';
    }

}
function payCardDirect(cardKey){
	if(cardKey !== ""){
		location.href = appname + "/card/pay/accounts?numberProduct="+cardKey;
	}
}
function cashAdvanceDirect(cardKey){
    if(cardKey !== ""){
        location.href = appname + "/card/cash-advance/accounts?numberProduct="+cardKey;
    }
}
function cashAdvance(cardKey){
    $(".loader").removeClass("hidden");
    $.ajax({
        type: "POST",
        url: appname + "/card/cash-advance/accounts",
        data: {
            numberProduct : cardKey
        }
    }).done(function (data) {
        $(".loader").addClass("hidden");
        $("#step-1").addClass("hidden");
        $("#step-2").removeClass("hidden");
        $("#step-2").html(data);
        CARD_TEXT = $("#cardDescription").text();
        var height = $(".box-step-entrust-pointer.step-1-left").height();
        $(".heigth-right-step-entrust.step-1-right").height(height);

        var height1 = $(".pos-2-left").height();
        //height1 -= 20;
        $(".pos-2-right").height(height1);
        $("div.step-2-right").css("height","100%");
        if(CARD_SELECTED){
            $(".step-1-left").removeAttr("onclick");
        }

    }).fail(function (request, status, error) {
        $(".loader").addClass("hidden");
        var errorData = request.responseJSON;
        ajaxErrorHandler(errorData, status, error, ID_GENERIC_ERROR);
    })
}
