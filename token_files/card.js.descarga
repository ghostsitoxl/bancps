function cashAdvanceValidateQuota(maxValue){
    if(maxValue !== undefined && maxValue !== null && maxValue !== ""){
        var oldValue = $("#cash-advance-quota").val();
        oldValue = oldValue.substr(0,oldValue.length-1);
        var value = parseInt($("#cash-advance-quota").val());
        if(value > maxValue)
            $("#cash-advance-quota").val(oldValue);
    }
}