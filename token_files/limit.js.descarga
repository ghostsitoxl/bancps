	let account = obj.data('account');
    
    /*if (status == false) {
        obj.data('activo', true);
        obj.removeClass('glyphicon-eye-close').addClass('glyphicon-eye-open');
        input.attr('type', 'text');
    } else {
        obj.data('activo', false);
        obj.removeClass('glyphicon-eye-open').addClass('glyphicon-eye-close');
        input.attr('type', 'password');
    }*/
	
	$("#nroCuenta").html(account);
	$("#denominacion").html(obj.data('denominacion'));
