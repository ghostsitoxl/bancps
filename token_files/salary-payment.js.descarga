//funcion que obtiene las cuentas origen para el pago de salarios
function getSalaryAccounts(){
	location.href='/bancop/salary';
}

//funcion que recibe la cuenta seleccionada y la envia al controlador
function getSalaryAccount(accountNumber, codEnte){
	ACCOUNT_DESCRIPTION = $("#numberProduct option:selected").text();
	CURRENCY_ACCOUNT = $("#numberProduct option:selected").attr("data-currency");
	$.ajax({
        type: "POST",
        url: "/bancop/salary/account",
        data: {
            account : accountNumber,
            codEnte: codEnte
        }
    }).done(function (data) {
    	$("#step-1").addClass("hidden");
        $("#step-2").removeClass("hidden");
        $("#step-2").html("");
        $("#step-2").html(data);
        $("#numberAccount").text(ACCOUNT_DESCRIPTION);
        var height = $("div .pos-2-left").height();
        $("div .pos-2-right").height(height);
        $("div .step-2-right").css("height","100%");
    }).fail(function (request, status, error) {
        var errorData = request.responseJSON;
        ajaxErrorHandler(errorData, status, error, ID_GENERIC_ERROR);
    })
}

//funcion que muestra los divs manual o archivo dependiendo de la eleccion
function getSalaryPayment(){
	if($("#loadingMethod").val()==="U" && $("#typeRemuneration").val()!=="S") {
		var msg = "El último pago está habilitado solo para tipo de remuneración Salario";
		showModalGenericError(msg);
		return false;
	}
	
	TYPE_REM = $("#typeRemuneration").val();
	if(CURRENCY_ACCOUNT === "USD" && (TYPE_REM === "T" || TYPE_REM === "M")){
		var msg = "El pago de Tarjeta Gourmet/Credito solo esta disponible en Gs.";
		showModalGenericError(msg);
		return false;
	}
	TYPE_REM_DESCRIPTION = $("#typeRemuneration option:selected").text();
	PAYMENT_DESCRIPTION = "Tipo de Remuneración " + $("#typeRemuneration option:selected").text()+" — Carga "+ $("#loadingMethod option:selected").text();
	
	
	$("#numberAccountStep-3").text(ACCOUNT_DESCRIPTION);
	$("#paymentDescription").text(PAYMENT_DESCRIPTION);
	$("#step-1").addClass("hidden");
	$("#step-2").addClass("hidden");
    $("#step-3").removeClass("hidden");
    var height = $("div .pos-1-left").height();
    $("div .pos-1-right").height(height);
    $("div .step-1-right").css("height","100%");
    
    if($("#loadingMethod").val()==="A") {
    	LOADING_METHOD = "A";
    	$(".div-content-file").attr("onclick","loadFile()");
    	$("#buttonSalaryPaymentStep-3").removeClass("hidden");
    	$(".input-file").val("");
    	$("#btn-hasErrors").addClass("hidden");
		$("#btn-hasErrorsFile").addClass("hidden");

    	var length = $(".content-file-manual").length;
    	var i=0;
    	var pos = length - 1;
    	if(length > 1){
    		while(pos !== i){
    			$(".content-file-manual")[pos].remove();
    			pos--;
    		}
    	}
    	$("#div-file").removeClass("hidden");
    	$("#div-manual").addClass("hidden");
		$("#div-last").addClass("hidden");
    	$("#moreButtonSalary").addClass("hidden");
    	$(".total-officials").addClass("hidden");
    	$(".div-total-amount").addClass("hidden");
    	$(".content-file-manual").removeAttr("style");

		var height2 = $(".pos-3-left").height();
		$("div .pos-3-right").height(height2);
		$("div .step-3-right").css("height","100%");
    } else if($("#loadingMethod").val()==="M") {
		EMPLOYEES_SELECTED = [];
    	LOADING_METHOD = "M";
    	var length = $(".content-file-manual").length;
    	var i=0;
    	var pos = length - 1;
    	if(length > 1){
    		while(pos !== i){
    			$(".content-file-manual")[pos].remove();
    			pos--;
    		}
    	}
    	$("#div-manual").removeClass("hidden");
    	if(TYPE_REM === "T" || TYPE_REM === "M"){
    		$("#divSavedBeneficiaries").addClass("hidden");
    	}else{
    		$("#divSavedBeneficiaries").removeClass("hidden");
    	}
    	$("#moreButtonSalary").removeClass("hidden");
    	$("#div-file").addClass("hidden");
		$("#div-last").addClass("hidden");
    	$(".total-officials").removeClass("hidden");
    	$("#totalDestiny").text("1");
    	$("#totalAmountSalaryPay").text("0");
    	$(".div-total-amount").removeClass("hidden");
    	showInputLabels();
    	$("#divSendBeneficiaries").removeClass("hidden");
    	$(".content-file-manual").css("background-color","#E6E6E6");
    	$(".content-file-manual").css("margin-top","20px");

		var height2 = $(".pos-3-left").height();
		$("div .pos-3-right").height(height2);
		$("div .step-3-right").css("height","100%");
    } else {
		showLastBeneficiaries();
	}
}

function showLastBeneficiaries(){
	$(".loader").removeClass("hidden");
	$.ajax({
		type: "POST",
		url: appname+"/salary/payment/last"

	}).done(function (data) {
		if(data.hasError){
			if(data.errorBody.useApiMessage)
				showModalAdminError(data.errorBody.message);
			else
				showModalAdminError("Error obteniendo lista del Archivo");

			redirectLoginExpired(data.errorBody.code);
		}
		else {
			console.log("Recibido correctamente")
			$(".loader").addClass("hidden");
			$("#step-1").addClass("hidden");
			$("#step-2").addClass("hidden");
			$("#step-3").removeClass("hidden");
			$("#step-3").empty();
			$("#step-3").html(data);
			console.log("Last type hidden = ", $("#lastTypeHidden").val())
			$("#typeRemuneration").val($("#lastTypeHidden").val());
			$("#typeRemuneration").trigger('change');
			//originBeneficiaryData();
			TYPE_REM_DESCRIPTION = $("#typeRemuneration option:selected").text();
			TYPE_REM = $("#typeRemuneration").val();
			PAYMENT_DESCRIPTION = "Tipo de Remuneración " + $("#typeRemuneration option:selected").text()+" — Carga "+ $("#loadingMethod option:selected").text();
			$(".div-content-file").removeAttr("onclick");
			$("#numberAccountStep-3").text(ACCOUNT_DESCRIPTION);
			$("#paymentDescription").text(PAYMENT_DESCRIPTION);
			$(".input-file").val(FILE_INPUT);
			$("#buttonSalaryPaymentStep-3").addClass("hidden");
			$("#div-file").removeClass("hidden");
			$("#listFile").removeClass("hidden");
			$("#moreButtonSalary").removeClass("hidden");
			$(".total-officials").removeClass("hidden");
			$(".div-total-amount").removeClass("hidden");
			$("#totalDestiny").text($("#div-last #salary-fileToList tr").length);
			var totalAmount = 0;
			var tamAmount = $("#div-last .amount-fileToList").length;
			var coin = $("#coinSalary").val();
			for (i = 0; i < tamAmount; i++) {//se recorre los montos de la lista para mostrar en el total
				var ubi = $(".amount-fileToList")[i].value;
				ubi = ubi.replace(/\./g, '').replace(/,/g, '.');
				if (isNaN(parseInt(ubi)) === false) { // va a dar true si es vacio el input
					totalAmount = totalAmount + parseFloat(ubi);
				}
			}

			var result = formatStringAmount(totalAmount.toString().replace(".", ","), coin);
			var coinFormat = "";
			if (coin === 'true') {//se formatea en base a la moneda del origen
				coinFormat = "USD";
			} else {
				coinFormat = "Gs.";
			}
			result = coinFormat + " " + result;
			$("#totalAmountSalaryPay").text(result);
			$("#divSendBeneficiaries").removeClass("hidden");
			var height2 = $(".pos-3-left").height();
			$("div .pos-3-right").height(height2);
			$("div .step-3-right").css("height", "100%");



			LOADING_METHOD = "U";
			$("#buttonSalaryPaymentStep-3").removeClass("hidden");
			$(".input-file").val("");
			$("#btn-hasErrors").addClass("hidden");
			$("#btn-hasErrorsFile").addClass("hidden");

			var length = $(".content-file-manual").length;
			var i=0;
			var pos = length - 1;
			if(length > 1){
				while(pos !== i){
					$(".content-file-manual")[pos].remove();
					pos--;
				}
			}
			$("#div-file").addClass("hidden");
			$("#div-manual").addClass("hidden");
			$("#div-last").removeClass("hidden");
			$(".last-benef").removeClass("hidden");
			/*$("#moreButtonSalary").addClass("hidden");
			$(".total-officials").addClass("hidden");
			$(".div-total-amount").addClass("hidden");
			$(".content-file-manual").removeAttr("style");

			var height2 = $(".pos-3-left").height();
			$("div .pos-3-right").height(height2);
			$("div .step-3-right").css("height","100%");*/
		}
	}).fail(function (request, status, error) {
		$(".loader").addClass("hidden");
		var errorData = request.responseJSON;
		ajaxErrorHandler(errorData, status, error, ID_GENERIC_ERROR);
		$("#buttonSalaryPaymentStep-3Loading").addClass("hidden");
		$("#buttonSalaryPaymentStep-3").removeClass("hidden");
	}).complete(function () {
		$(".loader").addClass("hidden");
	});
}

//funcion que inserta el archivo en el input de tipo file
function loadFile(){
	$(".div-content-file").before(
			function() {
				if ( ! $(this).prev().hasClass('input-ghost') ) {
					var element = $("<input type='file' id='salaryPaymentFile' class='input-ghost' accept='.csv, .txt, .xls' style='visibility:visible; height:0'>");
					element.attr("name","salaryPaymentFile");
					element.change(function(){

						$(".input-file").val(element.val().split('\\').pop());
					});
					element.click();
					return element;
				}else{
					$("#salaryPaymentFile").remove();
					var element = $("<input type='file' id='salaryPaymentFile' class='input-ghost' accept='.csv, .txt, .xls' style='visibility:visible; height:0'>");
					element.attr("name","salaryPaymentFile");
					element.change(function(){

						$(".input-file").val(element.val().split('\\').pop());

					});
					element.click();
					return element;
				}
			}
		);

}
//funcion que valida y envia el archivo en el formato adecuado
function getValidFile(){

	$("#buttonSalaryPaymentStep-3Loading").removeClass("hidden");
	$("#buttonSalaryPaymentStep-3Loading").button().button('disable');
	$("#buttonSalaryPaymentStep-3").addClass("hidden");
	FILE_INPUT = $(".input-file").val();
	if(FILE_INPUT !== ""){
		var input = $("#salaryPaymentFile").val().split('.')[1].toLowerCase();
		if(input !== "csv" && input !== "xls" && input !== "xlsx" && input !== "txt"){
			$('html, body').animate({scrollTop: 0}, 800);
			var msg = "Extensión Invalida";
			 var error1 = '<div class="row body-error">' +
		        '<input type="hidden" id="messageError" value="' + msg + '">' +
		        '<div class="col-md-2 col-sm-1 hidden-xs"></div>' +
		        '<div class="col-md-8 col-sm-10 col-xs-12 box-error-generic message-container">' +
		        '<h1><span><i class="icon-message-title icon-alert"></i></span>Aviso</h1>' +
		        '<p>' + msg + '</p>' +
		        '<button type="button" class="close close-error" onclick="closeGenericError();"><span class="icon-close-white message-box"></span></button>' +
		        '</div>' +
		        '<div class="col-md-2 col-sm-1 hidden-xs"></div>' +
		        '</div>';

			 $("#genericError").hide();
			 $("#genericError").html(error1);
			 $("#genericError").show();
			$("#container-main").removeClass("content-main");


		}else{//si es el formato adecuado envia el archivo para que se guarde en la base de datos
			 var data = new FormData();
			 data.append("salaryPaymentFile", $('input[type=file]')[0].files[0]);
			 data.append("typeRem",TYPE_REM);
			 $(".loader").removeClass("hidden");
			$.ajax({
		            type: "POST",
		            enctype: 'multipart/form-data',
		            url: "/bancop/salary/payment/fileprocess",
		            data: data,
		            processData: false,
		            contentType: false,
		            cache: false,
			 }).done(function (data) {
				 $(".loader").addClass("hidden");
                if(data.hasError){
                    if(data.errorBody.useApiMessage)
                        showModalAdminError(data.errorBody.message);
                    else
                        showModalAdminError("Error Procesando Archivo");

                    redirectLoginExpired(data.errorBody.code);
                }
                else {
                    if (data === "OK") { //Si se guardo correctamente se envia para procesar el archivo
						$(".loader").removeClass("hidden");
                        PR = setInterval(function () {
                            checkProcess();
                        }, 5000);

                    }
                }
            }).fail(function (request, status, error) {
                $(".loader").addClass("hidden");
                var errorData = request.responseJSON;
                ajaxErrorHandler(errorData, status, error, ID_GENERIC_ERROR);
                clearInterval(PR);
                $("#buttonSalaryPaymentStep-3Loading").addClass("hidden");
                $("#buttonSalaryPaymentStep-3").removeClass("hidden");
            })

		}
	}else{
		var msg = "Debe Seleccionar un Archivo";
		showModalGenericError(msg);
	}
}
//funcion que controla el progreso de procesamiento del archivo
function  checkProcess(){
	$(".loader").removeClass("hidden");
	$.ajax({
        type: "POST",
		dataType: 'json',
        url: appname+"/salary/payment/check"

	 }).done(function (data) {
		 $(".loader").addClass("hidden");
		 console.log(data)
        if(data.hasError){
            if(data.errorBody.useApiMessage)
                showModalAdminError(data.errorBody.message);
            else
                showModalAdminError("Error Procesando Archivo");

            redirectLoginExpired(data.errorBody.code);
        }
        else {

            if (data.response.estado === 'COMPLETO') {//'COMPLETO' //TODO si ya proceso todo se llama a la funcion para obtener la lista en base al archivo
				clearInterval(PR);
				showFileToList();
			}else if (data.response.estado === 'PROCESANDO') {
            	showPartialListBeneficiaries(data.response.objetoProcesado);
            }else if(data.response.estado === 'ERROR'){
				clearInterval(PR);
				let messageError = "Error Procesando Archivo";
				if(data.response.mensajes[0] !== null && data.response.mensajes[0] !== undefined && data.response.mensajes[0] !== "")
					messageError = data.response.mensajes[0];
				showModalAdminError(messageError);
            }
        }
	 }).fail(function (request, status, error) {
		 $(".loader").addClass("hidden");
	        var errorData = request.responseJSON;
	        ajaxErrorHandler(errorData, status, error, ID_GENERIC_ERROR);
	        clearInterval(PR);
	        $("#buttonSalaryPaymentStep-3Loading").addClass("hidden");
	    	$("#buttonSalaryPaymentStep-3").removeClass("hidden");
	 });
}

function showPartialListBeneficiaries(beneficiaries){
	if(beneficiaries != null && beneficiaries !== undefined){
		$("#registerSalaryPayment").attr("disabled","disabled");
		$(".loader").removeClass("hidden");
		$.ajax({
			type: "POST",
			url: appname+"/salary/payment/partial-beneficiaries",
			data : {
				listBeneficiaries : JSON.stringify(beneficiaries)
			}

		}).done(function (data) {
			if(data.hasError){
				if(data.errorBody.useApiMessage)
					showModalAdminError(data.errorBody.message);
				else
					showModalAdminError("Error obteniendo lista del Archivo");

				redirectLoginExpired(data.errorBody.code);
			}
			else {
				$("#step-1").addClass("hidden");
				$("#step-2").addClass("hidden");
				$("#step-3").removeClass("hidden");
				$("#step-3").empty();
				$("#step-3").html(data);
				$("#registerSalaryPayment").attr("disabled","disabled");
				$(".div-content-file").removeAttr("onclick");
				$("#numberAccountStep-3").text(ACCOUNT_DESCRIPTION);
				$("#paymentDescription").text(PAYMENT_DESCRIPTION);
				$(".input-file").val(FILE_INPUT);
				$("#buttonSalaryPaymentStep-3").addClass("hidden");
				$("#div-file").removeClass("hidden");
				$("#listFile").removeClass("hidden");
				$("#moreButtonSalary").removeClass("hidden");
				$(".total-officials").removeClass("hidden");
				$(".div-total-amount").removeClass("hidden");
				$("#totalDestiny").text($("#salary-fileToList tr").length);
				var totalAmount = 0;
				var tamAmount = $(".amount-fileToList").length;
				var coin = $("#coinSalary").val();
				for (i = 0; i < tamAmount; i++) {//se recorre los montos de la lista para mostrar en el total
					var ubi = $(".amount-fileToList")[i].value;
					ubi = ubi.replace(/\./g, '').replace(/,/g, '.');
					if (isNaN(parseInt(ubi)) === false) { // va a dar true si es vacio el input
						totalAmount = totalAmount + parseFloat(ubi);
					}
				}

				var result = formatStringAmount(totalAmount.toString().replace(".", ","), coin);
				var coinFormat = "";
				if (coin === 'true') {//se formatea en base a la moneda del origen
					coinFormat = "USD";
				} else {
					coinFormat = "Gs.";
				}
				result = coinFormat + " " + result;
				$("#totalAmountSalaryPay").text(result);
				$("#divSendBeneficiaries").removeClass("hidden");
				var height2 = $(".pos-3-left").height();
				$("div .pos-3-right").height(height2);
				$("div .step-3-right").css("height", "100%");
			}
		}).fail(function (request, status, error) {
			$(".loader").addClass("hidden");
			var errorData = request.responseJSON;
			ajaxErrorHandler(errorData, status, error, ID_GENERIC_ERROR);
			$("#buttonSalaryPaymentStep-3Loading").addClass("hidden");
			$("#buttonSalaryPaymentStep-3").removeClass("hidden");
		});
	}else{
		$(".loader").addClass("hidden");
		clearInterval(PR);
		showModalAdminError("Error Procesando Archivo");
	}



}

function  processAndCheck(){
    $(".loader").removeClass("hidden");
    $.ajax({
        type: "POST",
		dataType: 'json',
        url: appname+"/salary/payment/process-check"

    }).done(function (data) {
        $(".loader").addClass("hidden");
        if(data.hasError){
            if(data.errorBody.useApiMessage)
                showModalAdminError(data.errorBody.message);
            else
                showModalAdminError("Error Procesando Archivo");

            redirectLoginExpired(data.errorBody.code);
        }
        else {
            if (data === 'COMPLETO') {//'COMPLETO' //TODO si ya proceso todo se llama a la funcion para obtener la lista en base al archivo
                clearInterval(PR);
                showFileToList();
            }else if(data === 'ERROR'){
				clearInterval(PR);
				showModalAdminError("Error Procesando Archivo");
			}
        }
    }).fail(function (request, status, error) {
        $(".loader").addClass("hidden");
        var errorData = request.responseJSON;
        ajaxErrorHandler(errorData, status, error, ID_GENERIC_ERROR);
        clearInterval(PR);
        $("#buttonSalaryPaymentStep-3Loading").addClass("hidden");
        $("#buttonSalaryPaymentStep-3").removeClass("hidden");
    });
}



//funcion que muestra la lista de beneficiarios en base al archivo procesado
function  showFileToList(){
	$(".loader").removeClass("hidden");
	$.ajax({
        type: "POST",
        url: appname+"/salary/payment/file"

	 }).done(function (data) {
        if(data.hasError){
            if(data.errorBody.useApiMessage)
            	showModalAdminError(data.errorBody.message);
            else
                showModalAdminError("Error obteniendo lista del Archivo");

            redirectLoginExpired(data.errorBody.code);
        }
        else {
            $(".loader").addClass("hidden");
            $("#step-1").addClass("hidden");
            $("#step-2").addClass("hidden");
            $("#step-3").removeClass("hidden");
            $("#step-3").empty();
            $("#step-3").html(data);
			//originBeneficiaryData();
            $(".div-content-file").removeAttr("onclick");
            $("#numberAccountStep-3").text(ACCOUNT_DESCRIPTION);
            $("#paymentDescription").text(PAYMENT_DESCRIPTION);
            $(".input-file").val(FILE_INPUT);
            $("#buttonSalaryPaymentStep-3").addClass("hidden");
            $("#div-file").removeClass("hidden");
            $("#listFile").removeClass("hidden");
            $("#moreButtonSalary").removeClass("hidden");
            $(".total-officials").removeClass("hidden");
            $(".div-total-amount").removeClass("hidden");
            $("#totalDestiny").text($("#div-file #salary-fileToList tr").length);
            console.log("Cantidad de registros: ", $("#div-file #salary-fileToList tr").length);
            var totalAmount = 0;
            var tamAmount = $("#div-file .amount-fileToList").length;
            var coin = $("#coinSalary").val();
            for (i = 0; i < tamAmount; i++) {//se recorre los montos de la lista para mostrar en el total
                var ubi = $(".amount-fileToList")[i].value;
                ubi = ubi.replace(/\./g, '').replace(/,/g, '.');
                if (isNaN(parseInt(ubi)) === false) { // va a dar true si es vacio el input
                    totalAmount = totalAmount + parseFloat(ubi);
                }
            }

            var result = formatStringAmount(totalAmount.toString().replace(".", ","), coin);
            var coinFormat = "";
            if (coin === 'true') {//se formatea en base a la moneda del origen
                coinFormat = "USD";
            } else {
                coinFormat = "Gs.";
            }
            result = coinFormat + " " + result;
            $("#totalAmountSalaryPay").text(result);
            $("#divSendBeneficiaries").removeClass("hidden");
            var height2 = $(".pos-3-left").height();
            $("div .pos-3-right").height(height2);
            $("div .step-3-right").css("height", "100%");
        }
	 }).fail(function (request, status, error) {
		 $(".loader").addClass("hidden");
	        var errorData = request.responseJSON;
	        ajaxErrorHandler(errorData, status, error, ID_GENERIC_ERROR);
	        $("#buttonSalaryPaymentStep-3Loading").addClass("hidden");
	    	$("#buttonSalaryPaymentStep-3").removeClass("hidden");
	 }).complete(function () {
        $(".loader").addClass("hidden");
    });
}
//funcion para agregar mas beneficiarios a la lista de beneficiarios
function showMoreSalary(){
	console.log("Method = ", LOADING_METHOD);
	if(LOADING_METHOD === "A") {//por archivo se usa table
		var length = $("#div-file #salary-fileToList tr").length;
		var valId = $("#div-file #salary-fileToList tr:last").attr("class").split("-")[3];
		var pos = (parseInt(valId) + 1);
		var tds = $("#div-file #salary-fileToList tr:first td").length;
		var coin = $("#coinSalary").val();
		var tr = "<tr class=" + 'tr-file-pos-' + pos + ">";  //se crea la nueva fila
		var imgDelete = $("#imgDelete").val();
		for (i = 0; i < tds; i++) {
			if (i == 3) { //se asignan las clases y eventos en base a la posicion
				tr += "<td class = 'text-gray text-amount padding-bottom-15'><input class='input-style font-size-11' " +
					"type='text' placeholder='Número Cuenta' onblur=" + 'getBeneficiaryFile(' + pos + ')' + "></td>";
			} else if (i == 5) {
				tr += "<td class = 'text-gray text-amount padding-bottom-15 tooltip'><input class='text-align-right font-size-11 amount-fileToList' " +
					"type='text' placeholder='Monto' onblur='getTotalFileToList()' maxlength='18' onkeyup=" + 'formatAmount($(this),' + coin + ')' + " style='width: 100%'>" +
					"<span class=\"tooltiptext\" style=\"background-color: transparent; bottom: 0%; left: 50%; width: 136%; padding: 0; font-size: 0.8rem\">Monto modificable</span></td>";
			} else if (i == 6) {
				tr += "<td class = 'cursor-pointer font-weight-bold' style='width: 7%;' onclick=" + 'deleteRowFileList(' + pos + ')' + "><img class='img-responsive icon-remove' style='cursor: pointer;' src="+imgDelete+"></td>";

			} else {
				tr += "<td class='text-gray text-align-left padding-bottom-5 text-capitalize'></td>";
			}

		}
		tr += "</tr>";
		$("#div-file #salary-fileToList").append(tr);//se agrega a la lista
		$("#totalDestiny").text($("#div-file #salary-fileToList tr").length);//se actualiza el total de beneficiarios

		var totalAmount = 0;
		var tamAmount = $("#div-file .amount-fileToList").length;
		for (i = 0; i < tamAmount; i++) {
			var ubi = $("#div-file .amount-fileToList")[i].value;
			ubi = ubi.replace(/\./g, '').replace(/,/g, '.');
			if (isNaN(parseInt(ubi)) === false) { // va a dar true si es vacio el input
				totalAmount = totalAmount + parseFloat(ubi);
			}
		}
		var coin = $("#coinSalary").val();
		var result = formatStringAmount(totalAmount.toString().replace(".", ","), coin);
		var coinFormat = "";
		if (coin == 'true') {
			coinFormat = "USD";
		} else {
			coinFormat = "Gs.";
		}
		result = coinFormat + " " + result;
		$("#totalAmountSalaryPay").text(result);//se actualiza el monto a pagar si fuese necesario

	} else if(LOADING_METHOD === "U") {//por archivo se usa table
		var length = $("#div-last #salary-fileToList tr").length;
		var valId = $("#div-last #salary-fileToList tr:last").attr("class").split("-")[3];
		var pos = (parseInt(valId)+1);
		var tds=$("#div-last #salary-fileToList tr:first td").length;
		var coin = $("#coinSalary").val();
		var tr = "<tr class="+'tr-file-pos-'+pos+">";  //se crea la nueva fila
		var imgDelete = $("#imgDelete").val();
		for(i=0; i<tds; i++){
			if(i == 3){ //se asignan las clases y eventos en base a la posicion
				tr += "<td class = 'text-gray text-amount padding-bottom-15'><input class='input-style font-size-11' " +
					"type='text' placeholder='Número Cuenta' onblur="+'getBeneficiaryLast('+pos+')'+"></td>";
			}else if( i == 5){
				tr += "<td class = 'text-gray text-amount padding-bottom-15 tooltip'><input class='text-align-right font-size-11 amount-fileToList' " +
					"type='text' placeholder='Monto' onblur='getTotalLastToList()' maxlength='18' onkeyup="+'formatAmount($(this),'+coin+')'+" style='width: 100%'>" +
					"<span class=\"tooltiptext\" style=\"background-color: transparent; bottom: 0%; left: 50%; width: 136%; padding: 0; font-size: 0.8rem\">Monto modificable</span></td>";
			}else if(i == 6){
				tr += "<td class = 'cursor-pointer font-weight-bold' style='width: 7%;' onclick="+'deleteRowLastList('+pos+')'+"><img class='img-responsive icon-remove' style='cursor: pointer;' src="+imgDelete+"></td>";

			}else{
				tr += "<td class='text-gray text-align-left padding-bottom-5 text-capitalize'></td>";
			}

		}
		tr += "</tr>";
		$("#div-last #salary-fileToList").append(tr);//se agrega a la lista
		$("#totalDestiny").text($("#div-last #salary-fileToList tr").length);//se actualiza el total de beneficiarios

		var totalAmount = 0;
		var tamAmount = $("#div-last .amount-fileToList").length;
		for(i=0; i<tamAmount;i++){
			var ubi = $("#div-last .amount-fileToList")[i].value;
			ubi = ubi.replace(/\./g, '').replace(/,/g, '.');
			if(isNaN(parseInt(ubi)) === false){ // va a dar true si es vacio el input
				totalAmount = totalAmount + parseFloat(ubi);
			}
		}
		var coin = $("#coinSalary").val();
		var result = formatStringAmount(totalAmount.toString().replace(".",","),coin);
		var coinFormat = "";
		if(coin == 'true'){
			coinFormat = "USD";
		}else{
			coinFormat = "Gs.";
		}
		result = coinFormat +" "+result;
		$("#totalAmountSalaryPay").text(result);//se actualiza el monto a pagar si fuese necesario

	}else{//manual se usa sucesion de divs con una clase en comun
		$(".content-file-manual").last().clone().insertBefore("#moreButtonSalary");//el nuevo div se inserta encima boton para agregar nuevos beneficiarios
		var tam = $(".content-file-manual").length;
		for(i=0;i<tam;i++){//se agrega todas las propiedades y se resetea todas las posiciones del div
			$(".content-file-manual:eq("+i+") #div-manual input:eq(0)").attr("onclick","deleteDivManual("+i+")");
			$(".content-file-manual:eq("+i+") #div-manual div:eq(0)").attr("id","div-beneficiary-"+i);
			$(".content-file-manual:eq("+i+") #div-manual div #accountNumberBeneficiary").attr("onblur","getBeneficiaryData("+i+")");
			$(".content-file-manual:eq("+i+") #div-manual div #divSavedBeneficiaries").attr("onclick","savedBeneficiaries("+i+")");
			$(".content-file-manual:eq("+i+") #div-manual div #mountBeneficiary").attr("onblur","getTotalAmountSalary("+i+")");
		}
		var length = $(".content-file-manual").length-1;//se resta uno porque se necesita la posicion del nuevo div
		var idPos = $(".content-file-manual:eq("+length+") #div-manual #div-beneficiary-"+length).attr("id");
		$("#"+idPos+" div input").each(function(){ //limpia todos los campos del nuevo div copiado
			$(this).val("");
		});


		$("#"+idPos+" .div-account-number-salary div").removeClass("div-error-background-orange"); //por si un div anterior tuvo errores se limpia la copia
		$("#"+idPos+" .div-account-number-salary span").text("");
