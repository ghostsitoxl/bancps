//funcion que actualiza el total a pagar y el total de beneficiarios en pago salarios manual
function getTotalAmountSalary(pos){
	validateMount(pos);
	var length = $(".mountBeneficiary").length; //recorremos todos los imputs con la clase
	var r = 0;
	for (i = 0; i < length; i++) {
		var ubi = $(".mountBeneficiary")[i].value; //probar si se debe limpiar primero el valor con los puntos
		ubi = ubi.replace(/\./g, '').replace(/,/g, '.');
		if (isNaN(parseInt(ubi)) === false) { // va a dar true si es vacio el input
			r = r + parseFloat(ubi);
		}
	}

	var coin = $("#coinSalary").val();
	var result = formatStringAmount(r.toString().replace(".", ","), coin);
	var coinFormat = "";
	if (coin == 'true') {
		coinFormat = "USD";
	} else {
		coinFormat = "Gs.";
	}
	result = coinFormat + " " + result;
	$("#totalAmountSalaryPay").text(result);
	$("#totalDestiny").text(length);

}

//funcion que retorna un monto formateado en base a la moneda
function formatStringAmount(elem, decimals){
	var value = elem.toString();
    value = value.replace(/\./g, '')
    value = value.replace(/,/g, '.')
    value = value.replace(/[^0-9\.]+/g, '')
    var number = value.split('.')
    var formattedString = number[0].replace(/\B(?=(\d{3})+\b)/g, ".")
    if (decimals == 'true') {
        if (value.indexOf('.') > 0 && value.indexOf('.') == value.length - 1) {
            formattedString += ','
        } else if (number[1] !== undefined) {
            //formattedString += ',' + parseInt(number[1].substring(0, 2))
            formattedString += ',' + number[1].substring(0, 2)
        }
    }
	return formattedString;
}

//Funcion para validar si el campo actual esta vacio o no
function validateMount(pos){
	POS_BENEFICIARY_DATA = pos;
	var mount = $(".mountBeneficiary")[POS_BENEFICIARY_DATA].value;
	if(!isNaN(parseInt(mount))){
		$("#div-beneficiary-"+POS_BENEFICIARY_DATA+" .div-mount-number-salary").removeClass("div-error-background-orange"); //por si hubo un error anteriormente se limpia
		$("#div-beneficiary-"+POS_BENEFICIARY_DATA+" .div-mount-number-salary span").addClass("hidden");
		$("#div-beneficiary-"+POS_BENEFICIARY_DATA+" .label-mountNumberBeneficiary").removeAttr("style");
		$("#div-beneficiary-"+POS_BENEFICIARY_DATA+" .mountBeneficiary").removeAttr("style");
	}else{
		//Se agrega el error si el monto esta vacio
		$("#div-beneficiary-" + POS_BENEFICIARY_DATA + " .div-mount-number-salary").addClass("div-error-background-orange");
		$("#div-beneficiary-" + POS_BENEFICIARY_DATA + " .div-mount-number-salary span").text("Monto inválido");
		$("#div-beneficiary-" + POS_BENEFICIARY_DATA + " .div-mount-number-salary span").removeClass("hidden");
		$("#div-beneficiary-" + POS_BENEFICIARY_DATA + " .label-mountNumberBeneficiary").attr("style", "color : white !important;");
		$("#div-beneficiary-" + POS_BENEFICIARY_DATA + " .mountBeneficiary").attr("style", "color : white !important;");
	}
}

//constructor para cargar la lista de beneficiarios
function Beneficiary(nameBeneficiary,typeAccount,accountNumberBeneficiary,mountBeneficiary,codEnte,additionalInfo,typeMovement){
	this.nameBeneficiary = nameBeneficiary;
	this.typeAccount  = typeAccount;
	this.accountNumberBeneficiary = accountNumberBeneficiary;
	this.mountBeneficiary = mountBeneficiary;
	this.codEnte = codEnte;
	this.additionalInfo = additionalInfo;
	this.typeMovement = typeMovement;
}

//funcion que envia la lista de beneficiarios en base al metodo de carga elegido
function submitListBeneficiaries(){
	var listBeneficiaries = [];
	if(LOADING_METHOD === "M"){//metodo manual
		var length = $(".content-file-manual").length;
		var errorCant = 0;//estilo que se asigna a los divs si existe algun error
		for (i = 0; i < length; i++) {
			errorCant = $(".content-file-manual:eq("+i+") #div-manual .div-error-background-orange").length;
		}


		var count = 0;
		if(errorCant === 0){ //si no hay ningun error realiza el envio de la lista
			for (i = 0; i < length; i++) {
				var nameBeneficiary = $(".nameBeneficiary")[i].value;
				var typeAccount = $(".typeAccount")[i].value;
				var accountNumberBeneficiary = $(".accountNumberBeneficiary")[i].value;
				var mountBeneficiary = $(".mountBeneficiary")[i].value.replace(
							/\./g, '').replace(/,/g, '.');
				var beneficiary = new Beneficiary(nameBeneficiary, typeAccount,
							accountNumberBeneficiary, mountBeneficiary,null,null,null);
				if(beneficiary.mountBeneficiary !== "" && beneficiary.accountNumberBeneficiary !== ""){
					listBeneficiaries.push(beneficiary);
				}else{
					count++;
				}
			}
			var lengthBeneficiaries = listBeneficiaries.length;
			if(count == 0){//si no hay campos vacios
				$(".loader").removeClass("hidden");
				$("#registerSalaryPayment").attr("disabled","disabled");
				$.ajax({
					type : "POST",
					url : appname + "/salary/registerbeneficiaries",
					data : {
						listBeneficiaries : JSON.stringify(listBeneficiaries),
						loadingMethod:LOADING_METHOD,
						typeRem : TYPE_REM
					}

				}).done(function(data) {
					$(".loader").removeClass("hidden");

                    if(data.hasError){
						data.errorBody = JSON.parse(data.errorBody);
                        if(data.errorBody.useApiMessage)
                            showModalAdminError(data.errorBody.message);
                        else
                            showModalAdminError("Error registrando la operación.");

                        redirectLoginExpired(data.errorBody.code);
                    }
                    else {
                    	let timerVal = lengthBeneficiaries >= 1000 ? 7000: 3000;
                        /*hacer llamada para chequear el estado*/
                        SALARY_INTERVAL = setInterval(function() {
                            checkProcessRegisterSalary();
                        }, timerVal);
                    }


				}).fail(function (request, status, error) {
					$(".loader").addClass("hidden");
					$("#registerSalaryPayment").removeAttr("disabled");
			        var errorData = request.responseJSON;
			        $("#container-main").css('margin-top', '0px');
			        ajaxErrorHandler(errorData, status, error, "genericError");
			    });
			}else{ //si existen beneficiarios con campos vacios
				var msg = "";
				if(count == 1){
					msg = "Favor verificar su grupo de beneficiarios a enviar. Encontramos "+count+" beneficiario con campos vacios";
				}else{
					msg = "Favor verificar su grupo de beneficiarios a enviar. Encontramos "+count+" beneficiarios con campos vacios";
				}
				showModalGenericError(msg);
			}
		}else{//si existe algun campo con error se muestra mensaje
			var msg = "";
			if(errorCant === 1){
				msg = "Favor verificar su grupo de cuentas a enviar. Encontramos "+errorCant+" cuenta con error";
			}else{
				msg = "Favor verificar su grupo de cuentas a enviar. Encontramos "+errorCant+" cuentas con error";
			}
			showModalGenericError(msg);
		}
	
	}else if(LOADING_METHOD === "A"){//metodo de carga Archivo
		var errorCant = $("#div-file #listFile tbody .salarioCredito .div-error-background-orange").length; //estilo que se setea para denotar error en las filas
		var length = $("#div-file #salary-fileToList tr").length;
		var tds=$("#div-file salary-fileToList tr:first td").length;
		var count = 0;
		if(errorCant == 0){//si no existe error en las filas se envia la lista
			var errorTypeMovement = false;
			var errorTypeMovementPosition = 0;
			for(i=0; i<length; i++){
					let idMap = $("#div-file #salary-fileToList tr:eq("+i+")").attr("class");
					let beneficiaryModified = null;
					if(SALARY_ORIGIN_BENEFICIARIES.get(idMap) !== undefined && SALARY_MODIFY_BENEFICIARIES.get(idMap) !== undefined){
						let beneficiaryOrigin = SALARY_ORIGIN_BENEFICIARIES.get(idMap);
