//funcion que controla el progreso del registro de la transaccion
function  checkProcessRegisterSalary(){
    $(".loader").removeClass("hidden");
    $.ajax({
        type: "GET",
		dataType: 'json',
        url: appname + "/salary/register/check"

    }).done(function (data) {
		$(".loader").addClass("hidden");
        if(data.hasError){
            clearInterval(SALARY_INTERVAL);
            if(data.errorBody.useApiMessage)
                showModalAdminError(data.errorBody.message);
            else
                showModalAdminError("Error en el procesamiento del pago");

            redirectLoginExpired(data.errorBody.code);
            $(".loader").addClass("hidden");

        }
        else {
			$(".loader").addClass("hidden");
			clearInterval(SALARY_INTERVAL);
            if (data.response.estado == 'COMPLETO'){//si ya proceso se obtiene la transaccion y se muestra la pantalla de confirmacion
				getTransactionApprovalRequest();
			}else if(data.response.estado == 'ERROR'){
            	let messageError = "Error Procesando el Pago";
            	if(data.response.mensajes[0] !== null && data.response.mensajes[0] !== undefined && data.response.mensajes[0] !== "")
					messageError = data.response.mensajes[0];
				showModalAdminError(messageError);

				
				$("[id^='div-beneficiary-']").each(function () {
                    let beneficiaryDivId = $(this).attr('id');
                    let numberAccount = $("#" + beneficiaryDivId + " #accountNumberBeneficiary").val(); 
                    console.log("Número de cuenta capturado: ", numberAccount);

                    if (data.response.mensajes.some(mensaje => mensaje.includes("Monto a acreditar excede al permitido mensual disponible para la cuenta básica: " + numberAccount))) {
                        $("#registerSalaryPayment").prop("disabled", false);
                        let $mountBeneficiary = $("#" + beneficiaryDivId + " .mountBeneficiary");
                        $("#" + beneficiaryDivId + " .div-mount-number-salary").addClass("div-error-background-orange").focus();
                        $("#" + beneficiaryDivId + " .div-mount-number-salary span").text("Monto crédito cta básico inválido.");
                        $("#" + beneficiaryDivId + " .div-mount-number-salary span").removeClass("hidden");
                        $("#" + beneficiaryDivId + " .label-mountNumberBeneficiary").attr("style", "color : white !important;");
                        $("#" + beneficiaryDivId + " .mountBeneficiary").attr("style", "color : white !important;");

                        $mountBeneficiary.one('click', function () {
                            $("#" + beneficiaryDivId + " .div-mount-number-salary").removeClass("div-error-background-orange"); // limpio si hubo un error anteriormente
                            $("#" + beneficiaryDivId + " .div-mount-number-salary span").addClass("hidden");
                            $("#" + beneficiaryDivId + " .label-mountNumberBeneficiary").removeAttr("style");
                            $("#" + beneficiaryDivId + " .mountBeneficiary").removeAttr("style");
                        });
                    }
                });
			}else if(data.response.estado == 'PROCESANDO' || data.response.estado == 'GUARDADO'){
				checkProcessRegisterSalary();
			}


        }
    }).fail(function (request, status, error) {
        $(".loader").addClass("hidden");
        var errorData = request.responseJSON;
        ajaxErrorHandler(errorData, status, error, ID_GENERIC_ERROR);
        clearInterval(SALARY_INTERVAL);
        $("#buttonSalaryPaymentStep-3Loading").addClass("hidden");
        $("#buttonSalaryPaymentStep-3").removeClass("hidden");
    });
}

function getTransactionApprovalRequest() {
	TOTAL_PROCESADOS = -1
	$(".loader").removeClass("hidden");
	$("#registerSalaryPayment").attr("disabled","disabled");
	$.ajax({
		type : "POST",
		dataType: 'json',
		url : appname + "/salary/approval/request"
	}).done(function(data) {
		$(".loader").removeClass("hidden");
		if(data.hasError){
			data.errorBody = JSON.parse(data.errorBody);
			if(data.errorBody.useApiMessage)
				showModalAdminError(data.errorBody.message);
			else
				showModalAdminError("Error solicitando la aprobación");
			redirectLoginExpired(data.errorBody.code);
		}
		else {
			APPROVE_INTERVAL = setInterval(function() {
				checkProcessApprovalRequest(data.response);
			}, 5000);
		}
	}).fail(function (request, status, error) {
		$(".loader").addClass("hidden");
		$("#registerSalaryPayment").removeAttr("disabled");
		var errorData = request.responseJSON;
		$("#container-main").css('margin-top', '0px');
		ajaxErrorHandler(errorData, status, error, "genericError");
	});
}

function checkProcessApprovalRequest(nroLote) {
	$(".loader").removeClass("hidden");
	$.ajax({
		type: "GET",
		dataType: 'json',
		url: appname + "/salary/approval/request/check",
		data: {
			loteToApprove : nroLote
		}

	}).done(function (data) {
		if(data.hasError){
			clearInterval(APPROVE_INTERVAL);
			if(data.errorBody.useApiMessage)
				showModalAdminError(data.errorBody.message);
			else
				showModalAdminError("Error en el procesamiento de la solicitud de aprobación");
			redirectLoginExpired(data.errorBody.code);
			$(".loader").addClass("hidden");
		}
		else {
			$(".loader").addClass("hidden");
			clearInterval(APPROVE_INTERVAL);
			if(TOTAL_PROCESADOS == data.response.cantidadProcesados) {
				if(data.response.cantidadProcesados == data.response.cantidadTotalTareas) {
					TOTAL_PROCESADOS = -1;
					getConfirmationViewSalary();
				} else {
					/** Las primeras transacciones van a retornar vacio porque ingresa como EXPIRADA */
					if(data.response.cantidadProcesados == 0) {
						checkProcessApprovalRequest(nroLote);
					} else {
						showModalAdminError("Error al intentar finalizar la solicitud de aprobación");
						$(".loader").addClass("hidden");
					}
				}
			} else {
				TOTAL_PROCESADOS = data.response.cantidadProcesados;
				if(data.response.estado == 'ERROR') {
					let messageError = "Error Procesando la aprobación";
					showModalAdminError(messageError);
				} else {
					checkProcessApprovalRequest(nroLote);
				}
			}
		}
	}).fail(function (request, status, error) {
		$(".loader").addClass("hidden");
		var errorData = request.responseJSON;
		ajaxErrorHandler(errorData, status, error, ID_GENERIC_ERROR);
		clearInterval(APPROVE_INTERVAL);
		$("#buttonSalaryPaymentStep-3Loading").addClass("hidden");
		$("#buttonSalaryPaymentStep-3").removeClass("hidden");
	});

}

function getConfirmationViewSalary() {
    $(".loader").removeClass("hidden");
    $.ajax({
        type: "POST",
        url: appname + "/salary/confirmation",

    }).done(function (data) {
        $(".loader").addClass("hidden");
        if(data.hasError){
            if(data.errorBody.useApiMessage)
                showModalAdminError(data.errorBody.message);
            else
                showModalAdminError("Error registrando la operación.");

            redirectLoginExpired(data.errorBody.code);
        }
        else {
            $(".loader").addClass("hidden");
            $("#step-1").addClass("hidden");
            $("#step-2").addClass("hidden");
            $("#step-3").addClass("hidden");
            $("#registerSalaryPayment").removeAttr("disabled");
            $("#step-4").removeClass("hidden");
            $("#step-4").html(data);
            TOTAL_OFFICIALS = $("#totalOfficialsStep-4").text();
            TOTAL_PAY = $("#totalSalaryPayStep-4").text();
            $("#numberAccountStep-4").text(ACCOUNT_DESCRIPTION);
            $("#step-4 #paymentDescription").text(PAYMENT_DESCRIPTION);
            var height1 = $("#step-4 .step-4-3-left").height();
            $("#step-4 .step-4-3-right").height(height1);
            $("#step-4 .step-4-3-right .step-3-right").css("height","100%");
            var height2 = $("#step-4 .pos-4-left").height();
            $("#step-4 .pos-4-right").height(height2);
            $("#step-4 .step-4-right").css("height","100%");
        }



    }).fail(function (errorData,status,error) {
        $(".loader").addClass("hidden");
        $("#registerSalaryPayment").removeAttr("disabled");
        var dataError = errorData.responseJSON;
        $("#container-main").css('margin-top', '0px');
        ajaxErrorHandler(dataError, status, error, "genericError");
    });
}


//funcion que confirma el pago de salarios
function confirmSalary(){
	var dinamicKey = $("#clave").val();
	var keyAproval = $("#keyAproval").val();
	var txToken = $("#tokenTransactionAprobation").val();
	if(dinamicKey !== ""){
		$(".loader").removeClass("hidden");
		$("#confirmSalaryPayment").attr("disabled","disabled");
		$.ajax({
			type : "POST",
			url : appname + "/salary/confirm",
			data : {
				dinamicKey : dinamicKey,
				tokenTransactionAprobation : txToken,
				keyAproval : keyAproval,
				loadingMethod : LOADING_METHOD
			}

		}).done(function(data) {
			$(".loader").addClass("hidden");
			$("#step-1").addClass("hidden");
			 $("#step-2").addClass("hidden");
			 $("#step-3").addClass("hidden");
			 $("#step-4").addClass("hidden");
			 $("#confirmSalaryPayment").removeAttr("disabled");
			 $("#step-5").removeClass("hidden");
			 $("#step-5").html(data);

			 $("#numberAccountStep-5").text(ACCOUNT_DESCRIPTION);
			 $("#salaryPayStep-5").text(PAYMENT_DESCRIPTION);
			 var msg = "";
			 if(LOADING_METHOD === "M"){
				 msg = "Pago de "+ TYPE_REM_DESCRIPTION+ " en formato Manual - Total de Funcionarios: " +TOTAL_OFFICIALS +
				 " - Monto "+TOTAL_PAY.capitalize();
			 }else{
				 msg = "Pago de " + TYPE_REM_DESCRIPTION+ " por Archivo - Total de Funcionarios: "+TOTAL_OFFICIALS +
				 " - Monto "+TOTAL_PAY.capitalize();
			 }
			 $("#salaryBeneficiariesStep-5").text(msg);
			 var height = $("#step-5 .step-3-left").height()+20;
			 $("#step-5 .step-3-left").height(height);
			 $("#step-5 .step-3-right").height(height);
		}).fail(function (request, status, error) {
			$(".loader").addClass("hidden");
			$("#confirmSalaryPayment").removeAttr("disabled");
	        var errorData = request.responseJSON;
	        $("#container-main").css('margin-top', '0px');
	        ajaxErrorHandler(errorData, status, error, "genericError");
	    });
	}else{//si no introduce nada en el input
		var msg = "Introduzca la Clave Transaccional";
		showModalGenericError(msg);
	}
}
//funcion que agrega el nuevo beneficiario en base al numero de cuenta
function getBeneficiaryFile(pos){
	var numberAccount = $("#div-file .tr-file-pos-"+pos+" td:eq(3) input").val();
	if(numberAccount == "") return;
	var rowSelector = $("#div-file .tr-file-pos-"+pos);
	var listBeneficiaries = [];
	var length = $("#div-last #salary-fileToList tr").length-1;
	var amountAux =  $("#div-file .tr-file-pos-"+pos+" td:eq(5) input").val();
	for(i=0; i<=length; i++){
		var nameBeneficiary = $("#div-file #salary-fileToList tr:eq("+i+") td:eq(0)").text().trim();
		var typeAccount = $("#div-file #salary-fileToList tr:eq("+i+") td:eq(1)").text().trim().toUpperCase();
		var typeMovement = $("#div-file #salary-fileToList tr:eq("+i+") td:eq(2)").text().trim().toUpperCase();
		var tdNumberAccount = $("#div-file #salary-fileToList tr:eq("+i+") td:eq(3)");
		var tdAmount = $("#div-file #salary-fileToList tr:eq("+i+") td:eq(5)");
		var accountNumberBeneficiary = "";
		var codEnte = tdNumberAccount.attr("codEnte");
		var mountBeneficiary = tdAmount.find("input").val().replace(/\./g, '').replace(/,/g, '.');
		if(tdNumberAccount.find("input").val() === undefined){
			accountNumberBeneficiary = tdNumberAccount.text().trim();
		}else{
			accountNumberBeneficiary = tdNumberAccount.find("input").val();
		}
		var beneficiary = new Beneficiary(nameBeneficiary, typeAccount,
				accountNumberBeneficiary, mountBeneficiary,codEnte,null,typeMovement);
		listBeneficiaries.push(beneficiary);
	}	
	$.ajax({
        type: "POST",
        url: appname + "/salary/check-beneficiary",
        data:{
        	numberAccount : numberAccount.trim(),
        	position : pos,
        	typeRem : TYPE_REM,
			loadingMethod : 'F'
        }
    }).done(function (data) {
    	rowSelector.html(data);
		rowSelector.children()[5].children[0].value = amountAux;
		var height2 = $(".pos-3-left").height();
    	$("div .pos-3-right").height(height2);
    	$("div .step-3-right").css("height","100%");
		showButtonsBeneficiariesError();
	});
}

