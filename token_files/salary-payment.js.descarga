function beneficiarySelected() {
	initAddEmployee();

}

async function initAddEmployee() {
	/** Verificar el estado por cada cuenta seleccionada */
	await verifyAccount();
}

function verifyAccount() {
	HAS_ERRORS = false;
	let cantChecked = $("#tableList tr td input[type='checkbox']:checked").size();
	$("#tableList tr td input[type='checkbox']:checked").each(function (index) {
		row = $(this).closest('tr');
		let accountNumber = row.find('td:eq(3)').text();
		$("#td-error-"+accountNumber).removeClass("td-manual-employee-error");
		$("#error-"+accountNumber).text("");
		$.ajax({
			type: "POST",
			dataType: 'json',
			url: appname + "/salary/getbeneficiary/account-status",
			data:{
				numberAccount : accountNumber.trim(),
				typeRem : TYPE_REM
			}
		}).done(function (data) {
			console.log("Finalizo proceso")
			if(data.errorNumberAccount === ""){

			} else { // si hubo error mostramos el mensaje y no permitirmos agregar el flujo
				HAS_ERRORS = true;
				$("#td-error-"+accountNumber).addClass("td-manual-employee-error");
				$("#error-"+accountNumber).text("Error en la cuenta " + accountNumber + ". " + data.errorNumberAccount);
			}
			if(index+1 == cantChecked) {
				proccessUpdateData();
			}
		});
	});
}

function proccessUpdateData() {
	EMPLOYEES_SELECTED = [];
	var seleccion = [];

	if(!HAS_ERRORS) {
		$("#tableList tr td input[type='checkbox']:checked").each(function () {
			row = $(this).closest('tr');
			var beneficiary = new Beneficiary(row.find('td:eq(1)').text(), row.find('td:eq(2)').text(),
				row.find('td:eq(3)').text(), row.find('input[type="number"]').val(), null, null, null);
			EMPLOYEES_SELECTED.push(beneficiary);
			seleccion.push({
				nameBeneficiary: row.find('td:eq(1)').text(),
				typeAccount: row.find('td:eq(2)').text(),
				numberAccount: row.find('td:eq(3)').text(),
				montoAccount: row.find('input[type="number"]').val()
			});
		});

		if(seleccion.length === 1) {

			beneficiarySelectedOne()

		} else {

			var element = $(".content-file-manual").last().clone();
			$(".content-file-manual").remove();
			for (var k = 0; k < seleccion.length; k++) {
				if(k > 0) {
					element = $(".content-file-manual").last().clone();
				}
				//$(".content-file-manual").last().empty()
				element.insertBefore("#moreButtonSalary"); //el nuevo div se inserta encima boton para agregar nuevos beneficiarios
				var tam = $(".content-file-manual").length;
				for (var i = 0; i < tam; i++) {//se agrega todas las propiedades y se resetea todas las posiciones del div
					$(".content-file-manual:eq(" + i + ") #div-manual input:eq(0)").attr("onclick", "deleteDivManual(" + i + ", '" + EMPLOYEES_SELECTED[i].accountNumberBeneficiary + "')");
					$(".content-file-manual:eq(" + i + ") #div-manual div:eq(0)").attr("id", "div-beneficiary-" + i);
					$(".content-file-manual:eq(" + i + ") #div-manual div #accountNumberBeneficiary").attr("onblur", "getBeneficiaryData(" + i + ")");
					$(".content-file-manual:eq(" + i + ") #div-manual div #divSavedBeneficiaries").attr("onclick", "savedBeneficiaries(" + i + ")");

				}
				var length = $(".content-file-manual").length - 1; //se resta uno porque se necesita la posicion del nuevo div
				var idPos = $(".content-file-manual:eq(" + length + ") #div-manual #div-beneficiary-" + length).attr("id");
				$("#" + idPos + " div input").each(function () { //limpia todos los campos del nuevo div copiado
					$(this).val("");
				});
				$("#" + idPos + " .div-account-number-salary div").removeClass("div-error-background-orange"); //por si un div anterior tuvo errores se limpia la copia
				$("#" + idPos + " .div-account-number-salary span").text("");
				$("#" + idPos + " .label-accountNumberBeneficiary").removeAttr("style");
				$("#" + idPos + " .accountNumberBeneficiary").removeAttr("style");
				$("#totalDestiny").text($(".content-file-manual").length);
			}

			var recorrido = tam - seleccion.length;
			if (recorrido === 0) {

				for (var j = 0; j < tam; j++) {
					var nameBeneficiary = seleccion[j].nameBeneficiary;
					var typeAccount = seleccion[j].typeAccount;
					var typeAccountVal = "";
					if (typeAccount === "Cuenta Corriente") {
						typeAccountVal = "CC"; //Se cambia por el valor del select
					} else {
						typeAccountVal = "AH";
					}
					var numberAccount = seleccion[j].numberAccount;
					var montoAccount = seleccion[j].montoAccount;

					$("#div-beneficiary-" + j + " #nameBeneficiary").val(nameBeneficiary.capitalize());
					$("#div-beneficiary-" + j + " #typeAccount").val(typeAccountVal);
					$("#div-beneficiary-" + j + " #accountNumberBeneficiary").val(numberAccount);
					$("#div-beneficiary-" + j + " #mountBeneficiary").val(montoAccount);

					$("#div-beneficiary-" + j + " .div-account-number-salary div").removeClass("div-error-background-orange"); //por si hubo un error anteriormente se limpia
					$("#div-beneficiary-" + j + " .div-account-number-salary span").addClass("hidden");
					$("#div-beneficiary-" + j + " .label-accountNumberBeneficiary").removeAttr("style");
					$("#div-beneficiary-" + j + " .accountNumberBeneficiary").removeAttr("style");
					$("#div-beneficiary-" + j + " #mountBeneficiary").focus();
					POS_BENEFICIARY_SELECTED = j + 1;
				}

			} else {
				var recorrer = tam - seleccion.length;

				for (var l = recorrer; l < tam; l++) {
					var a = l-recorrer;
					var nameBeneficiary = seleccion[a].nameBeneficiary;
					var typeAccount = seleccion[a].typeAccount;
					var typeAccountVal = "";
					if (typeAccount === "Cuenta Corriente") {
						typeAccountVal = "CC"; //Se cambia por el valor del select
					} else {
						typeAccountVal = "AH";
					}
					var numberAccount = seleccion[a].numberAccount;
					var montoAccount = seleccion[a].montoAccount;

					$("#div-beneficiary-" + POS_BENEFICIARY_SELECTED + " #typeAccount").val(typeAccountVal);
					$("#div-beneficiary-" + POS_BENEFICIARY_SELECTED + " #accountNumberBeneficiary").val(numberAccount).focus();
					$("#div-beneficiary-" + POS_BENEFICIARY_SELECTED + " #nameBeneficiary").val(nameBeneficiary.capitalize());
					$("#div-beneficiary-" + POS_BENEFICIARY_SELECTED + " #mountBeneficiary").val(montoAccount);

					$("#div-beneficiary-" + POS_BENEFICIARY_SELECTED + " .div-account-number-salary div").removeClass("div-error-background-orange"); //por si hubo un error anteriormente se limpia
					$("#div-beneficiary-" + POS_BENEFICIARY_SELECTED + " .div-account-number-salary span").addClass("hidden");
					$("#div-beneficiary-" + POS_BENEFICIARY_SELECTED + " .label-accountNumberBeneficiary").removeAttr("style");
					$("#div-beneficiary-" + POS_BENEFICIARY_SELECTED + " .accountNumberBeneficiary").removeAttr("style");
					$("#div-beneficiary-" + POS_BENEFICIARY_SELECTED + " #mountBeneficiary").focus();
					POS_BENEFICIARY_SELECTED = l + 1;

				}
			}
		}
		$('#modalSavedBeneficiaries').modal('toggle');
	}
}

//funcion que inserta en el div seleccionado para cargar datos del beneficiario en el caso de seleccionar un solo beneficiario
function beneficiarySelectedOne(){
	var pos = $("input[name=radioSalaryBeneficiaries]:checked").val();
	var nameBeneficiary = $(".tr-manual-pos-"+pos+" td:eq(1)").text();
	var typeAccount = $(".tr-manual-pos-"+pos+" td:eq(2)").text();
	var typeAccountVal = "";
	if(typeAccount === "Cuenta Corriente"){
		typeAccountVal = "CC"; //Se cambia por el valor del select
	}else{
		typeAccountVal = "AH";
	}
	var numberAccount = $(".tr-manual-pos-"+pos+" td:eq(3)").text();
	var listMonto = $('.tr-manual-pos-'+pos+' input[type="number"]').val();

	//numberAccount: row.find('td:eq(3)').text(),
	//montoAccount: row.find('input[type="number"]').val()

    //var listMonto = $("#mountBeneficiaryList").val();

	$("#div-beneficiary-"+POS_BENEFICIARY_SELECTED+" #nameBeneficiary").val(nameBeneficiary.capitalize());
	$("#div-beneficiary-"+POS_BENEFICIARY_SELECTED+" #typeAccount").val(typeAccountVal);
	$("#div-beneficiary-"+POS_BENEFICIARY_SELECTED+" #accountNumberBeneficiary").val(numberAccount);
    $("#div-beneficiary-"+POS_BENEFICIARY_SELECTED+" #mountBeneficiary").val(listMonto);

	$("#div-beneficiary-"+POS_BENEFICIARY_SELECTED+" .div-account-number-salary div").removeClass("div-error-background-orange"); //por si hubo un error anteriormente se limpia
	$("#div-beneficiary-"+POS_BENEFICIARY_SELECTED+" .div-account-number-salary span").addClass("hidden");
	$("#div-beneficiary-"+POS_BENEFICIARY_SELECTED+" .label-accountNumberBeneficiary").removeAttr("style");
	$("#div-beneficiary-"+POS_BENEFICIARY_SELECTED+" .accountNumberBeneficiary").removeAttr("style");

	getTotalAmountSalary(pos);

}
//funcion que envia notificacion por email
function salarySendEmail(email, subject, message, numberOperation) {
    $.ajax({
        type: "POST",
        url: appname + "/salary/notifyemail",
        data: {
            email: email,
            subject: subject,
            message: message,
            numberOperation: numberOperation,
        }
    }).done(function (data) {
        $("#emailDiv").addClass("hidden");
    }).fail(function (request, status, error) {
        var errorData = request.responseJSON;
        ajaxErrorHandler(errorData, status, error, ID_GENERIC_ERROR);
    })
}
//funcion que envia notificacion por sms
function salarySendSms(number, numberOperation) {

    $.ajax({
        type: "POST",
        url: appname + "/salary/notifysms",
        data: {
            numberPhone: number,
            numberOperation: numberOperation,
        }
    }).done(function (data) {
        $("#smsDiv").addClass("hidden");
    }).fail(function (request, status, error) {
        var errorData = request.responseJSON;
        ajaxErrorHandler(errorData, status, error, ID_GENERIC_ERROR);
    })

}
//funcion que permite descargar el reporte de pago de salarios en formato pdf
function downloadSalaryPdf(numberOperation){
	var params = 'numberOperation=' + numberOperation;
    var req = new XMLHttpRequest();
    req.open("POST", appname + "/salary/pdfsalary", true);
    req.responseType = "blob";
    req.setRequestHeader("Content-type", "application/x-www-form-urlencoded");
    req.onload = function () {
    	if(req.status === 200){
    		 var blob = req.response;
    	     var fileName = 'pago-salario' + '-' + numberOperation + '.pdf';
    	     downloadAllReport(blob, fileName);

    	}
    	else
            showModalGenericError("Error al generar el Comprobante");

    };
    req.send(params);
}
function deleteRowFileListBeneficiaries(pos){
	var aux = $("#tableList tbody tr").length;
	if(aux > 1){
		$(".tr-manual-pos-"+pos).remove();
	}
}

function showButtonsBeneficiariesError(){
	let lengthError = $("#listFile table tbody .div-error-background-orange").length;
	if(lengthError == 0){
		$("#btn-hasErrors").addClass("hidden");
		$("#btn-hasErrorsFile").addClass("hidden");
		$('#salary-fileToList tr').each(function(){$(this).removeClass("hidden")});
	}else{
		$("#btn-hasErrors").removeClass("hidden");
	}
}
function showSalaryBeneficiariesError(obj){

	if(obj.hasClass("btn-danger")){
		$('#salary-fileToList tr').each(function(){$(this).addClass("hidden")});
		$("#listFile table tbody").find(".div-error-background-orange").each(function(){
			$(this).parent().parent().removeClass("hidden");
		});
		obj.removeClass("btn-danger").addClass("btn-primary");
		obj.text("Mostrar Todo");
		$("#btn-hasErrorsFile").removeClass("hidden");
	}else{
		$('#salary-fileToList tr').each(function(){$(this).removeClass("hidden")});
		obj.addClass("btn-danger").removeClass("btn-primary");
		obj.text("Mostrar solo Errores");
		$("#btn-hasErrorsFile").addClass("hidden");
	}
	var height2 = $(".pos-3-left").height();
	$("div .pos-3-right").height(height2);
	$("div .step-3-right").css("height", "100%");

}

function originBeneficiaryData(){
	SALARY_ORIGIN_BENEFICIARIES = new Map();
	SALARY_MODIFY_BENEFICIARIES = new Map();
	var length = $("#salary-fileToList tr").length-1;
	for(i=0; i<=length; i++){
		var beneficiaryText = "";
		var tdBeneficiary = $("#salary-fileToList tr:eq("+i+") td:eq(0)");
		var tdNumberAccount = $("#salary-fileToList tr:eq("+i+") td:eq(3)");
		var tdAmount = $("#salary-fileToList tr:eq("+i+") td:eq(5)");
		var accountNumberBeneficiary = "";
		var mountBeneficiary = tdAmount.find("input").val().replace(/\./g, '').replace(/,/g, '.');
		if(tdNumberAccount.find("input").val() === undefined){
			accountNumberBeneficiary = tdNumberAccount.text().trim();
		}else{
			accountNumberBeneficiary = tdNumberAccount.find("input").val();
		}

		if(tdBeneficiary.find("input").val() === undefined)
			beneficiaryText = tdBeneficiary.text().trim();
		else
			beneficiaryText = tdBeneficiary.find("input").val();
		var beneficiaryOrigin = new BeneficiaryModified(accountNumberBeneficiary, mountBeneficiary,beneficiaryText);
		let idMap = "tr-file-pos-"+i;
		SALARY_ORIGIN_BENEFICIARIES.set(idMap,beneficiaryOrigin);
	}
}

function BeneficiaryModified(nroCuenta,monto,beneficiario){
	this.beneficiario = beneficiario;
	this.nroCuenta = nroCuenta;
	this.monto = monto;
}

function modifiedSalaryBeneficiary(pos,type,obj){
	let idMap = "tr-file-pos-"+pos;
	let account = "";
	let amount = "";
	let beneficiary = "";
	if(type === "account")
		account = obj.val();
	else if(type === "amount")
		amount = obj.val();
	else if(type === "beneficiary")
		beneficiary = obj.val();
	if(SALARY_MODIFY_BENEFICIARIES.get(idMap) !== undefined){
		let beneficiaryModified = SALARY_MODIFY_BENEFICIARIES.get(idMap);
		if(type === "account"){
			account = obj.val();
			amount = beneficiaryModified.monto;
			beneficiary = beneficiaryModified.beneficiario;
		}else if(type === "amount"){
			amount = obj.val();
			account = beneficiaryModified.nroCuenta;
			beneficiary = beneficiaryModified.beneficiario;
		}else if(type === "beneficiary"){
			beneficiary = obj.val();
			amount = beneficiaryModified.monto;
			account = beneficiaryModified.nroCuenta;
		}

	}
	let beneficiaryOrigin = new BeneficiaryModified(account, amount,beneficiary);
	SALARY_MODIFY_BENEFICIARIES.set(idMap,beneficiaryOrigin);
}

function downloadFileSalaryError(){
	var req = new XMLHttpRequest();
	var params = "";
	req.open("POST", appname + "/salary/beneficiaries/error", true);
	req.responseType = "blob";
	req.setRequestHeader("Content-type", "application/x-www-form-urlencoded");
	req.onload = function () {
		if(req.status === 200){
			var blob = req.response;
			var fileName = 'salario-beneficiarios-errores.pdf';
			downloadAllReport(blob, fileName);
		}else{
			showModalGenericError("Error al generar el Comprobante");
		}

	};
	req.send(params);
}

function verifyTransactionSalary(){
	let totalAmount = $("#totalAmountSalaryPay").text().split(" ")[1];
	totalAmount = totalAmount.trim().replace(/\./g, '').replace(/,/g, '.');
	console.log("Method -> ", LOADING_METHOD);
	if(LOADING_METHOD === "A") {
		$(".loader").removeClass("hidden");
		$.ajax({
			type: "POST",
			dataType: 'json',
			url: appname + "/salary/validate-transaction",
			data: {
				totalPay: totalAmount
			}

		}).done(function (data) {
			$(".loader").addClass("hidden");
			if (data.hasError) {
				if (data.errorBody.useApiMessage)
					showModalAdminError(data.errorBody.message);
				else
					showModalAdminError("Error en la verificacion.");

				redirectLoginExpired(data.errorBody.code);
			} else {
				$('#dgcAceptar').off("click");
				$('#dgcRechazar').off("click");
				if (data.response.estado === "ERROR") {
					$(".loader").addClass("hidden");
					$('.message').html(data.response.mensaje);
					var dgcTiempo = 0;
					var alVentana = $('.dgcVentana').height();
					var alNav = $(window).height();
					var supNav = $(window).scrollTop();
					$('.dgcAlert').css('height', $(document).height());
					$('.dgcVentana').css('top', ((alNav - alVentana) / 2 + supNav - 100) + 'px');
					$('.dgcAlert').css('display', 'block');
					$('.dgcAlert').animate({opacity: 1}, dgcTiempo);
					$('.dgcMensaje .title-alert').text("Aviso");
					$('#dgcAceptar').text("Continuar el proceso");
					$('#dgcRechazar').text("Finalizar el proceso");
					$('#dgcRechazar').removeClass("hidden");
					$('#dgcAceptar').click(function (e) {
						$('.dgcAlert').animate({opacity: 0}, dgcTiempo);
						$('.dgcAlert').css('display', 'none');
						submitListBeneficiaries();
					});
					$('.dgcCerrar').click(function (e) {
						$('.dgcAlert').animate({opacity: 0}, dgcTiempo);
						$('.dgcAlert').css('display', 'none');
						$('.dgcMensaje .title-alert').text("Importante");
						$('#dgcAceptar').text("Aceptar");
						$('#dgcRechazar').addClass("hidden");
						$('#dgcRechazar').text("Rechazar");
					});
					$('#dgcRechazar').click(function (e) {
						$('.dgcCerrar').click();
					});
				} else {
					submitListBeneficiaries();
				}

			}


		}).fail(function (errorData, status, error) {
			$(".loader").addClass("hidden");
			var dataError = errorData.responseJSON;
			$("#container-main").css('margin-top', '0px');
			ajaxErrorHandler(dataError, status, error, "genericError");
		});
	} else {
		submitListBeneficiaries();
	}
}

