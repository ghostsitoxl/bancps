		$("#"+idPos+" .label-mountNumberBeneficiary").removeAttr("style");
		$("#"+idPos+" .mountBeneficiary").removeAttr("style");

		$("#totalDestiny").text($(".content-file-manual").length);
	}
	var height2 = $(".pos-3-left").height();
	 $("div .pos-3-right").height(height2);
	 $("div .step-3-right").css("height","100%");
}
//funcion que permite obtener datos del beneficiario en base al numero de cuenta
function getBeneficiaryData(pos){
	var numberAccount = $("#div-beneficiary-"+pos+" #accountNumberBeneficiary").val();
	POS_BENEFICIARY_DATA = pos;
	$.ajax({
		dataType: 'json',
        type: "POST",
        url: appname + "/salary/getbeneficiary",
        data:{
        	numberAccount : numberAccount.trim(),
        	typeRem : TYPE_REM
        }

    }).done(function (data) {
    	if(data.errorNumberAccount === ""){//si no hubo ningun error al traer los datos
    		var nameBeneficiary = data.nameBeneficiary.toLowerCase();
    		$("#div-beneficiary-"+POS_BENEFICIARY_DATA+" #nameBeneficiary").val(nameBeneficiary.capitalize());
        	$("#div-beneficiary-"+POS_BENEFICIARY_DATA+" #typeAccount").val(data.typeAccount);

        	$("#div-beneficiary-"+POS_BENEFICIARY_DATA+" .div-account-number-salary div").removeClass("div-error-background-orange"); //por si hubo un error anteriormente se limpia
    		$("#div-beneficiary-"+POS_BENEFICIARY_DATA+" .div-account-number-salary span").addClass("hidden");
    		$("#div-beneficiary-"+POS_BENEFICIARY_DATA+" .label-accountNumberBeneficiary").removeAttr("style");
    		$("#div-beneficiary-"+POS_BENEFICIARY_DATA+" .accountNumberBeneficiary").removeAttr("style");

    	}else{ //si hubo error se setea los estilos para marcar el error
    		$("#div-beneficiary-"+POS_BENEFICIARY_DATA+" .div-account-number-salary div").addClass("div-error-background-orange");
    		$("#div-beneficiary-"+POS_BENEFICIARY_DATA+" .div-account-number-salary span").text(data.errorNumberAccount);
			$("#div-beneficiary-"+POS_BENEFICIARY_DATA+" .div-account-number-salary span").removeClass("hidden");
    		$("#div-beneficiary-"+POS_BENEFICIARY_DATA+" .label-accountNumberBeneficiary").attr("style","color : white !important;");
    		$("#div-beneficiary-"+POS_BENEFICIARY_DATA+" .accountNumberBeneficiary").attr("style","color : white !important;");

    	}


    });
}
//para borrar el div seleccionado
function deleteDivManual(pos, employee) {
    if(EMPLOYEES_SELECTED != null && EMPLOYEES_SELECTED != undefined & EMPLOYEES_SELECTED != "") {
        if(employee != null && employee != undefined & employee != "") {
            EMPLOYEES_SELECTED = jQuery.grep(EMPLOYEES_SELECTED, function(value) {
                return value.accountNumberBeneficiary != employee;
            });
        }
    }
    console.log(EMPLOYEES_SELECTED);
    var aux = parseInt(pos);
    var length = $(".content-file-manual").length;
    if (length > 1) {
        $(".content-file-manual")[aux].remove();
        getTotalAmountSalary(pos);
        var height2 = $(".pos-3-left").height();
        $("div .pos-3-right").height(height2);
        $("div .step-3-right").css("height", "100%");
    }
}

//para borrar una de las filas de la tabla
function deleteRowFileList(pos){
	var aux = $("#div-file #listFile table tbody tr").length;
	if(aux > 1){
		$.ajax({
	        type: "POST",
	        url: appname + "/salary/delete/beneficiary",
	        data:{
	        	position: pos,
				type_record: 'FILE'
	        }
	    }).done(function (data) {
	    	let idMap = "tr-file-pos-"+pos
	    	$("."+idMap).remove();
	    	SALARY_ORIGIN_BENEFICIARIES.delete(idMap);
	    	SALARY_MODIFY_BENEFICIARIES.delete(idMap);
			showButtonsBeneficiariesError();
			getTotalFileToList();
			 var height2 = $(".pos-3-left").height();
			 $("div .pos-3-right").height(height2);
			 $("div .step-3-right").css("height","100%"); 
	    });
		
	}
}

function deleteRowLastList(pos){
	var aux = $("#div-last #listFile table tbody tr").length;
	if(aux > 1){
		$.ajax({
			type: "POST",
			url: appname + "/salary/delete/beneficiary",
			data:{
				position: pos,
				type_record: 'LAST'
			}
		}).done(function (data) {
			let idMap = "tr-file-pos-"+pos
			$("."+idMap).remove();
			SALARY_ORIGIN_BENEFICIARIES.delete(idMap);
			SALARY_MODIFY_BENEFICIARIES.delete(idMap);
			showButtonsBeneficiariesError();
			getTotalLastToList();
			var height2 = $(".pos-3-left").height();
			$("div .pos-3-right").height(height2);
			$("div .step-3-right").css("height","100%");
		});

	}
}

//funcion que muestra la lista de beneficiarios relacionados a la empresa dentro de un modal
function savedBeneficiaries(pos) {
	console.log("Posicion ", pos);
    POS_BENEFICIARY_SELECTED = pos;
    $("#tableList tr td input[type='checkbox']:checked").each(function () {
        $(this).prop('checked',true);
    });

    var posCheck = $("input[name=radioSalaryBeneficiaries]:checked").val();

    if(EMPLOYEES_SELECTED == null || EMPLOYEES_SELECTED == undefined) {
        EMPLOYEES_SELECTED = [];
    }

    console.log("Employees selected: ", JSON.stringify(EMPLOYEES_SELECTED));

    $.ajax({
        type: "POST",
        url: appname + "/salary/savedbeneficiaries",
        data: {
            listBeneficiariesSelected: JSON.stringify(EMPLOYEES_SELECTED)
        }
    }).done(function (data) {
        $("#listSavedBeneficiaries").html(data);
        $("#modalSavedBeneficiaries").modal('toggle');
        var height = window.innerHeight - 168; //para adaptar el tamaño total del modal
        $("#listSavedBeneficiaries").css("max-height",height+"px");

    }).fail(function (request, status, error) {
        var errorData = request.responseJSON;
        $("#container-main").css('margin-top', '0px');
        ajaxErrorHandler(errorData, status, error, "genericError");
    })
}
