function searchBeneficiariesModal(){
	var denominationBeneficiary = $("#denominationBeneficiariesModal").val().toUpperCase();
	var nroCuentaBeneficiary = $("#nroCuentaBeneficiariesModal").val();
	var table = $("#listSavedBeneficiaries #tableList tbody tr");
	var count = 0;
	console.log("Cantidad de filas ", table.length);
	for(var i=0;i<table.length-1;i++){
		var td1 = $(".tr-manual-pos-"+i+" td:eq(1)");
		var td2 = $(".tr-manual-pos-"+i+" td:eq(3)");
		var tr = $(".tr-manual-pos-"+i);
		if(denominationBeneficiary !== "" && nroCuentaBeneficiary === "") {
			console.log('Posicion ', i, ' -> ', td1);
			if(td1.html().toUpperCase().indexOf(denominationBeneficiary) > -1){
				tr.css("display","");
			} else {
				tr.css("display","none");
				count++;
			}
		} else if(denominationBeneficiary === "" && nroCuentaBeneficiary !== ""){
			if(td2.html().toUpperCase().indexOf(nroCuentaBeneficiary) > -1){
				tr.css("display","");
			}else{
				tr.css("display","none");
				count++;
			}
		} else if(denominationBeneficiary !== "" && nroCuentaBeneficiary !== "") {
			if(td1.html().toUpperCase().indexOf(denominationBeneficiary) > -1 &&
				td2.html().toUpperCase().indexOf(nroCuentaBeneficiary) > -1) {
				tr.css("display","");
			} else {
				tr.css("display","none");
				count++;
			}
		} else {
			tr.css("display","");
		}
	}

	if(count === table.length){
		$("#tableAux").removeClass("hidden");
		$("#tableList").addClass("hidden");
	} else {
		$("#tableAux").addClass("hidden");
		$("#tableList").removeClass("hidden");
	}
}

