function calculateXpressComission(element){
	var amount = element.val().replace(/\./g, '').replace(/,/g, '.');
	var transferComission = $("#transfer-commission");
	var comissionPercent = parseFloat($("#xpressComisionPorcentaje").val());
	var comission = 0;
	comission = (comission * comissionPercent) / 100;
	var decimals = false;
	if(currencyProduct === "GS"){
		comission = parseInt(amount);
		comission = parseInt(Math.round((comission * comissionPercent) / 100));
		var commissionGs = parseInt($("#xpressComisionMinGs").val());
		if(comission > commissionGs)
			transferComission.val(comission)
		else
			transferComission.val(commissionGs)
	}else{
		comission = parseFloat(amount);
		comission = parseFloat((comission * comissionPercent) / 100).toFixed(2);
		decimals = true;
		var commissionUsd = parseFloat($("#xpressComisionMinUsd").val());
		if(comission > commissionUsd)
			transferComission.val(comission.toString().replace(".",","))
		else
			transferComission.val(commissionUsd.toString().replace(".",","))
	}
	formatAmount(transferComission,decimals);

}

function showContacts(level) {
	var destiny = $("#select-destiny-val").val();
	$(".loader").removeClass("hidden");
	$.ajax({
		type: "POST",
		url: appname + "/transfer/contacts",
		data: {
			destiny: destiny
		}
	}).done(function (data) {
		$("#listSavedContacts").html(data);
		$("#modalSavedContacts").modal('show');
		var height = window.innerHeight - 168;
		$("#listSavedContacts").css("max-height",height+"px");
		$(".loader").addClass("hidden");
		if(level == 2) {
			if(destiny == "Otras Cuentas") {
				$("#select-beneficiary-third option[value=" + NRO_ACCOUNT_DELETE + "]").remove();
				let nroCuenta = $("#select-beneficiary-third").val();
				if(nroCuenta.length > 0) {
					$("#select2-select-beneficiary-third-container").text(nroCuenta);
					setTimeout(function () {
						$("#select2-select-beneficiary-third-container").text(nroCuenta);
					},500);
				}
			} else if(destiny == "Otros Bancos SIPAP") {
				$("#select-beneficiary-sipap-0 option[value=" + NRO_ACCOUNT_DELETE + "]").remove();
				let nroCuenta = $("#select-beneficiary-sipap-0").val();
				if(nroCuenta.length > 0) {
					$("#select2-select-beneficiary-sipap-0-container").text(nroCuenta);
					setTimeout(function () {
						$("#select2-select-beneficiary-sipap-0-container").text(nroCuenta);
					},500);
				}
			} else if(destiny == "COOPERATIVA") {
				$("#select-beneficiary-coop option[value=" + NRO_ACCOUNT_DELETE + "]").remove();
				let nroCuenta = $("#select-beneficiary-coop").val();
				if(nroCuenta.length > 0) {
					actualizarNroCuenta(nroCuenta)
					setTimeout(function () {
						var valor = $("#select-beneficiary-coop").val();
						var coopPrefijo = $("#choose-entity-coop-0 option:selected").attr("prefijo");

						if(coopPrefijo == undefined || coopPrefijo == "" || coopPrefijo == "0")
							return;
						if(valor == null || valor == undefined || valor == "0")
							valor = "";
						$("#select2-select-beneficiary-coop-container").text(coopPrefijo+valor);
					},500);
				}
			} else if(destiny == "INTERNACIONAL") {
				$("#select-beneficiary-international option[value=" + NRO_ACCOUNT_DELETE + "]").remove();
				let nroCuenta = $("#select-beneficiary-international").val();
				if(nroCuenta.length > 0) {
					$("#select2-select-beneficiary-international-container").text(nroCuenta);
					setTimeout(function () {
						$("#select2-select-beneficiary-international-container").text(nroCuenta);
					},500);
				}
			}
		}
	}).fail(function (request, status, error) {
		var errorData = request.responseJSON;
		$("#container-main").css('margin-top', '0px');
		ajaxErrorHandler(errorData, status, error, "genericError");
		$(".loader").addClass("hidden");
	})
}

function deleteContact(beneficiario, nroCuenta) {
	$("#spanDenominacion").text(beneficiario.capitalize());
	$("#spanNroCuenta").text(nroCuenta);
	$("#modalConfirmDelete").modal('toggle');
	NRO_ACCOUNT_DELETE = nroCuenta;
}

function closeConfirmDelete() {
	$("#modalConfirmDelete").modal('toggle');
}

function deleteContactConfirmed() {
	$.ajax({
		type: "POST",
		url: appname + "/transfer/contacts/delete",
		data: {
			accountNumber: NRO_ACCOUNT_DELETE
		}
	}).done(function (data) {
		$("#modalConfirmDelete").modal('hide');
		$("#modalSavedContacts").modal('hide');
		if(data.response.toString().toUpperCase() === "OK") {
			setTimeout(function () {
				showContacts(2);
			},500);
		}
	}).fail(function (request, status, error) {
		$("#modalConfirmDelete").modal('hide');
	})
}

function searchContactsModal(){
    var busqueda = $("#nroCuentaBeneficiariesModal").val();
    var table = $("#tableList tbody tr");
    var count = 0;
    for(var i=0;i<table.length;i++){
        var tdDenominacion = $(".tr-manual-pos-"+i+" td:eq(1)");  // Denominación
        var tdCuenta = $(".tr-manual-pos-"+i+" td:eq(2)");        // Cuenta
        var tdMoneda = $(".tr-manual-pos-"+i+" td:eq(3)");        // Moneda
        var tdDocumento = $(".tr-manual-pos-"+i+" td:eq(4)");     // Documento
        var tr = $(".tr-manual-pos-"+i);
        
        if(busqueda !== "") {
            if(tdDenominacion.html().toUpperCase().indexOf(busqueda.toUpperCase()) > -1 ||
                tdCuenta.html().toUpperCase().indexOf(busqueda.toUpperCase()) > -1 ||
                tdMoneda.html().toUpperCase().indexOf(busqueda.toUpperCase()) > -1 ||
                tdDocumento.html().toUpperCase().indexOf(busqueda.toUpperCase()) > -1
            ){
                tr.css("display","");
            } else {
                tr.css("display","none");
                count++;
            }
        } else {
            tr.css("display","");
        }
    }

	if(busqueda !== "") {
		if(count === table.length){
			$("#tableAux").removeClass("hidden");
			$("#tableList").addClass("hidden");
		} else {
			$("#tableAux").addClass("hidden");
			$("#tableList").removeClass("hidden");
		}
	} else {
		$("#tableAux").addClass("hidden");
		$("#tableList").removeClass("hidden");
	}

}

function loadContact(nroCuenta) {
	var destiny = $("#select-destiny").val();
	$("#modalSavedContacts").modal('hide');
	if(destiny == "Otras Cuentas") {
		$("#select-beneficiary-third").val(nroCuenta).trigger("change")
		$("#select2-select-beneficiary-third-container").text(nroCuenta);
		fillFieldsTransfer(nroCuenta, "TRANSFERENCIA_TERCEROS", $("#select-beneficiary-third"));

	} else if(destiny == "Otros Bancos SIPAP") {
		$("#select-beneficiary-sipap-0").val(nroCuenta).trigger("change")
		$("#select2-select-beneficiary-sipap-0-container").text(nroCuenta);
		fillFieldsTransfer(nroCuenta, "TRANSFERENCIA_SIPAP", null);

	} else if(destiny == "COOPERATIVA") {
		$("#account-number-select").val(nroCuenta)
		console.log("Nro de cuenta a cargar ", nroCuenta)
		$("#select-beneficiary-coop").val(nroCuenta).trigger("change")
		actualizarNroCuenta(nroCuenta)
		fillFieldsTransferCooperativaWithParam(nroCuenta, "TRANSFERENCIA_COOPERATIVA");

	} else if(destiny == "INTERNACIONAL") {
		$("#select-beneficiary-international").val(nroCuenta).trigger("change")
		$("#select2-select-beneficiary-international-container").text(nroCuenta);
		fillFieldsTransfer(nroCuenta, "TRANSFERENCIA_INTERNACIONAL", $("#select-beneficiary-international"));
	}

}

function actualizarNroCuenta(nroCuenta){
	var valor = nroCuenta;
	var coopPrefijo = $("#choose-entity-coop-0 option:selected").attr("prefijo");

	if(coopPrefijo == undefined || coopPrefijo == "" || coopPrefijo == "0")
		return;
	if(valor == null || valor == undefined || valor == "0")
		valor = "";
	$("#select2-select-beneficiary-coop-container").text(coopPrefijo+valor);
}

function validarCuentaCooperativaTransfer(nroCuenta){
	hideErrorBlocksTransfer();
	var coopPrefijo = $("#choose-entity-coop-0 option:selected").attr("prefijo");
	var tipoDocumento = $("div#transferenciaCooperativa #choose-type-document-0 option:selected").attr("value");
	var nroDocumento = $("div#transferenciaCooperativa #transfer-document1-0").val();
	var idAfiliado = $("#choose-entity-coop-0 option:selected").attr("idAfiliado");
	$.ajax({
		type: "POST",
		url: appname + "/account/coop",
		data: {
			idAfiliado: idAfiliado,
			numberAccount: coopPrefijo+nroCuenta,
			typeDocument: tipoDocumento,
			document: nroDocumento
		}
	}).done(function (data) {
	}).fail(function (request, status, error) {
		var errorData = request.responseJSON;
		ajaxErrorHandler(errorData, status, error, "genericError");
		return false;
	});
}

function fillFieldsTransferCooperativaWithParam(account,typeTransfer){
	var typeSipap = $("#transfer-type").val();
	$(".loader").removeClass("hidden");
	$.ajax({
		type: "POST",
		url: appname + "/transfer/fill-fields",
		data: {
			account: account,
			typeTransaction: typeTransfer,
			typeSipap: typeSipap
		}
	}).done(function (data) {
		$(".loader").addClass("hidden");
		var obj = jQuery.parseJSON(data);
		$("#select-beneficiary-coop").val(account);
		console.log("Nro de cuenta a cargar desde fillFields ", account);
		$("#select-beneficiary-coop").trigger("change");
		console.log("Select value:", $("#select-beneficiary-coop").val());
		$("#destiny-account-coop").val(account);
		$("div#transferenciaCooperativa #choose-entity-coop-0").val(obj.entidad).change();
		$("div#transferenciaCooperativa #choose-type-document-0").val(obj.tipoDocumento);
		$("div#transferenciaCooperativa #transfer-document1-0").val(obj.nroDocumento);
		$("div#transferenciaCooperativa #nameLastname-0").val(obj.beneficiario);
		$("div#transferenciaCooperativa #choose-country").val(obj.paisDestino.codigoPais);
		$("div#transferenciaCooperativa #choose-city").val(obj.ciudadDestino.codigoCiudad);
		$("div#transferenciaCooperativa #transferCoinInt").val(obj.codigoMoneda);
	}).fail(function (request, status, error) {
		$(".loader").addClass("hidden");
		var errorData = request.responseJSON;
		ajaxErrorHandler(errorData, status, error, ID_GENERIC_ERROR);
	})
}