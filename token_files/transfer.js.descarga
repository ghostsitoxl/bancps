	var token = $("#tokenTransfer").val();
	var keyAproval = $("#keyAproval").val();
	var typeTransaction = $("#typeTransaction").val();
	$(".loader").removeClass("hidden");
	$("#step-4 #buttonReadyToTransfer").attr("disabled","disabled");
	$.ajax({
		type: "POST",
		url: appname + "/transfer/confirminternationaltransfer",
		data: { 
			dinamicKey: key,
			tokenTransferAproved:token,
			keyAproval : keyAproval,
			typeTransaction : typeTransaction,
			numberProduct : numberProduct

		}	
	}).done(function (data) {
		$(".loader").addClass("hidden");
		$("#step-3").addClass("hidden");
		$("#step-4 #buttonReadyToTransfer").removeAttr("disabled");
		$("#step-4").html(data);
		$("#step-4").removeClass("hidden");
		
		$("div.step-last1-left #numberCuentaConfirm").text(productText);
		
		
		$("div.step-last2-left #numberCuentaConfirmDestination").text(TEXT_STEP_2);
		$("#BeneficiaryData").text(TEXT_STEP_3);
		
		var height1 = $("div.step-last1-left").height();
		height1 = height1;
		$("div.step-last1-right").height(height1);
		
		var height1 = $("div.step-last2-left").height();
		height1 = height1;
		$("div.step-last2-right").height(height1);
		$("div.step-last2-right i").css("height","100%");
		
		var height1 = $("div.step-last3-left").height();
		height1 = height1;
		$("div.step-last3-right").height(height1);
		
		var height1 = $("div.step-last-left").height();
		height1 = height1;
		$("div.step-last-right").height(height1);
	
	}).fail(function (request, status, error) {
		$(".loader").addClass("hidden");
		$("#step-4 #buttonReadyToTransfer").removeAttr("disabled");
		var errorData = request.responseJSON;
		ajaxErrorHandler(errorData, status, error, ID_GENERIC_ERROR);
	})
}
function ShowBeneficiarySelectLabel(){
	var elementID = this.getAttribute("id");
	var element = $("div#beneficiaryForm #"+elementID);
	
	if(element.val() !== "0" ){
		$("div#beneficiaryForm #label-" + elementID).removeClass("hidden");
	}else{
		$("div#beneficiaryForm #label-" + elementID).addClass("hidden");
	}
}


function saveBeneficiaryDataInter(beneficiaryName,beneficiaryNumber, beneficiaryDirection, typeDocumentBeneficiary,
		beneficiaryDocument,beneficiaryCountry,beneficiaryCity, beneficiaryEmail){
	BENEFICIARY_NAME_INTER = beneficiaryName;
	BENEFICIARY_NUMBER_INTER = beneficiaryNumber;
	BENEFICIARY_TYPE_DOCUMENT_INTER = typeDocumentBeneficiary;
	BENEFICIARY_DOCUMENT_INTER = beneficiaryDocument;
	BENEFICIARY_COUNTRY_INTER = beneficiaryCountry;
	BENEFICIARY_CITY_INTER = beneficiaryCity;
	BENEFICIARY_DIRECTION_INTER = beneficiaryDirection;
	BENEFICIARY_EMAIL = beneficiaryEmail;
	
}
