					callback();
			}, 300);
		});*/
	}
	if(!$.isEmptyObject(BENEFICIARY_CITY_INTER) && BENEFICIARY_CITY_INTER !== ""){
		/*$("div#beneficiaryForm #choose-country").trigger("change", function () {
			$("div#beneficiaryForm #choose-city").val(BENEFICIARY_CITY_INTER.codigoCiudad);
			$("div#beneficiaryForm #choose-city").trigger("change");
			setTimeout(function () {
				$("div#beneficiaryForm #choose-city").val(BENEFICIARY_CITY_INTER.codigoCiudad).change();
			}, 1500);
		});*/
		let codCity = BENEFICIARY_CITY_INTER.codigoCiudad !== undefined ? BENEFICIARY_CITY_INTER.codigoCiudad : BENEFICIARY_CITY_INTER;
		setTimeout(function () {
			$("div#beneficiaryForm #choose-city").val(codCity).change();
		}, 2000);


		/*$("div#intDestiny #choose-country").trigger("change", function () {
			$("div#intDestiny #choose-city").val(obj.ciudadDestino.codigoCiudad);
			$("div#intDestiny #choose-city").trigger("change");
			setTimeout(function () {
				$("div#intDestiny #choose-city").val(obj.ciudadDestino.codigoCiudad);
				$("div#intDestiny #choose-city").trigger("change");
			}, 500);
		});
		setTimeout(function() {
			$("div#beneficiaryForm #choose-city").val(BENEFICIARY_CITY_INTER.codigoCiudad);
			$("div#beneficiaryForm #choose-city").trigger("change");
		},500);*/
	}

	
	$("#beneficiaryDocument").val(BENEFICIARY_DOCUMENT_INTER);
	$("#beneficiaryDocument").trigger("change");
	$("#beneficiaryDirection").val(BENEFICIARY_DIRECTION_INTER);
	$("#beneficiaryDirection").trigger("change");
	$("#beneficiaryEmail").val(BENEFICIARY_EMAIL);
	$("#beneficiaryEmail").trigger("change");
}
function sendBeneficiaryNextStep(){
	var beneficiaryName = $("#beneficiaryName").val();
	var beneficiaryNumber = $("#beneficiaryPhone").val();
	var beneficiaryDirection = $("#beneficiaryDirection").val();
	var typeDocumentBeneficiary = $("div#beneficiaryForm #choose-type-document-0").val();
	var typeDocumentBeneficiaryDesc = $("div#beneficiaryForm #choose-type-document-0 option:selected").text();
	var beneficiaryDocument = $("#beneficiaryDocument").val();
	var beneficiaryCountryDesc = $("div#intBeneficiary #choose-country option:selected").text();
    var beneficiaryCountry = $("div#intBeneficiary #choose-country").val();
    var beneficiaryCityDesc = $("div#intBeneficiary #choose-city option:selected").text();
    var beneficiaryCity = $("div#intBeneficiary #choose-city").val();
    var beneficiaryEmail = $("#beneficiaryEmail").val();
    
    var next = "false";
    next = validateBeneficiaryInputs(beneficiaryName, beneficiaryNumber, beneficiaryDirection, typeDocumentBeneficiary, beneficiaryDocument, beneficiaryCountry, beneficiaryCity, beneficiaryEmail);
	if (next === "true"){
		
		if(beneficiaryEmail != "" && !validateEmail(beneficiaryEmail)){
			showModalGenericError("Ingrese un email válido.");
			return;
		}
		
		var transferInternationalBeneficiary = new loadBeneficiaryData(beneficiaryName, beneficiaryNumber, beneficiaryDirection, typeDocumentBeneficiary, beneficiaryDocument, beneficiaryCountry, beneficiaryCity, beneficiaryEmail);
		
		saveBeneficiaryDataInter(beneficiaryName,beneficiaryNumber, beneficiaryDirection, typeDocumentBeneficiary,
				beneficiaryDocument,beneficiaryCountry,beneficiaryCity, beneficiaryEmail);
		transferInternationalBeneficiary = JSON.stringify(transferInternationalBeneficiary);
        
        TEXT_STEP_3 = "Denominación: " + beneficiaryName.toLowerCase().capitalize() + " / " + "Documento: " + beneficiaryDocument + " / " + "Tipo Documento: " + typeDocumentBeneficiaryDesc.toLowerCase().capitalize() + " / " +
		"Pais: " + beneficiaryCountryDesc.toLowerCase().capitalize() + " / " + "Ciudad: " + beneficiaryCityDesc.toLowerCase().capitalize();
        if(beneficiaryDirection !== ""){
        	TEXT_STEP_3+=  " / "+"Dirección: "+ beneficiaryDirection.toLowerCase().capitalize();
        }else if(beneficiaryNumber !== ""){
        	TEXT_STEP_3+= " / " + "Teléfono: " + beneficiaryNumber +".";  
        }
        TEXT_STEP_3+=  " / "+"Email: "+ beneficiaryEmail;
        transferInternationalRegisterBeneficiary(transferInternationalBeneficiary);
	}else{
		msg = "Debe Completar todos los campos";
		showModalGenericError(msg);
		setEmptyErrorMessagesInternational();
	}
}
function validateBeneficiaryInputs(beneficiaryName, beneficiaryNumber, beneficiaryDirection, beneficiaryTypeDocument, beneficiaryDocument, beneficiaryCountry, beneficiaryCity, beneficiaryEmail){
	var allOK = "true"
	if(beneficiaryName === "" || beneficiaryCountry === "0" || beneficiaryCity === "0" || beneficiaryDirection === ""){
		allOK="false";
	}
	return allOK;
}

function showHideLabelCountry(element){
	var parent = element.parentElement.parentElement.parentElement.parentElement.parentElement.getAttribute("id");
	var selectedCountry = element.value;
	if(selectedCountry === "0"){
		$("div#"+parent+" #label-choose-country").addClass("hidden");
    }else{
    	$("div#"+parent+" #label-choose-country").removeClass("hidden");
    	loadCities(selectedCountry, parent);
    }
}

function modifySelectCitiesInternationalTransfer(){
	var selectorDestiny = $("#transferenciaInternacional #intDestiny #choose-city");
	var selectorIntermediary = $("#transferenciaInternacional #intIntermediary #choose-city");
	var selectorBeneficiary = $("#intBeneficiary #choose-city");

	if(!selectorBeneficiary.next().hasClass("select2")){
		selectorBeneficiary.select2({
	        language:{
	                formatNoMatches:function (term){
	                return null;
	        }
	        },
	        placeholder:'Seleccionar una ciudad',
	        width:'100%',
	        tags: true
		}).on("select2:select", function(e) {
		    
		});
		return;
	}
	
	if(!selectorDestiny.next().hasClass("select2")){
		selectorDestiny.select2({
			language:{
				formatNoMatches:function (term){
					return null;
				}
			},
			placeholder:'Seleccionar una ciudad',
			width:'100%',
			tags: true
		}).on("select2:select", function(e) {
			
		});
		return;
	}
	
	if(!selectorIntermediary.next().hasClass("select2")){
		selectorIntermediary.select2({
			language:{
				formatNoMatches:function (term){
					return null;
				}
			},
			placeholder:'Seleccionar una ciudad',
			allowClear: true,
			width:'100%',
			tags: true
		}).on("select2:select", function(e) {
			
		});
	}
	
}

function fillFieldsTransfer(account,typeTransfer,element){
	var typeSipap = $("#transfer-type").val();
	$(".loader").removeClass("hidden");
	$.ajax({
		type: "POST",
		url: appname + "/transfer/fill-fields",
		data: { 
			account: account,
			typeTransaction: typeTransfer,
			typeSipap: typeSipap
		}	
	}).done(function (data) {
		$(".loader").addClass("hidden");
		var obj = jQuery.parseJSON(data);
		switch (typeTransfer) {
			case 'TRANSFERENCIA_INTERNACIONAL':
				$("div#transferenciaInternacional #label-inter").removeClass("hidden");
				$("div#transferenciaInternacional #transferCoinInt").val(obj.codigoMoneda);
				$("#inputSwift").val(obj.entidadSwift);
				if (obj.abaDestino !== "") {
					$("div#transferenciaInternacional #inputABA").removeClass("empty");

				}
				$("#inputABA").val(obj.abaDestino);
				BENEFICIARY_NAME_INTER = obj.beneficiario;
				BENEFICIARY_NUMBER_INTER = obj.telefono;
				BENEFICIARY_TYPE_DOCUMENT_INTER = obj.tipoDocumento;
				BENEFICIARY_DOCUMENT_INTER = obj.nroDocumento;
				if (typeof obj.paisBeneficiario !== 'undefined') {
					BENEFICIARY_COUNTRY_INTER = obj.paisBeneficiario;
					if (typeof obj.ciudadBeneficiario !== 'undefined') {
						BENEFICIARY_CITY_INTER = obj.ciudadBeneficiario;
					}
				}
				BENEFICIARY_DIRECTION_INTER = obj.dirBeneficiario;
				BENEFICIARY_EMAIL = obj.correoElectronico;
				$("div#transferenciaInternacional #inputBank").val(obj.entidad);
				if (typeof obj.entidadInt !== 'undefined') {
					$("div#transferenciaInternacional #intermediaryEntity").val(obj.entidadInt);
					$("div#transferenciaInternacional #intermediaryEntity").trigger("change");
				}
				if (typeof obj.abaInter !== 'undefined') {
					$("div#transferenciaInternacional #intermediaryAba").val(obj.abaInter);
					$("div#transferenciaInternacional #intermediaryAba").trigger("change");
				}
				if (typeof obj.entidadSwiftInt !== 'undefined') {
					$("div#transferenciaInternacional #intermediarySwift").val(obj.entidadSwiftInt);
					$("div#transferenciaInternacional #intermediarySwift").trigger("change");
				}
				if (typeof obj.tiempo !== 'undefined') {
					$("div#transferenciaInternacional #selectTime").val(obj.tiempo);
					$("div#transferenciaInternacional #selectTime").trigger("change");
				} else {
					$("div#transferenciaInternacional #selectTime").val("0hs");
				}
				if (typeof obj.modalidadCobro !== 'undefined') {
					$("div#transferenciaInternacional #selectPaymentMode").val(obj.modalidadCobro);
					$("div#transferenciaInternacional #selectPaymentMode").trigger("change");
				}
				if (typeof obj.cuentaComision !== 'undefined') {
					$("div#transferenciaInternacional #modalitySelectProduct").val(obj.cuentaComision);
					$("div#transferenciaInternacional #modalitySelectProduct").trigger("change");
				}
				$("div#transferenciaInternacional #inputBank").removeClass("empty");
				$("div#transferenciaInternacional #inputSwift").removeClass("empty");

				if (!$.isEmptyObject(obj.paisDestino)) {
					$("div#intDestiny #choose-country").val(obj.paisDestino.codigoPais);
					$("div#intDestiny #choose-country").change(function (e, callback) {

						setTimeout(function () {
							if (typeof callback === "function")
								callback();
						}, 200);
					});


				}

				if (!$.isEmptyObject(obj.ciudadDestino)) {
					$("div#intDestiny #choose-country").trigger("change", function () {
						$("div#intDestiny #choose-city").val(obj.ciudadDestino.codigoCiudad);
						$("div#intDestiny #choose-city").trigger("change");
						setTimeout(function () {
							$("div#intDestiny #choose-city").val(obj.ciudadDestino.codigoCiudad);
							$("div#intDestiny #choose-city").trigger("change");
						}, 500);
					});
				}

				if (!$.isEmptyObject(obj.paisInter)) {
					$("div#intIntermediary #choose-country").val(obj.paisInter.codigoPais);
					$("div#intIntermediary #choose-country").change(function (e, callback) {

						setTimeout(function () {
							if (typeof callback === "function")
								callback();
						}, 500);
					});
				}

				if (!$.isEmptyObject(obj.ciudadInter)) {
					$("div#intIntermediary #choose-country").trigger("change", function () {
						$("div#intIntermediary #choose-city").val(obj.ciudadInter.codigoCiudad);
						$("div#intIntermediary #choose-city").trigger("change");
						setTimeout(function () {
							$("div#intIntermediary #choose-city").val(obj.ciudadInter.codigoCiudad);
							$("div#intIntermediary #choose-city").trigger("change");
						}, 500);
					});
				}

				break;
			case 'TRANSFERENCIA_TERCEROS':

				$("div#transferenciaTerceros #transfer-document1-0").val(obj.nroDocumento);
				$("div#transferenciaTerceros #transfer-document1-0").removeClass("empty");
				break;
			case 'TRANSFERENCIA_XPRESS':
				$("div#transferenciaXpress #transfer-document1-0").val(obj.nroDocumento);
				$("div#transferenciaXpress #choose-entity-xpress-0").val(obj.entidad);
				$("div#transferenciaXpress #label-for-choose-entity-xpress-0").removeClass("hidden");
				$("div#transferenciaXpress #nameLastname-0").val(obj.beneficiario);
				$("div#transferenciaXpress #nameLastname-0").removeClass("empty");
				$("div#transferenciaXpress #choose-type-document-0").val(obj.tipoDocumento);
				$("div#transferenciaXpress #label-choose-type-document-0").removeClass("hidden");

				break;
			default://si es SIPAP
				var position = 0
				if(element != null) {
					split = element.context.id.split("-");
					var position = split[split.length - 1];
				}

				$("#sipap-algo-" + position + " div#transferenciaSipap #transfer-coin-" + position).val(obj.codigoMoneda);
				$(".select-currency-sipap").trigger("change");
				$("#sipap-algo-" + position + " div#transferenciaSipap #transfer-coin-" + position).removeClass("empty");

				$("#sipap-algo-" + position + " div#transferenciaSipap #choose-entity-" + position).val(obj.entidad);
				$("#sipap-algo-" + position + " div#transferenciaSipap #label-for-choose-entity-" + position).removeClass("hidden");

				$("#sipap-algo-" + position + " div#transferenciaSipap #nameLastname-" + position).val(obj.beneficiario);
				$("#sipap-algo-" + position + " div#transferenciaSipap #nameLastname-" + position).removeClass("empty");
				if (obj.tipoDocumento !== "") {
					$("#sipap-algo-" + position + " div#transferenciaSipap #choose-type-document-" + position).val(obj.tipoDocumento);
					$("#sipap-algo-" + position + " div#transferenciaSipap #label-choose-type-document-" + position).removeClass("hidden");

				}
				$("#sipap-algo-" + position + " div#transferenciaSipap #transfer-document1-" + position).val(obj.nroDocumento);
				$("#sipap-algo-" + position + " div#transferenciaSipap #transfer-document1-" + position).removeClass("empty");
				break;
		}
	}).fail(function (request, status, error) {
		$(".loader").addClass("hidden");
		var errorData = request.responseJSON;
		ajaxErrorHandler(errorData, status, error, ID_GENERIC_ERROR);
	})	
}

function fillFieldsTransferCooperativa(account,typeTransfer){
	var typeSipap = $("#transfer-type").val();
	$(".loader").removeClass("hidden");
	$.ajax({
		type: "POST",
		url: appname + "/transfer/fill-fields",
		data: { 
			account: account,
			typeTransaction: typeTransfer,
			typeSipap: typeSipap
		}	
	}).done(function (data) {
		$(".loader").addClass("hidden");
		var obj = jQuery.parseJSON(data);
		$("div#transferenciaCooperativa #choose-entity-coop-0").val(obj.entidad).change();
		$("div#transferenciaCooperativa #choose-type-document-0").val(obj.tipoDocumento);
    	$("div#transferenciaCooperativa #transfer-document1-0").val(obj.nroDocumento);
    	$("div#transferenciaCooperativa #nameLastname-0").val(obj.beneficiario);
    	$("div#transferenciaCooperativa #choose-country").val(obj.paisDestino.codigoPais);
    	$("div#transferenciaCooperativa #choose-city").val(obj.ciudadDestino.codigoCiudad);
    	$("div#transferenciaCooperativa #transferCoinInt").val(obj.codigoMoneda);
	}).fail(function (request, status, error) {
		$(".loader").addClass("hidden");
		var errorData = request.responseJSON;
		ajaxErrorHandler(errorData, status, error, ID_GENERIC_ERROR);
	})	
}

function consultarOrdenDePago(){
	var ordenDePago = $("#transferPayOrder").val();
	if(ordenDePago == "") return;
	$.ajax({
		type: "GET",
		url: appname + "/transfer/payOrder",
		dataType: 'json', 
		data: {
			payOrder : ordenDePago
		}
	}).done(function(data){
		console.log("data completa:", data);
		$("#transferenciaInternacional #transferAmountPayOrder").val(data.monto.toString().replace(/\./,',')).trigger("keyup").attr("disabled", true);
		$("#transferenciaInternacional #transferCoinPayOrder").val(data.codigoMoneda).change().attr("disabled", true);
	}).fail(function(request, status, error){
		var errorData = request.responseJSON;
		$("#transferenciaInternacional #transferAmountPayOrder").attr("disabled", false).val("");
		$("#transferenciaInternacional #transferCoinPayOrder").attr("disabled", false).val("0");
		ajaxErrorHandler(errorData, status, error, ID_GENERIC_ERROR);
	})
}


function validateCoopInputs(tranfData) {
	if (tranfData.byAlias == true) {
		if (tranfData.source === "" ||
			tranfData.coin === "" || tranfData.coin === "0" ||
			tranfData.ammount === "" ||
			tranfData.concept === "" ||
			tranfData.reason === "" || tranfData.reason === "0" ||
			tranfData.alias === "" ||
			tranfData.typeAlias === "") {
			return false;
		}
		return true;
	} else {
		if (tranfData.cuentaOrigen === "" ||
			tranfData.cuentaDestino === "" ||
			tranfData.codCooperativa === "" ||
			tranfData.nombreCooperativa === "" ||
			tranfData.denominacion === "" ||
			tranfData.moneda === "0" ||
			tranfData.monto === "" ||
			tranfData.tipoDocumento === "0" ||
			tranfData.nroDocumento === "" ||
			tranfData.codPais === "0" ||
			tranfData.codCiudad === "undefined" ||
			tranfData.codMotivo === "0" ||
			tranfData.concepto === "") {
			return false;
		}
		return true;
	}
}

function validateXpressInputs(xpressData){
	if(xpressData.originAccount === "" || xpressData.entity === "" || xpressData.destinyAccount === "" || xpressData.amount === "" || xpressData.concept === "")
		//xpressData.beneficiary === "" || xpressData.typeDoc === "" || xpressData.numberDoc === "" ||
		//xpressData.concept === "" ||
		return false;
	return true;
}

function setEmptyErrorMessagesCoop(tranfData) {
	if (tranfData.alias !== undefined && tranfData.typeAlias !== undefined) {
		var alias = tranfData.alias;
		var typeAlias = tranfData.typeAlias;
		var currency = tranfData.coin;
		var amount = tranfData.ammount;
		var concept = tranfData.concept;
		var reason = tranfData.reason;
		var codPais = tranfData.codPais;
		var codCiudad = tranfData.codCiudad;

		if (alias === "") {
			$("#transferenciaCooperativa #alias-0").addClass("orange-background");
			$("#transferenciaCooperativa #error-alias").text("Introduzca un alias");
		}

		if (typeAlias === "") {
			$("#transferenciaCooperativa #aliasType-0").addClass("orange-background");
			$("#transferenciaCooperativa #error-aliasType").text("Seleccione tipo de alias");
		}

		if (currency === "" || currency === "0") {
			$("#transferenciaCooperativa #transferCoinInt").addClass("orange-background");
			$("#transferenciaCooperativa #error-transfer-coin-0").text("Seleccione moneda");
		}

		if (amount === "") {
			$("div#transferenciaCooperativa #transfer-ammount-0").addClass("orange-background");
			$("div#transferenciaCooperativa #error-transfer-ammount-0").text("Introduzca monto");
		}

		if (concept === "") {
			$("div#transferenciaCooperativa #transfer-concept-0").addClass("orange-background");
			$("div#transferenciaCooperativa #error-transfer-concept-0").text("Introduzca concepto");
		}

		if (reason === "" || reason === "0") {
			$("div#transferenciaCooperativa #choose-reason-0").addClass("orange-background");
			$("div#transferenciaCooperativa #error-choose-reason-0").text("Seleccione motivo");
		}

		if (codPais === "" || codPais === "0") {
			$("div#transferenciaCooperativa div#intDestinyCoop #choose-country").addClass("orange-background");
			$("div#intDestinyCoop #error-choose-country").text("Seleccione país");
		}

		if (codCiudad === "" || codCiudad === "0" || codCiudad === undefined) {
			$("div#transferenciaCooperativa div#intDestinyCoop #divChooseCity").addClass("orange-background");
			$("div#transferenciaCooperativa div#intDestinyCoop #error-choose-city").text("Seleccione ciudad");
		}
	} else {
		var beneficiaryAccount = tranfData.cuentaDestino
		var currency = tranfData.moneda;
		var amount = tranfData.monto;
		var beneficiaryTypeDocument = tranfData.tipoDocumento;
		var chooseCountry = tranfData.codPais;
		var chooseCity = tranfData.codCiudad;
		var beneficiaryDocument = tranfData.nroDocumento;
		var beneficiaryName = tranfData.denominacion;
		var concept = tranfData.concepto;
		var reason = tranfData.codMotivo;
		var cuentaDestino = tranfData.cuentaDestino;

		if (beneficiaryTypeDocument === "" || beneficiaryTypeDocument === "0") {
			$("#transferenciaCooperativa #choose-type-document-0").addClass("orange-background");
			$("#transferenciaCooperativa #error-choose-type-document-0").text("Seleccione tipo de documento");
		}
		if (currency === "" || currency === "0") {
			$("#transferenciaCooperativa #transferCoinInt").addClass("orange-background");
			$("#transferenciaCooperativa #error-transfer-coin-0").text("Seleccione moneda");
		}

		if (amount === "") {
			$("div#transferenciaCooperativa #transfer-ammount-0").addClass("orange-background");
			$("div#transferenciaCooperativa #error-transfer-ammount-0").text("Introduzca monto");
		}

		if (chooseCountry === "" || chooseCountry === "0") {
			$("div#transferenciaCooperativa div#intDestinyCoop #choose-country").addClass("orange-background");
			$("div#intDestinyCoop #error-choose-country").text("Seleccione país");
		}

		if (chooseCity === "" || chooseCity === "0" || chooseCity === undefined) {
			$("div#transferenciaCooperativa div#intDestinyCoop #divChooseCity").addClass("orange-background");
			$("div#transferenciaCooperativa div#intDestinyCoop #error-choose-city").text("Seleccione ciudad");
		}

		if (beneficiaryName === "") {
			$("#transferenciaCooperativa #nameLastname-0").addClass("orange-background");
			$("#transferenciaCooperativa #error-nameLastname-0").text("Introduzca nombre y apellido");
		}
		if (concept === "") {
			$("div#transferenciaCooperativa #transfer-concept-0").addClass("orange-background");
			$("div#transferenciaCooperativa #error-transfer-concept-0").text("Introduzca concepto");
		}
		if (reason === "" || reason === "0") {
			$("div#transferenciaCooperativa #choose-reason-0").addClass("orange-background");
			$("div#transferenciaCooperativa #error-choose-reason-0").text("Seleccione motivo");
		}

		if (beneficiaryDocument === "") {
			$("div#transferenciaCooperativa #transfer-document1-0").addClass("orange-background");
			$("div#transferenciaCooperativa #error-transfer-document1-0").text("Introduzca documento");
		}

		if (cuentaDestino === "") {
			$("#transferenciaCooperativaAccount span.select2").addClass("orange-background");
			$("div#transferenciaCooperativaAccount #error-bank-destiny-0").text("Introduzca la cuenta destino");
		}
	}

	// Ajustar la altura del contenedor derecho para que coincida con el izquierdo
	var height1 = $("div.step-2-left").height();
	$("div.step-2-right").height(height1);
}

