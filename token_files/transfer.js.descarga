var BENEFICIARY_NAME_INTER = "";
var BENEFICIARY_NUMBER_INTER = "";
var BENEFICIARY_TYPE_DOCUMENT_INTER = "";
var BENEFICIARY_DOCUMENT_INTER = "";
var BENEFICIARY_COUNTRY_INTER = "";
var BENEFICIARY_CITY_INTER = "";
var BENEFICIARY_DIRECTION_INTER = "";
var BENEFICIARY_EMAIL = "";
var TEXT_STEP_2 = "";
var TEXT_STEP_3 = "";
var NRO_ACCOUNT_DELETE = ""

function goBackToStepthreeTransfer(){
	$("#step-1").addClass("hidden");
	$("#step-2").addClass("hidden");
    $("#step-3").removeClass("hidden");
    $("#step-4").addClass("hidden");
    loadBeneficiaryDataTransfer();
    
}

//Funciones que cargan el objeto de transferencia internacional
function loadTransferInternationalBank(origin, destinyAccount, amount, coinType, exchange, time, paymentMode, accountPaymentMode, reason,
										concept, entityName, entityCountry, entityCity, swift, aba, intermediaryBank, 
										intermediaryCountry, intermediaryCity, intermediarySwift, intermediaryAba, payOrder, coinPayOrder, amountPayOrder){
	this.originAccount = origin;
    this.destinyAccount = destinyAccount;
    this.amount = amount.replace(/\./g, '').replace(/,/g, '.');;
    this.coin = coinType;
    this.exchangeContract = exchange;
    this.time = time;
    this.paymentMode = paymentMode;
    this.accountPaymentMode = accountPaymentMode;
    this.reason = reason;
    this.concept = concept;
    this.payOrder = payOrder;
    this.coinPayOrder = coinPayOrder;
    this.amountPayOrder = amountPayOrder != "" ? amountPayOrder.replace(/\./g, '').replace(/,/g, '.') : 0;
    this.requirePayOrder = $("#transferenciaInternacional #choose-reason-0 option:selected").attr("require-pay-order") == "S";
    this.internationalBank = new loadBankData(entityName, entityCountry, entityCity, swift, aba);
    this.internationalIntermediaryBank = new loadIntermediaryData(intermediaryBank, intermediaryCountry, intermediaryCity, intermediarySwift, intermediaryAba);
 }
function loadBankData(entityName, entityCountry, entityCity, swift, aba){
	this.name = entityName;
	this.country = entityCountry;
	this.city = entityCity;
	this.swift = swift;
	this.aba = aba;
}
function loadIntermediaryData(entityName, entityCountry, entityCity, swift, aba){
	this.name = entityName;
	this.country = entityCountry;
	this.city = entityCity;
	this.swift = swift;
	this.aba = aba;
}
function loadBeneficiaryData(beneficiaryName, beneficiaryNumber, beneficiaryDirection, beneficiaryTypeDocument, beneficiaryDocument, beneficiaryCountry, beneficiaryCity, beneficiaryEmail){
	this.denomination = beneficiaryName;
	this.number = beneficiaryNumber;
	this.document = beneficiaryDocument;
	this.documentType = beneficiaryTypeDocument;
	this.country = beneficiaryCountry;
	this.city = beneficiaryCity;
	this.direction = beneficiaryDirection;
	this.emailComprobanteSwift = beneficiaryEmail;
}

//Funcion para pasar del paso 2 al 3 en transferencias Internacionales
function transferInternationalRegisterBank(BankData){
	$(".loader").removeClass("hidden");
	$("#buttonSelectAccountDestiny").attr("disabled","disabled");
	$.ajax({
		type: "POST",
		url: appname + "/transfer/interregisterbank",
		data: { bank: BankData,

		}	
	}).done(function (data) {
		$(".loader").addClass("hidden");
		$("#step-2").addClass("hidden");
		$("#buttonSelectAccountDestiny").removeAttr("disabled");
		$("#step-3").html(data);
		$("#step-3").removeClass("hidden");
		loadCountries("beneficiary");
		$("#numberCuentaConfirm").text(productText)
		$("#numberCuentaConfirmDestination").text(TEXT_STEP_2);
		loadBeneficiaryDataTransfer();
		
		var height1 = $("div.step-41-left").height();
		height1 = height1;
		$("div.step-41-right").height(height1);
		
		var height1 = $("div.step-42-left").height();
		height1 = height1;
		$("div.step-42-right").height(height1);
		$("div.step-42-right i").css("height","100%");
		
		var height1 = $("div.step-43-left").height();
		height1 = height1;
		$("div.step-43-right").height(height1+10);
		$('#genericError').hide();
	}).fail(function (request, status, error) {
		$(".loader").addClass("hidden");
		$("#buttonSelectAccountDestiny").removeAttr("disabled");
		var errorData = request.responseJSON;
		ajaxErrorHandler(errorData, status, error, ID_GENERIC_ERROR);
	})
}
//Funcion que valida si todos los campos estan cargados
function validateInternationalInputs(origin,coin, amount, destinyAccount, reason, time, paymentMode, accountPaymentMode, concept, entityName, entityCountry,
			entityCity, swift, aba, intermediaryBank, intermediaryCountry, intermediaryCity, intermediarySwift, intermediaryAba, payOrder, coinPayOrder, amountPayOrder){
	var intermediaryCountryValidate = $("div#intIntermediary #choose-country").val();
	var intermediarySwiftValidate = $("#intermediarySwift").val();
	var intermediaryAbaValidate = $("#intermediaryAba").val();
	var allOK = "true";
	var requiereOrdenDePago =  $("#transferenciaInternacional #choose-reason-0 option:selected").attr("require-pay-order") == "S";
	
	if(origin === "" || coin === "0" || amount === "" || destinyAccount === "" || destinyAccount.length > 40 || reason === "0" || time === "Null" ||  paymentMode === "0" || accountPaymentMode === "" || concept === "" ||
	  (requiereOrdenDePago && (payOrder === "" || coinPayOrder === "" || amountPayOrder === "")) || entityName === "" || entityCountry === "0" || entityCity === "0" || (aba === "" && swift ==="")){
		allOK="false";
	}
	if(intermediaryBank !== null && (intermediaryCountry === "0" || intermediaryCity === "0" || (intermediarySwiftValidate === "" && intermediaryAbaValidate === ""))){
		allOK="false";
	}else if(intermediaryBank === null && (intermediaryCountryValidate !== "0" || intermediarySwiftValidate !== "" || intermediaryAbaValidate !== "")){
		allOK="false";
	}
	return allOK;
}

function setEmptyErrorMessagesInternational(){
	var inputBank = $("#inputBank").val();
	var inputDestiny = $("div#transferenciaInternacional #select-beneficiary-international").val();
	var chooseCountry = $("div#intDestiny #choose-country").val();
	var chooseCity = $("div#intDestiny #choose-city").val();
	var inputSwift = $("#inputSwift").val();
	var inputAba = $("#inputABA").val();
	var intermediaryEntity = $("#intermediaryEntity").val();
	var intermediaryCountry = $("div#intIntermediary #choose-country").val();
	var intermediaryCity = $("div#intIntermediary #choose-city").val();
	var intermediarySwift = $("#intermediarySwift").val();
	var intermediaryAba = $("#intermediaryAba").val();
	var paymentMode = $("#selectPaymentMode").val();
	var amount = $("div#transferenciaInternacional #transfer-ammount-0").val();
	var time = $("#selectTime").val();
	var reason = $("div#transferenciaInternacional #choose-reason-0").val();
	var currency = $("#transferenciaInternacional #transferCoinInt").val();
	var concept = $("div#transferenciaInternacional #transfer-concept-0").val();
	
	var beneficiaryName = $("#beneficiaryName").val();
	var typeDocumentBeneficiary = $("div#beneficiaryForm #choose-type-document-0").val();
	var beneficiaryDocument = $("#beneficiaryDocument").val();
    var beneficiaryCountry = $("div#beneficiaryForm div#intBeneficiary #choose-country").val();
    var beneficiaryCity = $("div#beneficiaryForm div#intBeneficiary #choose-city").val();
    var beneficiaryDirection = $("#beneficiaryDirection").val();
	var payOrder = $("#transferenciaInternacional #transferPayOrder").val();
	var coinPayOrder = $("#transferenciaInternacional #transferCoinPayOrder").val();
	var amountPayOrder = $("#transferenciaInternacional #transferAmountPayOrder").val();
	
	if(currency === "0"){
		$("#transferenciaInternacional #error-transfer-coin-0").text("Seleccione una Moneda");
		$("#transferenciaInternacional #transferCoinInt").addClass("orange-background");
	}
	if(inputBank === ""){
		$("#inputBank").addClass("orange-background");
	    $("#error-inputBank").text("Introduzca una Entidad Bancaria");
	}if(inputDestiny === ""){
		$("div#transferenciaInternacional #select-beneficiary-international").addClass("orange-background");
	    $("div#transferenciaInternacional #error-bank-destiny-0").text("Introduzca una Cuenta");
	}if(inputDestiny.length > 40){
		$("div#transferenciaInternacional #select-beneficiary-international").addClass("orange-background");
	    $("div#transferenciaInternacional #error-bank-destiny-0").text("La cuenta supera el tamaño permitido");
	
	}if(chooseCountry === "" || chooseCountry === "0"){
		$("div#transferenciaInternacional div#intDestiny #choose-country").addClass("orange-background")
		 $("div#intDestiny #error-choose-country").text("Seleccione un Pais");
	}if(chooseCity === "" || chooseCity === "0"){
		$("div#transferenciaInternacional div#intDestiny #choose-city").addClass("orange-background")
	    $("div#intDestiny #error-choose-city").text("Seleccione una Ciudad");
	}if((inputSwift === "" && inputAba === "")){
		$("#inputSwift").addClass("orange-background");
		$("#error-inputSwift").text("Introduzca Codigo Aba o Swift");			
		
		$("#inputABA").addClass("orange-background");
		$("#error-inputABA").text("Introduzca Codigo Aba o Swift");			
	}if(intermediaryEntity !== "" && (intermediaryCountry === "" || intermediaryCountry === "0")){
		$("#intermediaryCountry-div #choose-country").addClass("orange-background");
	    $("div#intIntermediary #error-choose-country").text("Seleccione un Pais");
	}if(intermediaryEntity !== "" && (intermediaryCity === "" || intermediaryCity === "0")){
		$("div#intIntermediary #choose-city").addClass("orange-background");
	    $("div#intIntermediary #error-choose-city").text("Seleccione una Ciudad");
	}if(intermediaryEntity !== "" && (intermediarySwift === "" && intermediaryAba ==="")){
		$("#intermediarySwift").addClass("orange-background");
	    $("#error-intermediarySwift").text("Introduzca Codigo Swift");
	    
	    $("#intermediaryAba").addClass("orange-background");
	    $("#error-intermediaryABA").text("Introduzca Codigo ABA");
	}if(intermediaryEntity === "" && (intermediaryCountry !== "0" || intermediarySwift !== "" || intermediaryAba !== "")){
		$("#intermediaryEntity").addClass("orange-background");
		$("#error-intermediaryEntity").text("Introduzca una Entidad Bancaria");
	}if(paymentMode === "" || paymentMode === "0"){
		$("#selectPaymentMode").addClass("orange-background");
	    $("#error-selectPaymentMode").text("Seleccione Modo de Pago");
	}if(paymentMode === "O" && $("#modalitySelectProduct").val() === "0"){
		$("#modalitySelectProduct").addClass("orange-background");
		$("#error-paymentModeAccount").text("Seleccione una Cuenta");
	}if(paymentMode === "B" && $("#paymentModeAccount").val() === ""){
		$("#paymentModeAccount").addClass("orange-background");
		$("#error-paymentModeAccount").text("Introduzca una Cuenta");
	}if(amount === ""){
		$("div#transferenciaInternacional #transfer-ammount-0").addClass("orange-background");
	    $("div#transferenciaInternacional #error-transfer-ammount-0").text("Introduzca un Monto");
	}if(time === "Null"){
		$("#selectTime").addClass("orange-background");
	    $("#error-selectTime").text("Seleccione el Tiempo");
	}if(reason === "0"){
		$("div#transferenciaInternacional #error-choose-reason-0").text("Seleccione un Motivo");
	    $("div#transferenciaInternacional #choose-reason-0").addClass("orange-background");
	}if(beneficiaryName === ""){
		$("#beneficiaryForm #error-beneficiaryName").text("Introduzca una Denominación");
		$("#beneficiaryForm #beneficiaryName").addClass("orange-background");
	}if(beneficiaryCountry === "0"){
		$("#beneficiaryForm #choose-country").addClass("orange-background");
		$("#beneficiaryForm #error-choose-country").text("Seleccione un Pais");
	}if(beneficiaryCity === "0"){
		$("#beneficiaryForm #choose-city").addClass("orange-background");
	    $("#beneficiaryForm #error-choose-city").text("Seleccione una Ciudad");
	}if(beneficiaryDirection === ""){
		//$("#beneficiaryForm #error-beneficiaryName").text("Introduzca una Denominación");
		$("#beneficiaryForm #beneficiaryDirection").addClass("orange-background");
	}if(payOrder === ""){//"}if(payOrder || payOrder === ""){" NHB-45 MVAM
		$("div#transferenciaInternacional #error-transferPayOrder").text("Introduzca una Orden de Pago");
	    $("div#transferenciaInternacional #transferPayOrder").addClass("orange-background");
	}if(concept === ""){
		$("div#transferenciaInternacional #error-transfer-concept-0").text("Introduzca un Concepto");
		$("div#transferenciaInternacional #transfer-concept-0").addClass("orange-background");
	}
    
    var height1 = $("div.step-2-left").height();
	$("div.step-2-right").height(height1);
}

//Funcion para pasar del paso 3 al 4 en transferencias Internacionales
function transferInternationalRegisterBeneficiary(BeneficiaryData){
	$(".loader").removeClass("hidden");
	$("#buttonBeneficiaryDataNext").attr("disabled","disabled");
	$.ajax({
		type: "POST",
		url: appname + "/transfer/registerinternational",
		data: { beneficiary: BeneficiaryData,

		}	
	}).done(function (data) {
		$(".loader").addClass("hidden");
		$("#step-3").addClass("hidden");
		$("#buttonBeneficiaryDataNext").removeAttr("disabled");
		$("#step-4").html(data);
		$("#step-4").removeClass("hidden");
		
		$("div.step-last1-left #numberCuentaConfirm").text(productText);
		var quotization = $("#quotizationInternational").val();
		var comDesc = $("#comDesc").val();
		var payerDesc = $("#payerDesc").val();
		if(quotization != 1 && quotization != 0){
			TEXT_STEP_2 += " / "+ "Cotización: GS. "+quotization;
		}
		TEXT_STEP_2 += " / "+"Comisión: "+comDesc +" / Pago Comisión: "+payerDesc;
		
		
		$("div.step-last2-left #numberCuentaConfirmDestination").text(TEXT_STEP_2);
		$("#BeneficiaryData").text(TEXT_STEP_3);
		
		var height1 = $("div.step-last1-left").height();
		height1 = height1;
		$("div.step-last1-right").height(height1);
		
		var height1 = $("div.step-last2-left").height();
		height1 = height1;
		$("div.step-last2-right").height(height1);
		$("div.step-last2-right i").css("height","100%");
		
		var height1 = $("div.step-last3-left").height();
		height1 = height1;
		$("div.step-last3-right").height(height1);
		
		var height1 = $("div.step-last-left").height();
		height1 = height1;
		$("div.step-last-right").height(height1);
		
		var height1 = $("div .step-3-left").height();
		$("div .step-3-right").height(height1);
	
	}).fail(function (request, status, error) {
		$(".loader").addClass("hidden");
		$("#buttonBeneficiaryDataNext").removeAttr("disabled");
		var errorData = request.responseJSON;
		ajaxErrorHandler(errorData, status, error, ID_GENERIC_ERROR);
	})
}

function confirmTransferInternational(){
