}
//funcion para enviar el archivo y guardarlo en la bd
function sendFormFilesProviders(data) {
	PROVIDER_ORIGIN_BENEFICIARIES = new Map();
	PROVIDER_MODIFY_BENEFICIARIES = new Map();
	PROVIDER_ORIGIN_LOAD = false;
	$("#buttonProviderLoading").removeClass("hidden");
	$("#buttonSelectAccountDestiny").addClass("hidden");
	$("#buttonProviderLoading").button().button('disable');
	var height = $("#step-2 .step-2-left").height();
	$("#step-2 .step-2-right").height(height);
	$(".loader").removeClass("hidden");
	$.ajax({
        type: 'POST',
        enctype: 'multipart/form-data',
        url: appname + '/payprovider/uploadfiles',
        data: data,
        processData: false,
        contentType: false,
        cache: false,
    }).done(function(data){
    	$(".loader").addClass("hidden");
    	if(data === "OK"){
			$(".loader").removeClass("hidden");
    		setTimeout(function() {
    			processFile();
			}, 3000);
    	}
    	

    }).fail(function(request, status, error){
    	$(".loader").addClass("hidden");
        var errorData = request.responseJSON;
        $("#container-main").css('margin-top', '0px');
        ajaxErrorHandler(errorData, status, error, "genericError");
        $("#buttonProviderLoading").addClass("hidden");
    	$("#buttonSelectAccountDestiny").removeClass("hidden");
    	var height = $("#step-2 .step-2-left").height();
    	$("#step-2 .step-2-right").height(height);
        clearInterval(PROVIDER_INTERVAL);
    })
}
//funcion para solicitar el procesamiento del archivo
function processFile(){
	$(".loader").removeClass("hidden");
	$.ajax({
        type: 'POST',
		dataType: 'json',
        url: appname + '/payprovider/process/file'   
    }).done(function(data){
    	$(".loader").addClass("hidden");
    	if(data.response === "OK"){
    		PROVIDER_INTERVAL = setInterval(function() {
				$(".loader").removeClass("hidden");
    			checkProcessProvider();
			}, 3000);
    	}
    }).fail(function(request, status, error){
    	$(".loader").addClass("hidden");
        var errorData = request.responseJSON;
        $("#container-main").css('margin-top', '0px');
        ajaxErrorHandler(errorData, status, error, "genericError");
        $("#buttonProviderLoading").addClass("hidden");
    	$("#buttonSelectAccountDestiny").removeClass("hidden");
        clearInterval(PROVIDER_INTERVAL);
    })
}

//funcion que controla el progreso de procesamiento del archivo
function  checkProcessProvider(){
	$(".loader").removeClass("hidden");
	$.ajax({
        type: "GET",
		dataType: 'json',
        url: appname +"/payprovider/process/check"
	 }).done(function (data) { 
		 $(".loader").addClass("hidden");
        if(data.hasError){
            if(data.errorBody.useApiMessage)
                showModalAdminError(data.errorBody.message);
            else
                showModalAdminError("Error Procesando Archivo");

            redirectLoginExpired(data.errorBody.code);
        }
        else {
            if (data.response.estado === 'COMPLETO') { //si ya proceso todo se llama a la funcion para obtener la lista en base al archivo
                clearInterval(PROVIDER_INTERVAL);
                fileToListProvider();
			}else if (data.response.estado === 'PROCESANDO') {
				showPartialListProviders(data.response.objetoProcesado);
            }else if (data.response.estado === 'ERROR') { //si ya proceso todo se llama a la funcion para obtener la lista en base al archivo
				clearInterval(PROVIDER_INTERVAL);
				let messageError = "Error Procesando Archivo";
				if(data.response.mensajes[0] !== null && data.response.mensajes[0] !== undefined && data.response.mensajes[0] !== "")
					messageError = data.response.mensajes[0];
				showModalAdminError(messageError);
			}
        }
	 }).fail(function (request, status, error) {
		 $(".loader").addClass("hidden");
	        var errorData = request.responseJSON;
	        ajaxErrorHandler(errorData, status, error, ID_GENERIC_ERROR);
			clearInterval(PROVIDER_INTERVAL);
	        $("#buttonSalaryPaymentStep-3Loading").addClass("hidden");
	    	$("#buttonSalaryPaymentStep-3").removeClass("hidden");
	 });
}

function showPartialListProviders(providers){
	if(providers != null && providers !== undefined){
		$("#salary-fileToList .edit-button").prop("disabled",true);
		$("#salary-fileToList .delete-button").prop("disabled",true);
		$("#buttonNextPayments").attr("disabled","disabled");
		$("#modalProvider .modalAddProvider").modal('hide');//cuando quiere agregar o editar proveedores
		$("#modalProvider .modalEditProvider").modal('hide');//cuando quiere agregar o editar proveedores
		$(".loader").removeClass("hidden");
		$.ajax({
			type: 'POST',
			url: appname + '/payprovider/partial-providers',
			data : {
				listProviders : JSON.stringify(providers)
			}

		}).done(function(data){
			$("#step-1").addClass("hidden");
			$("#step-2").addClass("hidden");
			$("#step-3").removeClass("hidden");
			$(".modal-backdrop").removeClass('in');
			$(".fade").removeClass('modal-backdrop');
			$("body").removeClass("modal-open");
			$("#step-3").html(data);
			$("#buttonNextPayments").attr("disabled","disabled");
			$("#totalDestiny").text($("#provider-table tbody tr").length);
			var totalAmount = 0;
			var length = $("#provider-table tbody tr").length;
			for(var i=0;i<length;i++){
				totalAmount += parseFloat($("#provider-table tbody tr:eq("+i+") td:eq(6)").text().replace(/\./g, '').replace(/,/g, '.').trim());
			}
			var result = "";
			var currency = "";
			if(CURRENCY_PROVIDER_ORIGIN === "GS"){
				result = formatStringAmount(totalAmount,'false');
				currency = "Gs. ";
			}else{
				result = formatStringAmount(totalAmount.toString().replace(".",","),'true');
				currency = "USD. ";
			}
			result = currency + result;
			$("#totalTransfer").text(result);

			$("#accountNumberDescriptionStep3").text(ACCOUNT_PROVIDER_DESCRIPTION);

			$("#step-3 .step-1-right").height($("#step-3 .step-1-left").height());
			var height1 = $(".step3-2-left").height()+20;
			$(".step3-2-right").height(height1);
			$(".step3-2-left").height(height1);
			var height2 = $(".step-3-left").height();
			$(".step-3-right").height(height2);
			$("#buttonReadyAddPayment span").text("Listo");
			$("#buttonReadyEditPayment span").text("Listo");
			$("#salary-fileToList .edit-button").prop("disabled",true);
			$("#salary-fileToList .delete-button").prop("disabled",true);

		}).fail(function(request, status, error){
			$(".loader").addClass("hidden");
			var errorData = request.responseJSON;
			$("#container-main").css('margin-top', '0px');
			ajaxErrorHandler(errorData, status, error, "genericError");
			$("#buttonProviderLoading").addClass("hidden");
			$("#buttonSelectAccountDestiny").removeClass("hidden");
		})
	}else{
		$(".loader").addClass("hidden");
		clearInterval(PROVIDER_INTERVAL);
		showModalAdminError("Error Procesando Archivo");
	}



}

//funcion para calcular el total de proveedores y el total a pagar
function getTotalAmountProviderInvoice(){
	var length = $(".invoice-ammount input").length;
	var totalAmount = 0;
	for(var i=0;i<length;i++){
		var ubi = $(".invoice-ammount input")[i].value;
		ubi = ubi.replace(/\./g, '').replace(/,/g, '.');
		if(isNaN(parseInt(ubi)) === false){ // va a dar true si es vacio el input
			totalAmount = totalAmount + parseFloat(ubi);
		}
	}
	
	var result = "";
    var currency = "";
    if(CURRENCY_PROVIDER_ORIGIN === "GS"){
    	result = formatStringAmount(totalAmount,'false');
    	currency = "Gs. ";
    }else{
    	result = formatStringAmount(totalAmount.toString().replace(".",","),'true');
    	currency = "USD. ";
    }
    result = currency + result;
    $("#totalInvoicesAmmount").text(result);
}

