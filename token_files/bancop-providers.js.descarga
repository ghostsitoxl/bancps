//Funcion que permite mantener en un input oculto el archivo obligatorio de pago de proveedores
function loadFilePayProvider(){
	$(".div-content-file-pay-provider").before(
			function() {
				if ( ! $(this).prev().hasClass('input-ghost') ) {
					var element = $("<input type='file' id='payProviderFile' class='input-ghost' accept='.csv, .xls, .txt' style='visibility:hidden; height:0'>");
					element.attr("name","payProviderFile");
					element.change(function(){
						
						$(".input-file-provider").val(element.val().split('\\').pop());
					});
					element.click();
					return element;
				}else{
					$("#payProviderFile").remove();
					var element = $("<input type='file' id='payProviderFile' class='input-ghost' accept='.csv, .xls, .txt' style='visibility:hidden; height:0'>");
					element.attr("name","payProviderFile");
					element.change(function(){
						
						$(".input-file-provider").val(element.val().split('\\').pop());
					});
					element.click();
					return element;
				}
			}
		);
}
