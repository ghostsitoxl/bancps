//funcion que permite descargar el reporte de pago de salarios en formato pdf
function downloadProviderPdf(numberOperation){
	var params = 'numberOperation=' + numberOperation;
    var req = new XMLHttpRequest();
    req.open("POST", appname + "/payprovider/pdfprovider", true);
    req.responseType = "blob";
    req.setRequestHeader("Content-type", "application/x-www-form-urlencoded");
    req.onload = function () {
    	if(req.status === 200){
    		var blob = req.response;
            var fileName = 'pago-proveedor' + '-' + numberOperation + '.pdf';
            downloadAllReport(blob, fileName);
    	}else{
    		showModalGenericError("Error al generar el Comprobante");
    	}
    };
    req.send(params);
}

function downloadBeneficiariesZIP(externalID){
	externalID = parseInt(externalID);
	$(".loader").removeClass("hidden");
	var params = 'externalID=' + externalID;
	var req = new XMLHttpRequest();
	req.open("POST", appname + "/payprovider/beneficiaries/zip", true);
	req.responseType = "blob";
	req.setRequestHeader("Content-type", "application/x-www-form-urlencoded");
	req.onload = function () {
		if(req.status === 200){
			var blob = req.response;
			var fileName = 'beneficiario-proveedores' + '-' + externalID + '.zip';
			downloadAllReport(blob, fileName);
		}else{
			showModalGenericError("Error al generar el ZIP");
		}
		$("#modalPayProviderDetails").modal('hide');
		$(".loader").addClass("hidden");
	};
	req.send(params);
}

function showProviderBeneficiariesError(obj){

	if(obj.hasClass("btn-danger")){
		$('#salary-fileToList tr').each(function(){$(this).addClass("hidden")});
		$("#listFile table tbody").find(".div-error-background-orange").each(function(){
			$(this).removeClass("hidden");
		});
		obj.removeClass("btn-danger").addClass("btn-primary");
		obj.text("Mostrar Todo");
		$("#btn-hasErrorsFile").removeClass("hidden");
	}else{
		$('#salary-fileToList tr').each(function(){$(this).removeClass("hidden")});
		obj.addClass("btn-danger").removeClass("btn-primary");
		obj.text("Mostrar solo Errores");
        $("#btn-hasErrorsFile").addClass("hidden");
	}

	$("#step-3 .step-1-right").height($("#step-3 .step-1-left").height());
	var height2 = $(".step-3-left").height();
	$(".step-3-right").height(height2);

}

function originBeneficiaryProviderData(){
	if (!PROVIDER_ORIGIN_LOAD) {
		PROVIDER_ORIGIN_BENEFICIARIES = new Map();
		PROVIDER_MODIFY_BENEFICIARIES = new Map();
		var length = $("#salary-fileToList tr").length - 1;
		for (i = 0; i <= length; i++) {
			var tdNumberAccount = $("#salary-fileToList tr:eq(" + i + ") td:eq(3)");
			var beneficiaryText = $("#salary-fileToList tr:eq(" + i + ") td:eq(1)").text();
			var tdAmount = $("#salary-fileToList tr:eq(" + i + ") td:eq(6)");
			var documentNumber = tdNumberAccount.attr("documentNumber");
			var accountNumberBeneficiary = "";
			var orderPay = $("#salary-fileToList tr:eq(" + i + ")").attr("orderpay");
			var mountBeneficiary = tdAmount.text().replace(/\./g, '').replace(/,/g, '.');
			if (tdNumberAccount.find("input").val() === undefined) {
				accountNumberBeneficiary = tdNumberAccount.text().trim();
			} else {
				accountNumberBeneficiary = tdNumberAccount.find("input").val();
			}

			var beneficiaryOrigin = new BeneficiaryProviderModified(beneficiaryText,accountNumberBeneficiary, mountBeneficiary,documentNumber,orderPay);
			let idMap = "tr-file-pos-" + i;
			PROVIDER_ORIGIN_BENEFICIARIES.set(orderPay, beneficiaryOrigin);
			PROVIDER_ORIGIN_LOAD = true;


		}
	}

}

function BeneficiaryProviderModified(beneficiario,nroCuenta,monto,nroDocumento,ordenPago){
	this.beneficiario = beneficiario;
	this.nroCuenta = nroCuenta;
	this.monto = monto;
	this.nroDocumento = nroDocumento;
	this.ordenPago = ordenPago;
}

function modifiedProviderBeneficiary(pos,account,amount,documentNumber,orderPayValue,denomination){
	let idMap = orderPayValue;
	let beneficiaryOrigin = "";
	account = escapeXml(account);
	documentNumber = escapeXml(documentNumber);
	denomination = escapeXml(denomination);
	if(PROVIDER_MODIFY_BENEFICIARIES.get(idMap) === undefined){
		beneficiaryOrigin = PROVIDER_ORIGIN_BENEFICIARIES.get(idMap);
		if(beneficiaryOrigin.nroCuenta === account)
			account = "";
		if(beneficiaryOrigin.monto === amount)
			amount = "";
		if(beneficiaryOrigin.nroDocumento === documentNumber)
			documentNumber = "";
		if(beneficiaryOrigin.beneficiario === denomination)
			denomination = "";
	}else{
		let beneficiaryModified = PROVIDER_MODIFY_BENEFICIARIES.get(idMap);
		if(beneficiaryModified.nroCuenta === account || beneficiaryModified.nroCuenta === "")
			account = beneficiaryModified.nroCuenta;
		if(beneficiaryModified.monto === amount || beneficiaryModified.monto === "")
			amount = beneficiaryModified.monto;
		if(beneficiaryModified.nroDocumento === documentNumber || beneficiaryModified.nroDocumento === "")
			documentNumber = beneficiaryModified.nroDocumento;
		if(beneficiaryModified.beneficiario === denomination || beneficiaryModified.beneficiario === "")
			denomination = beneficiaryModified.beneficiario;
	}
	if(account !== "" || amount !== "" || documentNumber !== "" || denomination !== ""){
		beneficiaryOrigin = new BeneficiaryProviderModified(denomination,account, amount,documentNumber,orderPayValue);
		PROVIDER_MODIFY_BENEFICIARIES.set(idMap,beneficiaryOrigin);
	}

}

function downloadFileProviderError(){
	var req = new XMLHttpRequest();
