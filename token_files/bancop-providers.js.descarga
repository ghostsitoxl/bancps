	$("#step-1 .step-1-right").height($("#step-1 .step-1-left").height());
	$("#step-2").addClass("hidden");
	$("#step-3").addClass("hidden");
	$("#step-4").addClass("hidden");
}

function goBackToStepTwoProvider() {
	PROVIDER_ORIGIN_BENEFICIARIES = new Map();
	PROVIDER_MODIFY_BENEFICIARIES = new Map();
	$("#step-1").addClass("hidden");
	$("#step-2").removeClass("hidden");
	$("#buttonSelectAccountDestiny").removeClass("hidden");
	$("#buttonProviderLoading").addClass("hidden");
	var height = $("#step-2 .step-2-left").height();
	$("#step-2 .step-2-right").height(height);
	$("#step-3").addClass("hidden");
	$("#step-4").addClass("hidden");
}

function goBackToStepThreeProvider() {
	$("#step-1").addClass("hidden");
	$("#step-2").addClass("hidden");
	$("#step-3").removeClass("hidden");
	$("#step-4").addClass("hidden");
}


/*Metodos para la funcionalidad de pago de proveedores*/
//funcion para agregar una factura
function showMoreInvoice() {
    /*Clonar invoice-item y agragar al contenedor*/
	
	
	if($("#invoice-list").hasClass("hidden")){
		$("#invoice-list").removeClass("hidden");
	}else{
		var $invoice = $(".invoice-item").first().clone(false);
		if(!$invoice.hasClass("row"))
			$invoice.addClass("row");
		$("#invoice-list").append($invoice);
		var type = $("#chooseDestiny #select-destiny").val();
		var length =  $(".invoice-item").length;
		var content = $(".invoice-item")[length-1];
		var tam = content.children.length;
		for(var i=0;i<tam-1;i++){
			content.children[i].children[1].setAttribute("value","");
			if(i === 2){//posicion del datepicker
				content.children[i].children[1].setAttribute("value","");
				content.children[i].children[1].setAttribute("id","datepicker-"+length);//debemos setear un nuevo id o no asigna la propiedad del datepicker
				var aux = content.children[i].children[1].getAttribute("id");
				$("#"+aux).removeClass('hasDatepicker');
				$("#"+aux).datepicker('destroy').removeClass('hasDatepicker');
				$("#"+aux).datepicker({
					dateFormat: 'dd/mm/yy'
				});
			}
		}
		
		
		$.datepicker.setDefaults($.datepicker.regional["es"]);
    	$(".datePickerInvoice").datepicker({
    		dateFormat: 'dd/mm/yy'
    	});
		$(".invoice-item:last input").val('');
		$(".invoice-item:last input").removeClass("div-error-background-orange");
		$(".invoice-item:last span.color-orange-error").remove();
	}
	$("#totalInvoices").text($(".invoice-item").length);
	
		
	
    
}
//funcion que solicita al controlador borrar un proveedor con sus facturas si es que tiene
function deleteProvider(orderPay){
	$.ajax({
        type: 'POST',
        url: appname + '/payprovider/delete/provider',
        data: {
            orderPay: parseInt(orderPay),
        }
    });
}
//funcion para borrar una factura
function deleteInvoice(obj) {
    var length = $(".invoice-item").length;
	obj.parentElement.parentElement.parentElement.remove();
	getTotalAmountProviderInvoice();
	$("#totalInvoices").text($(".invoice-item").length);
	
	
}


