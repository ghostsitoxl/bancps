	        	totalAmount += parseFloat($("#provider-table tbody tr:eq("+i+") td:eq(6)").text().replace(/\./g, '').replace(/,/g, '.').trim());
	        }
	        var result = "";
	        var currency = "";
	        if(CURRENCY_PROVIDER_ORIGIN === "GS"){
	        	result = formatStringAmount(totalAmount,'false');
	        	currency = "Gs. ";
	        }else{
	        	result = formatStringAmount(totalAmount.toString().replace(".",","),'true');
	        	currency = "USD. ";
	        }
	        result = currency + result;
	        $("#totalTransfer").text(result);
	        
	        $("#accountNumberDescriptionStep3").text(ACCOUNT_PROVIDER_DESCRIPTION);
	        
	        $("#step-3 .step-1-right").height($("#step-3 .step-1-left").height());
