function loadPayment(payment) {
	$(".loader").removeClass("hidden");
    $.ajax({
        type: "POST",
        url: appname + "/payprovider/paydetail",
        data: {
            numberPayment: payment,
        }
    }).done(function (data) {
    	$(".loader").addClass("hidden");
    	$("#modalProvider").removeClass("hidden");
    	$("#modalProvider").html(data);
    	$("#modalProvider #modalAddProvider").modal('toggle');
          
	}).fail(function (errorData,status,error) {
		$(".loader").addClass("hidden");
        ajaxErrorHandler(errorData, status, error, ID_GENERIC_ERROR);
    });
}

//funcion para editar datos del proveedor con sus facturas
function editDataProvider(){

	var orderPayValue = $("#orderPayValue").val();
	var movementType = $(".modalEditProvider #chooseDestiny #select-destiny").val();
	var account = $(".modalEditProvider #inputDestiny input").val();
	var documentNumber = $(".modalEditProvider #transferDocument input").val();
	var direction = $(".modalEditProvider #directionProvider input").val();
	var amount = $(".modalEditProvider #transferAmmount input").val().replace(/\./g, '').replace(/,/g, '.');
	var cellphone = $(".modalEditProvider #cellphoneNumber").val();
	var emailDirection = $(".modalEditProvider #emailDirection").val();
	var emailDirection2 = $(".modalEditProvider #emailDirection2").val();
	var emailDirection3 = $(".modalEditProvider #emailDirection3").val();
	var typeSipap = "";
	var codBank = "";
	var denomination = $(".modalEditProvider #nameLastname input").val();
	var codTypeDocument = "";
	var payDay = "";
	var cantInvoices = "";
	var idMap = "";
	var pos = "";
	var classLength = $("tr[orderpay='"+orderPayValue+"']")[0].classList.length;
	if(classLength == 1){
		pos = $("tr[orderpay='"+orderPayValue+"']").attr("class").trim().split("-")[3];
		idMap = $("tr[orderpay='"+orderPayValue+"']").attr("class").trim();
	}else{
		pos = $("tr[orderpay='"+orderPayValue+"']")[0].classList[1].split("-")[3];
		idMap = $("tr[orderpay='"+orderPayValue+"']")[0].classList[1].trim();
	}
	modifiedProviderBeneficiary(pos,account,amount,documentNumber,orderPayValue,denomination);
	if(movementType === "I"){//tipo SIPAP
		typeSipap = "LBTR";
		codBank = $(".modalEditProvider #transferEntity #banksProvider").val();
		codTypeDocument = $(".modalEditProvider #typeDocument #typeDocumentProvider").val();
		payDay = $(".modalEditProvider #transferDates input").val();
	}else{
		payDay = $(".modalEditProvider #transferDates input").val() != undefined ? $(".modalEditProvider #transferDates input").val() : "";
	}
	var length = 0;
	var listInvoices = [];
	if(!$("#invoice-list").hasClass("hidden")){
		length = $("#invoice-list .invoice-item").length;
		for(var i=0;i<length;i++){
			var invoiceCodEnte = $("#invoice-list .invoice-item:eq("+i+")").attr("invoiceCodEnte");
			var invoiceNumber = $("#invoice-list .invoice-item:eq("+i+") input")[0].value;
			var stamped = $("#invoice-list .invoice-item:eq("+i+") input")[1].value;
			var datePay = $("#invoice-list .invoice-item:eq("+i+") input")[2].value;
			var concept = $("#invoice-list .invoice-item:eq("+i+") input")[3].value;
			var amountInvoice = $("#invoice-list .invoice-item:eq("+i+") input")[4].value.replace(/\./g, '').replace(/,/g, '.');
			var invoice = new constructorInvoices("",invoiceNumber,stamped,datePay,concept,amountInvoice,invoiceCodEnte);
			listInvoices.push(invoice);
		}
	}
	cantInvoices = length;
	let beneficiaryModified = null;
	if(PROVIDER_ORIGIN_BENEFICIARIES.get(orderPayValue) !== undefined && PROVIDER_MODIFY_BENEFICIARIES.get(orderPayValue) !== undefined){
		beneficiaryModified = PROVIDER_ORIGIN_BENEFICIARIES.get(orderPayValue);

	}
	var providerJson = new  constructorProvider("",movementType,account,documentNumber,
							amount,typeSipap,codBank,denomination,codTypeDocument,
							payDay,cantInvoices,direction, cellphone, emailDirection,beneficiaryModified, emailDirection2, emailDirection3);
	
	$("#buttonReadyEditPayment span").text("Procesando...");
	$("#buttonReadyEditPayment").button().button('disable');
	$(".loader").removeClass("hidden");
	$.ajax({
		type : "POST",
		url : appname + "/payprovider/edit",
		data : {
			 orderPay: orderPayValue,
			 provider: JSON.stringify(providerJson),
			 listInvoices : JSON.stringify(listInvoices)
		}
	}).done(function(data) {
		$(".loader").addClass("hidden");
		if(data === "OK"){
    		PROVIDER_INTERVAL = setInterval(function() {
    			checkProcessProvider();
			}, 7000);
    	}
       
	}).fail(function(errorData, status, error) {
		$(".loader").addClass("hidden");
		clearInterval(PROVIDER_INTERVAL);
		ajaxErrorHandler(errorData, status, error, ID_GENERIC_ERROR);
	});
}


//constructor de una factura
function constructorInvoices(orderPay,invoiceNumber,stamped,datePay,concept,amount,codEnte){
	this.orderPay = orderPay;
	this.invoiceNumber = invoiceNumber;
	this.stamped = stamped;
	this.datePay = datePay;
	this.concept = concept;
	this.amount = amount;
	this.codEnte = codEnte;
	
}

//constructor de un proveedor
function constructorProvider(orderPay,movementType,account,documentNumber,amount,typeSipap,codBank,denomination,codTypeDocument,
		payDay,cantInvoices,direction, cellphone, emailDirection,additionalInfo, emailDirection2, emailDirection3){
	this.orderPay = orderPay;
	this.movementType = movementType;
	this.account = account;
	this.documentNumber = documentNumber;
	this.amount = amount;
	this.typeSipap = typeSipap;
	this.codBank = codBank;
	this.denomination = denomination;
	this.codTypeDocument = codTypeDocument;
	this.payDay = payDay;
	this.cantInvoices = cantInvoices;
	this.direction = direction;
	this.cellphone = cellphone;
	this.emailDirection = emailDirection;
	this.additionalInfo = additionalInfo;
	this.emailDirection2 = emailDirection2;
	this.emailDirection3 = emailDirection3
}

//funcion para agregar un nuevo proveedor
function addNewProvider(){
	var orderPayValue = 0;
	var movementType = $(".modalAddProvider #chooseDestiny #select-destiny").val();
	var account = $(".modalAddProvider #inputDestiny input").val();
	var documentNumber = $(".modalAddProvider #transferDocument input").val();
	var direction = $(".modalAddProvider #directionProvider input").val();
	var amount = $(".modalAddProvider #transferAmmount input").val().replace(/\./g, '').replace(/,/g, '.');
	var cellphone = $(".modalAddProvider #cellphoneNumber").val();
	var emailDirection = $(".modalAddProvider #emailDirection").val();
	var emailDirection2 = $(".modalAddProvider #emailDirection2").val();
	var emailDirection3 = $(".modalAddProvider #emailDirection3").val();
	var typeSipap = "";
	var codBank = "";
	var denomination = $(".modalAddProvider #nameLastname input").val();
	var codTypeDocument = "";
	var payDay = "";
	var cantInvoices = "";
	if(movementType === "I"){
		typeSipap = "LBTR";
		codBank = $(".modalAddProvider #transferEntity #banksProvider").val();
		codTypeDocument = $(".modalAddProvider #typeDocument #typeDocumentProvider").val();
		payDay = $(".modalAddProvider #transferDates input").val();
	}
	var length = 0;
	var listInvoices = [];
	if(!$("#invoice-list").hasClass("hidden")){
		length = $("#invoice-list .invoice-item").length;
		for(var i=0;i<length;i++){
			var invoiceCodEnte = $("#invoice-list .invoice-item:eq("+i+")").attr("invoiceCodEnte");
			var invoiceNumber = $("#invoice-list .invoice-item:eq("+i+") input")[0].value;
			var stamped = $("#invoice-list .invoice-item:eq("+i+") input")[1].value;
			var datePay = $("#invoice-list .invoice-item:eq("+i+") input")[2].value;
			var concept = $("#invoice-list .invoice-item:eq("+i+") input")[3].value;
			var amount = $("#invoice-list .invoice-item:eq("+i+") input")[4].value.replace(/\./g, '').replace(/,/g, '.');
			var invoice = new constructorInvoices("",invoiceNumber,stamped,datePay,concept,amount,invoiceCodEnte);//constructor para una factura
			listInvoices.push(invoice);//se carga la lista de facturas
		}
	}
	cantInvoices = length;
	
	var providerJson = new  constructorProvider("",movementType,account,documentNumber,
							amount,typeSipap,codBank,denomination,codTypeDocument,
							payDay,cantInvoices,direction, cellphone, emailDirection,null, emailDirection2, emailDirection3); //constructor para un proveedor
	$("#buttonReadyAddPayment").button().button('disable');
	$("#buttonReadyAddPayment span").text("Procesando...");
	$.ajax({
		type : "POST",
		url : appname + "/payprovider/edit",
		data : {
			 orderPay: orderPayValue,
			 provider: JSON.stringify(providerJson),
			 listInvoices : JSON.stringify(listInvoices)
		}
	}).done(function(data) {
		if(data === "OK"){
    		PROVIDER_INTERVAL = setInterval(function() {
    			checkProcessProvider();
			}, 7000);
    	}
       
	}).fail(function(errorData, status, error) {
		clearInterval(PROVIDER_INTERVAL);
		ajaxErrorHandler(errorData, status, error, ID_GENERIC_ERROR);
	});
}

//funcion utilizada para registrar un pago de proveedores
function registerPaymentProviders(){
	   DESCRIPTION_FILE = $("#descriptionFile").text();	
	   var errorLength = $("#salary-fileToList .div-error-background-orange").length;
	   //si existe un registro con error se muestra mensaje
	   if (errorLength > 0) {
			var msg = "";
			if (errorLength === 1) {
				msg = "Favor verificar su grupo de proveedores a enviar. Encontramos "
						+ errorLength + " proveedor con error";
			} else {
				msg = "Favor verificar su grupo de proveedores a enviar. Encontramos "
						+ errorLength + " proveedores con error";
			}
			showModalGenericError(msg);
	   }else{
		   $(".loader").removeClass("hidden");
		   let mapFilter = new Map();
		   if(PROVIDER_MODIFY_BENEFICIARIES.size > 0){
		   		const iterator = PROVIDER_MODIFY_BENEFICIARIES.keys();
		   		for(let i=0; i<PROVIDER_MODIFY_BENEFICIARIES.size;i++){
		   			let keyMap = iterator.next().value;
					let beneficiaryOrigin =PROVIDER_ORIGIN_BENEFICIARIES.get(keyMap);
                    let beneficiaryModified =beneficiaryOrigin ;
                        /*let beneficiaryModified =  PROVIDER_MODIFY_BENEFICIARIES.get(keyMap);
                        if(beneficiaryModified.nroCuenta !== "")
                            beneficiaryModified.nroCuenta = beneficiaryOrigin.nroCuenta;
                        if(beneficiaryModified.monto !== "")
                            beneficiaryModified.monto = beneficiaryOrigin.monto;
                        if(beneficiaryModified.nroDocumento !== "")
                            beneficiaryModified.nroDocumento = beneficiaryOrigin.nroDocumento;
                        if(beneficiaryModified.beneficiario !== "")
                            beneficiaryModified.beneficiario = beneficiaryOrigin.beneficiario;*/
					mapFilter.set(keyMap,beneficiaryModified);
				}
		   }
		   $("#buttonNextPayments").attr("disabled","disabled");
		   $.ajax({
		        type: "POST",
			   dataType: 'json',
		        url: appname + "/payprovider/registerpay",
			   data:{
				   providerModified:JSON.stringify(Object.fromEntries(mapFilter))
			   }
		        
		    }).done(function (data) {
			   $(".loader").removeClass("hidden");
               if(data.hasError){
				   data.errorBody = JSON.parse(data.errorBody);
                   if(data.errorBody.useApiMessage)
                       showModalAdminError(data.errorBody.message);
                   else
                       showModalAdminError("Error registrando la operación.");

                   redirectLoginExpired(data.errorBody.code);
               }
               else {
               		/*hacer llamada para chequear el estado*/
                   PROVIDER_INTERVAL = setInterval(function() {
                       checkProcessRegisterProvider();
                   }, 3000);
               	}
		        
		    }).fail(function (errorData,status,error) {
		    	$(".loader").addClass("hidden");
			   	$("#buttonNextPayments").removeAttr("disabled");
		        ajaxErrorHandler(errorData, status, error, ID_GENERIC_ERROR);
		    });  
	   }
}

//funcion que controla el progreso del registro de la transaccion
function  checkProcessRegisterProvider(){
    $(".loader").removeClass("hidden");
    $.ajax({
        type: "GET",
		dataType: 'json',
        url: appname + "/payprovider/register/check"

    }).done(function (data) {
		$(".loader").addClass("hidden");
        if(data.hasError){
            if(data.errorBody.useApiMessage)
                showModalAdminError(data.errorBody.message);
            else
                showModalAdminError("Error en el proceso de pago.");

            redirectLoginExpired(data.errorBody.code);
            $(".loader").addClass("hidden");
			clearInterval(PROVIDER_INTERVAL);
        }
        else {
			$(".loader").addClass("hidden");
			clearInterval(PROVIDER_INTERVAL);
			if (data.response.estado == 'COMPLETO'){//si ya proceso se obtiene la transaccion y se muestra la pantalla de confirmacion
				getConfirmationView();
			}else if(data.response.estado == 'ERROR'){
				let messageError = "Error Procesando el Pago";
				if(data.response.mensajes[0] !== null && data.response.mensajes[0] !== undefined && data.response.mensajes[0] !== "")
					messageError = data.response.mensajes[0];
				showModalAdminError(messageError);
			}else if(data.response.estado == 'PROCESANDO' || data.response.estado == 'GUARDADO'){
				checkProcessRegisterProvider();
			}
        }

    }).fail(function (request, status, error) {
        $(".loader").addClass("hidden");
        var errorData = request.responseJSON;
        ajaxErrorHandler(errorData, status, error, ID_GENERIC_ERROR);
        clearInterval(PROVIDER_INTERVAL);
        $("#buttonSalaryPaymentStep-3Loading").addClass("hidden");
        $("#buttonSalaryPaymentStep-3").removeClass("hidden");
    });
}


function getConfirmationView() {
    $(".loader").removeClass("hidden");
    $.ajax({
        type: "POST",
        url: appname + "/payprovider/confirmation",

    }).done(function (data) {
        $(".loader").addClass("hidden");
        if(data.hasError){
            if(data.errorBody.useApiMessage)
                showModalAdminError(data.errorBody.message);
            else
                showModalAdminError("Error registrando la operación.");

            redirectLoginExpired(data.errorBody.code);
        }
        else {

			  $("#step-1").addClass("hidden");
			  $("#step-2").addClass("hidden");
			  $("#step-3").addClass("hidden");
			  $("#step-4").html(data);
			  $("#step-4").removeClass("hidden");
			  $("#accountNumberDescriptionStep4").text(ACCOUNT_PROVIDER_DESCRIPTION);
			  $("#descriptionFileStep4").text(DESCRIPTION_FILE);
			  $("#step-4 .step-1-right").height($("#step-4 .step-21-left").height())
			  var height1 = $(".step-4-2-left").height()+20;
			  $(".step-4-2-left").height(height1);
			  $(".step-4-2-right").height(height1);
			  var height2 = $(".step-4-3-left").height();
			  $(".step-4-3-right").height(height2);
			  var height3 = $(".step-4-left").height();
			  $(".step-4-3-right i").css("height","100%");
			  $(".step-4-right").height(height3);
        }



    }).fail(function (errorData,status,error) {
        $(".loader").addClass("hidden");
		var dataError = errorData.responseJSON;
		ajaxErrorHandler(dataError, status, error, ID_GENERIC_ERROR);
    });
}

function confirmPaymentProviders(dinamicKey, token, aproval) {
	var txToken = $("#tokenTransactionAprobation").val();    
	DESCRIPTION_PAY = $("#payProviderDescription").text();
	$(".loader").removeClass("hidden");
	var data = {
        dinamicKey : dinamicKey,
        tokenTransactionAprobation : txToken
	};
	console.log(data);
	$.ajax({
		type : "POST",
		url : appname + "/payprovider/confirmpay",
		data : data
	}).done(function(data) {
		$(".loader").addClass("hidden");
		$("#step-1").addClass("hidden");
		$("#step-2").addClass("hidden");
		$("#step-3").addClass("hidden");
		$("#step-4").html(data);
		$("#step-4").removeClass("hidden");
		$("#providerPayStep-5").text(DESCRIPTION_PAY);
		$("#accountNumberDescriptionStep4").text(ACCOUNT_PROVIDER_DESCRIPTION);
		$("#descriptionFileStep4").text(DESCRIPTION_FILE);
		var height1 = $(".step-4-2-left").height() + 20;
		$(".step-4-2-left").height(height1);
		$(".step-4-2-right").height(height1);
		$(".modal-backdrop").remove();

	}).fail(function(request, status, error) {
		$(".loader").addClass("hidden");
        $(".modal-backdrop").remove();
		var errorData = request.responseJSON;
		$("#container-main").css('margin-top', '0px');
		ajaxErrorHandler(errorData, status, error, "genericError");
	})
}

