function condiciones() {
    $("#condiciones-ok").val("S")
}

function getSuscriptionService(action) {
    if(document.getElementById('condiciones-ok') != null) {
        var condicionesOk = document.getElementById('condiciones-ok').value;
        if(condicionesOk == 'N') {
            return
        }
    }

    if (action === "I" || action === "M") {
        var isChecked = document.getElementById('checkSuscription').checked;
        var suscription = document.getElementById('checkSuscription').value;
        if (isChecked && suscription === 'N') {
            $(".loader").removeClass("hidden");
            $("#activeSuscription").attr("disabled", "disabled");
        } else {
            return
        }
    }
    var fields = {
        action: action,
    }

    var $form = $('<form>', {
        action: appname + '/service/suscription',
        method: 'get',
    }).append(
        $.map(fields, function (val, key) {
            return $('<input>').attr({
                type: "hidden",
                name: key,
                value: val
            })
        })
    )
    $form.appendTo('body').submit();
}


function downloadPaymentRequestReturnReport(identifier) {
    var params = 'paymentIdentifier=' + identifier;
    var req = new XMLHttpRequest();
    req.open("POST", appname + "/payment/pdfpayment", true);
    req.responseType = "blob";
    req.setRequestHeader("Content-type", "application/x-www-form-urlencoded");
    req.onload = function () {
        if(req.status === 200){
            var blob = req.response;
            var fileName = 'solicitud-pago' + '-' + identifier + '.pdf';
            downloadAllReport(blob, fileName);
        }else{
            showModalGenericError("Error al generar el Comprobante");
        }


    };
    req.send(params);
}